      "text": "Of course. Here is the complete, self-contained Python script and the exact steps to properly re-run the augmentation experiment.\n\nThe key is to first install the missing `tensorflow-addons` library, which enables the discrete rotation functionality.\n\n---\n\n### Step 1: Install the Missing Library\n\nOpen your terminal or command prompt (with your `toroidal_sim_env` activated) and run this command:\n\n```bash\npip install tensorflow-addons\n```\n\nThis will add the necessary package to your environment.\n\n### Step 2: The Complete Script\n\nSave the following code as `qa_confusion_audit.py`. This is the identical, complete script from before, provided here again for your convenience.\n\n```python\n# qa_confusion_audit.py\n# Quantum Arithmetic (QA) confusion audit for Fashion-MNIST + QAConv24 Keras layer\n# Requires: tensorflow\u003e\u003d2.11, numpy, tensorflow-addons\n\nimport argparse, csv, math, os\nimport numpy as np\nimport tensorflow as tf\nfrom tensorflow.keras import layers, models\n\n# --------------------------\n# QA: integer/toroidal utils\n# --------------------------\n\ndef toroidal_shift_np(X, dy, dx):\n    return np.roll(np.roll(X, dy, axis\u003d0), dx, axis\u003d1)\n\ndef residue_spectrum_mod24(X_uint8):\n    R \u003d np.bincount((X_uint8 % 24).ravel(), minlength\u003d24)\n    return R\n\ndef ring_indices(h\u003d28, w\u003d28):\n    y,x \u003d np.indices((h,w))\n    cy,cx \u003d (h-1)/2., (w-1)/2.\n    r \u003d np.round(np.hypot(y-cy, x-cx)).astype(int)\n    rings \u003d {}\n    for rr in np.unique(r):\n        rings[rr] \u003d (r\u003d\u003drr)\n    return rings\n\ndef ring_residue_entropy(X_uint8, rings):\n    ent \u003d []\n    for rr,mask in rings.items():\n        vals \u003d (X_uint8[mask] % 24)\n        hist \u003d np.bincount(vals, minlength\u003d24).astype(np.float64)\n        s \u003d hist.sum()\n        if s \u003d\u003d 0:\n            ent.append(0.0)\n            continue\n        p \u003d hist / s\n        e \u003d float(-(p * np.log2(p + 1e-12)).sum())\n        ent.append(e)\n    return float(np.mean(ent)) if len(ent) else 0.0\n\n# --------------------------------------\n# Rank-24 INT stencil bank (3x3 kernels)\n# --------------------------------------\n\ndef _rot90(K, k):\n    R \u003d K.copy()\n    for _ in range(k % 4):\n        R \u003d np.rot90(R)\n    return R\n\ndef rank24_integer_stencils():\n    # Four oriented, integer 3x3 bases\n    B0 \u003d np.array([[ 1,  0, -1],\n                   [ 2,  0, -2],\n                   [ 1,  0, -1]], dtype\u003dint)     # E-W (0°)\n    B1 \u003d np.array([[ 1,  2,  1],\n                   [ 0,  0,  0],\n                   [-1, -2, -1]], dtype\u003dint)     # N-S (90°)\n    B2 \u003d np.array([[ 2,  1,  0],\n                   [ 1,  0, -1],\n                   [ 0, -1, -2]], dtype\u003dint)     # 45°\n    B3 \u003d np.array([[ 0,  1,  2],\n                   [-1,  0,  1],\n                   [-2, -1,  0]], dtype\u003dint)     # 135°\n\n    seeds \u003d [B0, B1, B2, B3]\n    mixes \u003d [(1,0), (2,1), (1,1), (1,2), (1,-1), (2,-1)]  # 6 phase mixes\n\n    stencils \u003d []\n    for s_idx, K in enumerate(seeds):\n        for r in range(4):  # 0,90,180,270\n            Kr \u003d _rot90(K, r)\n            Kn_base \u003d seeds[(s_idx + 1) % 4]    # neighbor orientation\n            Kn \u003d _rot90(Kn_base, r)\n            for (a,b) in mixes:\n                M \u003d a*Kr + b*Kn\n                # gcd-normalize to keep entries small\n                flat \u003d M.ravel()\n                g \u003d int(np.gcd.reduce(flat)) if np.any(flat) else 1\n                M \u003d (M // g) if g else M\n                stencils.append(M.astype(int))\n                if len(stencils) \u003d\u003d 24:\n                    return stencils\n    return stencils\n\nSTENCILS_24 \u003d rank24_integer_stencils()  # list of 24 arrays [3x3]\n\n# ---------------------------------------------------\n# Axis/Mirror tallies via toroidal 3x3 integer convs\n# ---------------------------------------------------\n\ndef conv3_toroidal_sumabs(X_uint8, K):\n    # integer 3x3 conv with wraparound; return sum of abs responses\n    X \u003d X_uint8.astype(np.int32)\n    H, W \u003d X.shape\n    acc \u003d np.zeros_like(X, dtype\u003dnp.int32)\n    for dy in (-1,0,1):\n        for dx in (-1,0,1):\n            acc +\u003d int(K[dy+1, dx+1]) * toroidal_shift_np(X, dy, dx)\n    return int(np.abs(acc).sum())\n\ndef axis_mirror_tallies(X_uint8):\n    responses \u003d [conv3_toroidal_sumabs(X_uint8, K) for K in STENCILS_24]\n    A_axis   \u003d np.array(responses[0::2], dtype\u003dnp.float64)\n    A_mirror \u003d np.array(responses[1::2], dtype\u003dnp.float64)\n    return A_axis, A_mirror\n\ndef qa_signature(X_uint8):\n    R \u003d residue_spectrum_mod24(X_uint8)\n    rings \u003d ring_indices(*X_uint8.shape)\n    ring_H \u003d ring_residue_entropy(X_uint8, rings)\n    A_axis, A_mirror \u003d axis_mirror_tallies(X_uint8)\n    resp \u003d np.zeros(24, dtype\u003dnp.float64)\n    resp[0::2] \u003d A_axis\n    resp[1::2] \u003d A_mirror\n    top \u003d int(np.argmax(resp))\n    # gap \u003d top - second (absolute magnitude gap)\n    if resp.size \u003e\u003d 2:\n        top2 \u003d np.partition(resp, -2)[-2]\n        gap \u003d float(resp[top] - top2)\n    else:\n        gap \u003d 0.0\n    ratio \u003d float((A_axis.mean()+1e-9)/(A_mirror.mean()+1e-9))\n    return {\n        \"residue_peak\": int(np.argmax(R)),\n        \"phase_top\": top,\n        \"phase_gap\": gap,\n        \"axis_mirror_ratio\": ratio,\n        \"ring_entropy\": ring_H,\n    }\n\n# -----------------------\n# Keras: QAConv24 layer\n# -----------------------\n\nclass QAConv24(layers.Layer):\n    \"\"\"\n    Fixed 24 integer 3x3 filters applied to 1 input channel (28x28 greyscale).\n    Follow with a trainable 1x1 conv (mixer) to produce out_ch channels.\n    \"\"\"\n    def __init__(self, out_ch\u003d32, use_bias\u003dFalse, name\u003d\"QAConv24\", **kwargs):\n        super().__init__(name\u003dname, **kwargs)\n        self.out_ch \u003d out_ch\n        self.use_bias \u003d use_bias\n        # Prepare fixed filter bank [kh, kw, in_ch, out_ch] for tf.nn.conv2d:\n        K \u003d np.stack(STENCILS_24, axis\u003d0)              # [24, 3, 3]\n        K \u003d K[:, :, :, np.newaxis]                     # [24, 3, 3, 1]\n        K \u003d np.transpose(K, (1,2,3,0))                 # [3,3,1,24]\n        self.K_fixed \u003d tf.constant(K, dtype\u003dtf.float32)\n        # 1x1 mixer weights (trainable): [1,1,24,out_ch]\n        w_init \u003d tf.keras.initializers.GlorotUniform()\n        self.mixer \u003d self.add_weight(\n            name\u003d\"mixer_w\", shape\u003d(1,1,24,self.out_ch), initializer\u003dw_init, trainable\u003dTrue)\n        if self.use_bias:\n            self.bias \u003d self.add_weight(\n                name\u003d\"mixer_b\", shape\u003d(self.out_ch,), initializer\u003d\"zeros\", trainable\u003dTrue)\n        else:\n            self.bias \u003d None\n\n    def call(self, x):\n        # x: [N, H, W, 1]\n        x24 \u003d tf.nn.conv2d(x, self.K_fixed, strides\u003d1, padding\u003d\"SAME\")  # [N,H,W,24]\n        y \u003d tf.nn.conv2d(x24, self.mixer, strides\u003d1, padding\u003d\"SAME\")    # [N,H,W,out_ch]\n        if self.bias is not None:\n            y \u003d tf.nn.bias_add(y, self.bias)\n        return y\n\n# -----------------------\n# Baseline \u0026 QA models\n# -----------------------\n\ndef build_baseline_cnn(num_classes\u003d10):\n    # Simple 3x3 conv stack, mirroring a common MNIST/F-MNIST starter\n    inp \u003d layers.Input(shape\u003d(28,28,1))\n    x \u003d layers.Conv2D(32, 3, padding\u003d\"same\", activation\u003d\"relu\")(inp)\n    x \u003d layers.Conv2D(64, 3, padding\u003d\"same\", activation\u003d\"relu\")(x)\n    x \u003d layers.MaxPool2D(2)(x)\n    x \u003d layers.Dropout(0.25)(x)\n    x \u003d layers.Conv2D(128, 3, padding\u003d\"same\", activation\u003d\"relu\")(x)\n    x \u003d layers.GlobalAveragePooling2D()(x)\n    x \u003d layers.Dropout(0.25)(x)\n    out \u003d layers.Dense(num_classes, activation\u003d\"softmax\")(x)\n    model \u003d models.Model(inp, out)\n    model.compile(optimizer\u003d\"adam\", loss\u003d\"sparse_categorical_crossentropy\", metrics\u003d[\"accuracy\"])\n    return model\n\ndef build_qa_frontend_cnn(num_classes\u003d10):\n    inp \u003d layers.Input(shape\u003d(28,28,1))\n    x \u003d QAConv24(out_ch\u003d32)(inp)             # fixed 24 int filters + 1x1 mixer\n    x \u003d layers.Activation(\"relu\")(x)\n    x \u003d layers.Conv2D(64, 3, padding\u003d\"same\", activation\u003d\"relu\")(x)\n    x \u003d layers.MaxPool2D(2)(x)\n    x \u003d layers.Dropout(0.25)(x)\n    x \u003d layers.Conv2D(128, 3, padding\u003d\"same\", activation\u003d\"relu\")(x)\n    x \u003d layers.GlobalAveragePooling2D()(x)\n    x \u003d layers.Dropout(0.25)(x)\n    out \u003d layers.Dense(num_classes, activation\u003d\"softmax\")(x)\n    model \u003d models.Model(inp, out)\n    model.compile(optimizer\u003d\"adam\", loss\u003d\"sparse_categorical_crossentropy\", metrics\u003d[\"accuracy\"])\n    return model\n\n# -----------------------------------------\n# QA-respectful augmentation (discretized)\n# -----------------------------------------\n\ndef qa_discrete_augment(images, labels, rot_degrees\u003d(0,15,-15), shift\u003d2, zoom\u003dFalse):\n    \"\"\"\n    Very light, integer-preserving augmentation:\n    - rotations snapped to multiples of 15°\n    - toroidal integer pixel shifts up to +/- \u0027shift\u0027 (wraparound)\n    - optional nearest-neighbor zoom (~1.085) with integer resampling\n    Returns arrays of the same shape.\n    \"\"\"\n    import tensorflow_addons as tfa\n    imgs \u003d images.copy()\n    n \u003d imgs.shape[0]\n    for i in range(n):\n        x \u003d imgs[i, ..., 0].astype(np.uint8)\n        # rotation\n        phi \u003d np.random.choice(rot_degrees)\n        if phi !\u003d 0:\n            # rotate around center with nearest-mod