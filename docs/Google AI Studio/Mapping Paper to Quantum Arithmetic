3dnp.zeros(24,dtype\u003dnp.float64); resp[0::2]\u003dA_axis; resp[1::2]\u003dA_mirror\n    top\u003dint(np.argmax(resp)); top2\u003dnp.partition(resp,-2)[-2]if resp.size\u003e\u003d2 else resp[top]\n    gap\u003dfloat(resp[top]-top2); ratio\u003dfloat((A_axis.mean()+1e-9)/(A_mirror.mean()+1e-9))\n    return {\"residue_peak\":int(np.argmax(R)),\"phase_top\":top,\"phase_gap\":gap,\"axis_mirror_ratio\":ratio,\"ring_entropy\":ring_H}\n\n# --- [Keras Layers and Models remain unchanged] ---\nclass QAConv24(layers.Layer):\n    def __init__(self, out_ch\u003d32, use_bias\u003dFalse, name\u003d\"QAConv24\", **kwargs):\n        super().__init__(name\u003dname, **kwargs); self.out_ch\u003dout_ch; self.use_bias\u003duse_bias\n        K\u003dnp.stack(STENCILS_24,axis\u003d0)[:,:,:,np.newaxis]; K\u003dnp.transpose(K,(1,2,3,0))\n        self.K_fixed\u003dtf.constant(K,dtype\u003dtf.float32)\n        self.mixer\u003dself.add_weight(name\u003d\"mixer_w\",shape\u003d(1,1,24,self.out_ch),initializer\u003d\"glorot_uniform\",trainable\u003dTrue)\n        self.bias\u003dself.add_weight(name\u003d\"mixer_b\",shape\u003d(self.out_ch,),initializer\u003d\"zeros\",trainable\u003dTrue)if use_bias else None\n    def call(self,x):\n        x24\u003dtf.nn.conv2d(x,self.K_fixed,strides\u003d1,padding\u003d\"SAME\"); y\u003dtf.nn.conv2d(x24,self.mixer,strides\u003d1,padding\u003d\"SAME\")\n        return tf.nn.bias_add(y,self.bias)if self.bias is not None else y\ndef build_qa_frontend_cnn(num_classes\u003d10):\n    inp\u003dlayers.Input(shape\u003d(28,28,1)); x\u003dQAConv24(out_ch\u003d32)(inp); x\u003dlayers.Activation(\"relu\")(x)\n    x\u003dlayers.Conv2D(64,3,padding\u003d\"same\",activation\u003d\"relu\")(x); x\u003dlayers.MaxPool2D(2)(x); x\u003dlayers.Dropout(0.25)(x)\n    x\u003dlayers.Conv2D(128,3,padding\u003d\"same\",activation\u003d\"relu\")(x); x\u003dlayers.GlobalAveragePooling2D()(x)\n    x\u003dlayers.Dropout(0.25)(x); out\u003dlayers.Dense(num_classes,activation\u003d\"softmax\")