ges \u003d tf.pad(images, paddings, \"SYMMETRIC\")\n        responses_map \u003d tf.nn.conv2d(padded_images, self.kernels, strides\u003d[1, 1, 1, 1], padding\u003d\"VALID\")\n        responses_std \u003d tf.math.reduce_std(responses_map, axis\u003d[1, 2])\n        qa_full \u003d responses_std / (tf.norm(responses_std, axis\u003d-1, keepdims\u003dTrue) + 1e-6)\n        center_images \u003d images[:, 7:21, 7:21, :]\n        padded_center \u003d tf.pad(center_images, paddings, \"SYMMETRIC\")\n        center_responses_map \u003d tf.nn.conv2d(padded_center, self.kernels, strides\u003d[1, 1, 1, 1], padding\u003d\"VALID\")\n        center_responses_std \u003d tf.math.reduce_std(center_responses_map, axis\u003d[1, 2])\n        qa_center \u003d center_responses_std / (tf.norm(center_responses_std, axis\u003d-1, keepdims\u003dTrue) + 1e-6)\n        perimeter_images \u003d images * self.perimeter_mask\n        padded_perimeter \u003d tf.pad(perimeter_images, paddings, \"SYMMETRIC\")\n        perimeter_responses_map \u003d tf.nn.conv2d(padded_perimeter, self.kernels, strides\u003d[1, 1, 1, 1], padding\u003d\"VALID\")\n        perimeter_responses_std \u003d tf.math.reduce_std(perimeter_responses_map, axis\u003d[1, 2])\n        qa_perimeter \u003d perimeter_responses_std / (tf.norm(perimeter_responses_std, axis\u003d-1, keepdims\u003dTrue) + 1e-6)\n        multi_scale_vector \u003d tf.concat([qa_full, qa_center, qa_perimeter], axis\u003d-1)\n        b \u003d responses_std[:, 0]; e \u003d responses_std[:, 6]\n        d \u003d b + e; a \u003d b + 2 * e\n        qa_tuple \u003d tf.stack([b, e, d, a], axis\u003d-1)\n        qa_tuple_norm \u003d qa_tuple / (tf.norm(qa_tuple, axis\u003d-1, keepdims\u003dTrue) + 1e-6)\n        return multi_scale_vector, qa_tuple_norm\n\n# --- [CUSTOM KERAS COMPONENTS \u0026 MODEL ARCHITECTURE] ---\nclass QAConv24(layers.Layer):\n    def __init__(self, out_ch\u003d32, use_bias\u003dFalse, name\u003d\"QAConv24\", **kwargs):\n        super().__init__(name\