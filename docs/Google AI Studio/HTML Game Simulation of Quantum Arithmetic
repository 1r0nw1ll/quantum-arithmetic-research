\"output-b\"\u003e?\u003c/span\u003e, e\u003d\u003cspan id\u003d\"output-e\"\u003e?\u003c/span\u003e, d\u003d\u003cspan id\u003d\"output-d\"\u003e?\u003c/span\u003e, a\u003d\u003cspan id\u003d\"output-a\"\u003e?\u003c/span\u003e\u003c/div\u003e\n        \u003cdiv\u003eMeasurement (Final State):\u003cbr\u003e Rounded a: \u003cspan id\u003d\"measure-a\"\u003e?\u003c/span\u003e\u003cbr\u003e b/e Ratio: \u003cspan id\u003d\"measure-ratio\"\u003e?\u003c/span\u003e\u003cbr\u003e Is (b+e) Prime?: \u003cspan id\u003d\"measure-prime\"\u003e?\u003c/span\u003e\u003cbr\u003e Probabilistic Collapse: \u003cspan id\u003d\"measure-collapse\"\u003e?\u003c/span\u003e\u003c/div\u003e\n        \u003cdiv\u003eHarmonics (Aliquot Parts of Final \u0027a\u0027):\u003cbr\u003e \u003cul id\u003d\"harmonics-list\"\u003e\u003c/ul\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv id\u003d\"sequence-output\" class\u003d\"panel\"\u003e\n        \u003ch3\u003eOperation Sequence\u003c/h3\u003e\n        \u003cdiv id\u003d\"sequence-list\"\u003eRun simulation to see sequence...\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cscript\u003e\n        // --- DOM References --- (Same as v2)\n        const inputB \u003d document.getElementById(\u0027input-b\u0027);\n        const inputE \u003d document.getElementById(\u0027input-e\u0027);\n        const inputD \u003d document.getElementById(\u0027input-d\u0027);\n        const inputCycles \u003d document.getElementById(\u0027input-cycles\u0027);\n        const runButton \u003d document.getElementById(\u0027run-op-button\u0027);\n        const shareButton \u003d document.getElementById(\u0027share-button\u0027);\n        const canvas \u003d document.getElementById(\u0027qaCanvas\u0027);\n        const ctx \u003d canvas.getContext(\u00272d\u0027);\n        const vizInfo \u003d document.getElementById(\u0027viz-info\u0027);\n        const equationViewer \u003d document.getElementById(\u0027equation-viewer\u0027);\n        const initialBOut \u003d document.getElementById(\u0027initial-b\u0027);\n        const initialEOut \u003d document.getElementById(\u0027initial-e\u0027);\n        const initialDOut \u003d document.getElementById(\u0027initial-d\u0027);\n        const cycleCountFinal \u003d document.getElementById(\u0027cycle-count-final\u0027);\n        const outputB \u003d document.getElementById(\u0027output-b\u0027);\n        const outputE \u003d document.getElementById(\u0027output-e\u0027);\n        const outputD \u003d document.getElementById(\u0027output-d\u0027);\n        const outputA \u003d document.getElementById(\u0027output-a\u0027);\n        const measureA \u003d document.getElementById(\u0027measure-a\u0027);\n        const measureRatio \u003d document.getElementById(\u0027measure-ratio\u0027);\n        const measurePrime \u003d document.getElementById(\u0027measure-prime\u0027);\n        const measureCollapse \u003d document.getElementById(\u0027measure-collapse\u0027);\n        const harmonicsList \u003d document.getElementById(\u0027harmonics-list\u0027);\n        const sequenceListDiv \u003d document.getElementById(\u0027sequence-list\u0027);\n\n        // --- QA Simulation Functions --- (Same as v2)\n        function calculateA(b, e, d) {\n             if (isNaN(b) || isNaN(e) || isNaN(d)) return NaN;\n             const insideSqrt \u003d b*b + 2*d*e + e*e;\n             return (insideSqrt \u003e\u003d 0) ? Math.sqrt(insideSqrt) : NaN;\n        }\n\n        function qaTransform(q_in) {\n            const b_in \u003d q_in.b; const e_in \u003d q_in.e; const d_in \u003d q_in.d;\n            const a_prev \u003d calculateA(b_in, e_in, d_in);\n            if (isNaN(a_prev)) return { b: NaN, e: NaN, d: NaN, a: NaN };\n            const b_out \u003d b_in + 1;\n            const e_out \u003d e_in + b_in;\n            const d_out \u003d (a_prev \u003e\u003d 0) ? Math.round(Math.sqrt(a_prev)) : 0;\n            const a_out \u003d calculateA(b_out, e_out, d_out);\n            return { b: b_out, e: e_out, d: d_out, a: a_out };\n        }\n\n        function collapseToMeasurement(a) {\n            if (isNaN(a)) return NaN;\n            const floor \u003d Math.floor(a); const ceil \u003d Math.ceil(a);\n            if (floor \u003d\u003d\u003d ceil) return floor;\n            const probFloor \u003d ceil - a;\n            return Math.random() \u003c probFloor ? floor : ceil;\n        }\n\n        function measure(q) {\n             if (isNaN(q.a) || isNaN(q.b) || isNaN(q.e)) {\n                 return { rounded_a: \u0027N/A\u0027, ratio: \u0027N/A\u0027, primeRootCheck: \u0027N/A\u0027, collapsed_a: \u0027N/A\u0027 };\n             }\n            const ratio \u003d (q.e !\u003d\u003d 0) ? (q.b / q.e).toFixed(3) : \u0027Div/0\u0027;\n            const b_plus_e \u003d q.b + q.e;\n            return {\n                rounded_a: Math.round(q.a),\n                ratio: ratio,\n                primeRootCheck: !isNaN(b_plus_e) ? isPrime(Math.round(b_plus_e)) : false,\n                collapsed_a: collapseToMeasurement(q.a)\n            };\n        }\n\n        function getAliquotParts(n) {\n            if (isNaN(n) || n \u003c\u003d 0) return [];\n            let num \u003d Math.round(n);\n            let parts \u003d [];\n            for (let i \u003d 1; i \u003c\u003d num / 2; i++) {\n                if (num % i \u003d\u003d\u003d 0) { parts.push(i); }\n            }\n            // We specifically want *proper* divisors for this visualization\n            return parts;\n        }\n\n        function isPrime(num) {\n            if (isNaN(num)) return false;\n            num \u003d Math.floor(Math.abs(num));\n            if (num \u003c\u003d 1) return false; if (num \u003c\u003d 3) return true;\n            if (num % 2 \u003d\u003d\u003d 0 || num % 3 \u003d\u003d\u003d 0) return false;\n            for (let i \u003d 5; i * i \u003c\u003d num; i \u003d i + 6) {\n                if (num % i \u003d\u003d\u003d 0 || num % (i + 2) \u003d\u003d\u003d 0) return false;\n            }\n            return true;\n        }\n\n        // --- Visualization Function --- (MODIFIED)\n        function drawModWheel(modulus \u003d 24, highlightValue \u003d null, harmonics \u003d []) { // Added harmonics parameter\n            const radius \u003d Math.min(canvas.width, canvas.height) / 2 * 0.8;\n            const center \u003d { x: canvas.width / 2, y: canvas.height / 2 };\n            const pointRadius \u003d Math.min(15, Math.max(5, radius / modulus * 1.5));\n\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            ctx.beginPath();\n            ctx.arc(center.x, center.y, radius, 0, 2 * Math.PI);\n            ctx.strokeStyle \u003d \"#aaa\";\n            ctx.lineWidth \u003d 1;\n            ctx.stroke();\n\n            let highlightedIndex \u003d -1;\n             if (highlightValue !\u003d\u003d null \u0026\u0026 !isNaN(highlightValue)) {\n                 highlightedIndex \u003d Math.round(highlightValue) % modulus;\n                 if (highlightedIndex \u003c 0) highlightedIndex +\u003d modulus;\n             }\n\n            // Store positions for linking later\n            const positions \u003d {};\n\n            // Draw points and store positions\n            for (let i \u003d 0; i \u003c modulus; i++) {\n                let angle \u003d (2 * Math.PI * i / modulus) - (Math.PI / 2);\n                let x \u003d center.x + radius * Math.cos(angle);\n                let y \u003d center.y + radius * Math.sin(angle);\n                positions[i] \u003d { x, y }; // Store position by index\n\n                ctx.beginPath();\n                ctx.arc(x, y, pointRadius, 0, 2 * Math.PI);\n\n                if (i \u003d\u003d\u003d highlightedIndex) {\n                    ctx.fillStyle \u003d \"orange\"; ctx.fill(); ctx.strokeStyle \u003d \"black\"; ctx.lineWidth \u003d 2;\n                } else {\n                     ctx.fillStyle \u003d i % 2 \u003d\u003d\u003d 0 ? \"lightblue\" : \"lightgreen\"; ctx.fill(); ctx.strokeStyle \u003d \"#555\"; ctx.lineWidth \u003d 1;\n                }\n                 ctx.stroke();\n\n                ctx.fillStyle \u003d \"black\";\n                ctx.font \u003d `${Math.max(9, Math.min(12, pointRadius))}px sans-serif`;\n                ctx.textAlign \u003d \"center\"; ctx.textBaseline \u003d \"middle\";\n                ctx.fillText(i, x, y);\n            }\n\n            // --- NEW: Draw Harmonic Links ---\n            if (harmonics \u0026\u0026 harmonics.length \u003e\u003d 2) {\n                const harmonicIndices \u003d harmonics\n                    .map(h \u003d\u003e h % modulus) // Map harmonic value to its index on the wheel\n                    .filter((val, idx, self) \u003d\u003e self.indexOf(val) \u003d\u003d\u003d idx) // Keep unique indices\n                    .sort((a, b) \u003d\u003e a - b); // Sort indices for sequential drawing\n\n                if (harmonicIndices.length \u003e\u003d 2) {\n                    ctx.beginPath();\n                    ctx.strokeStyle \u003d \"rgba(255, 0, 0, 0.6)\"; // Red, semi-transparent links\n                    ctx.lineWidth \u003d 2;\n\n                    // Move to the first harmonic point\n                    const firstIndex \u003d harmonicIndices[0];\n                    if (positions[firstIndex]) { // Check if position exists (it should)\n                         ctx.moveTo(positions[firstIndex].x, positions[firstIndex].y);\n\n                         // Line to subsequent harmonic points\n                         for (let i \u003d 1; i \u003c harmonicIndices.length; i++) {\n                             const currentIndex \u003d harmonicIndices[i];\n                             if (positions[currentIndex]) {\n                                 ctx.lineTo(positions[currentIndex].x, positions[currentIndex].y);\n                             }\n                         }\n\n                         // Optional: Close the loop by connecting the last point back to the first\n                         ctx.lineTo(positions[firstIndex].x, positions[firstIndex].y);\n\n                         ctx.stroke(); // Draw the harmonic polygon/path\n                    }\n                }\n            }\n            // --- End Harmonic Links ---\n\n\n             // Update viz-info text (same as before)\n            if (highlightedIndex !\u003d\u003d -1) {\n                 vizInfo.textContent \u003d `Highlighting final ~a mod ${modulus} \u003d ${Math.round(highlightValue)} mod ${modulus} \u003d ${highlightedIndex}. Links show aliquot parts.`;\n            } else if (highlightValue \u003d\u003d\u003d null) {\n                 vizInfo.textContent \u003d `Mod-${modulus} Wheel`;\n             } else {\n                  vizInfo.textContent \u003d `Mod-${modulus} Wheel (Invalid \u0027a\u0027 for highlighting)`;\n             }\n        }\n\n        // --- Update Display Functions --- (Same as v2, except updateFinalDisplay passes harmonics list)\n        function updateFinalDisplay(initialQuNit, finalQuNit, measurement, harmonics, cycleCount) { // Added harmonics to args\n            initialBOut.textContent \u003d initialQuNit.b; initialEOut.textContent \u003d initialQuNit.e; initialDOut.textContent \u003d initialQuNit.d;\n            cycleCountFinal.textContent \u003d cycleCount;\n            outputB.textContent \u003d isNaN(finalQuNit.b) ? \u0027Error\u0027 : finalQuNit.b;\n            outputE.textContent \u003d isNaN(finalQuNit.e) ? \u0027Error\u0027 : finalQuNit.e;\n            outputD.textContent \u003d isNaN(finalQuNit.d) ? \u0027Error\u0027 : finalQuNit.d;\n            outputA.textContent \u003d isNaN(finalQuNit.a) ? \u0027Error\u0027 : finalQuNit.a.toFixed(3);\n            measureA.textContent \u003d measurement.rounded_a; measureRatio.textContent \u003d measurement.ratio;\n            measurePrime.textContent \u003d measurement.primeRootCheck ? \u0027Yes\u0027 : \u0027No\u0027;\n            measureCollapse.textContent \u003d measurement.collapsed_a;\n\n            harmonicsList.innerHTML \u003d \u0027\u0027; // Clear previous list\n            if (harmonics.length \u003e 0) {\n                harmonics.forEach(part \u003d\u003e {\n                    const li \u003d document.createElement(\u0027li\u0027);\n                    li.textContent \u003d part;\n                    harmonicsList.appendChild(li);\n                });\n            } else {\n                 harmonicsList.innerHTML \u003d isNaN(finalQuNit.a) ? \u0027\u003cli\u003eError\u003c/li\u003e\u0027 : \u0027\u003cli\u003eNone\u003c/li\u003e\u0027;\n            }\n        }\n\n        function updateSequenceDisplay(sequence) { // (Same as v2)\n             sequenceListDiv.innerHTML \u003d \u0027\u0027;\n             if (!sequence || sequence.length \u003d\u003d\u003d 0) { sequenceListDiv.textContent \u003d \u0027No sequence data.\u0027; return; }\n             sequence.forEach((state, index) \u003d\u003e {\n                 const itemDiv \u003d document.createElement(\u0027div\u0027); itemDiv.classList.add(\u0027sequence-item\u0027);\n                 itemDiv.innerHTML \u003d `\u003cstrong\u003eStep ${index}:\u003c/strong\u003e\u003cbr\u003e b\u003d\u003cspan class\u003d\"seq-b\"\u003e${isNaN(state.b)?\u0027Err\u0027:state.b}\u003c/span\u003e, e\u003d\u003cspan class\u003d\"seq-e\"\u003e${isNaN(state.e)?\u0027Err\u0027:state.e}\u003c/span\u003e, d\u003d\u003cspan class\u003d\"seq-d\"\u003e${isNaN(state.d)?\u0027Err\u0027:state.d}\u003c/span\u003e, a\u003d\u003cspan class\u003d\"seq-a\"\u003e${isNaN(state.a)?\u0027Err\u0027:state.a.toFixed(3)}\u003c/span\u003e`;\n                 sequenceListDiv.appendChild(itemDiv);\n             });\n         }\n\n        function updateEquationViewer(b, e, d) { // (Same as v2)\n             if (isNaN(b) || isNaN(e) || isNaN(d)) { equationViewer.textContent \u003d \"a \u003d √[ b² + 2de + e² ] - Invalid inputs\"; return; }\n             const bStr \u003d b.toString(); const eStr \u003d e.toString(); const dStr \u003d d.toString();\n             const aValue \u003d calculateA(b,e,d); const aStr \u003d isNaN(aValue) ? \u0027Error\u0027 : aValue.toFixed(4);\n             equationViewer.innerHTML \u003d `Current Formula:\u003cbr\u003e a \u003d \u0026radic;[ b² + 2de + e² ]\u003cbr\u003e Substituting Initial Values:\u003cbr\u003e a \u003d \u0026radic;[ (${bStr})² + 2×(${dStr})×(${eStr}) + (${eStr})² ]\u003cbr\u003e Resulting Initial \u0027a\u0027 ≈ ${aStr}`;\n         }\n\n        // --- Event Listeners --- (MODIFIED runButton listener)\n        runButton.addEventListener(\u0027click\u0027, () \u003d\u003e {\n            const bVal \u003d parseInt(inputB.value, 10); const eVal \u003d parseInt(inputE.value, 10); const dVal \u003d parseInt(inputD.value, 10); const numCycles \u003d parseInt(inputCycles.value, 10);\n            if (isNaN(bVal) || isNaN(eVal) || isNaN(dVal) || isNaN(numCycles) || numCycles \u003c 1) { alert(\"Please enter valid numbers for b, e, d, and cycles.\"); return; }\n            updateEquationViewer(bVal, eVal, dVal);\n\n            const initialQuNit \u003d { b: bVal, e: eVal, d: dVal };\n            let currentQuNit \u003d initialQuNit;\n            const sequence \u003d [currentQuNit];\n\n            for (let i \u003d 0; i \u003c numCycles; i++) {\n                currentQuNit \u003d qaTransform(currentQuNit); sequence.push(currentQuNit);\n                if (isNaN(currentQuNit.a)) { console.error(`Calculation error at cycle ${i + 1}`); break; }\n            }\n            const finalQuNit \u003d currentQuNit;\n            const finalMeasurement \u003d measure(finalQuNit);\n            const finalHarmonics \u003d getAliquotParts(finalQuNit.a); // Calculate harmonics\n\n            updateFinalDisplay(initialQuNit, finalQuNit, finalMeasurement, finalHarmonics, sequence.length - 1);\n            updateSequenceDisplay(sequence);\n\n            // Pass finalHarmonics to the drawing function\n            drawModWheel(24, finalQuNit.a, finalHarmonics); // MODIFIED CALL\n        });\n\n        shareButton.addEventListener(\u0027click\u0027, () \u003d\u003e { // (Same as v2)\n             const bVal \u003d inputB.value; const eVal \u003d inputE.value; const dVal \u003d inputD.value; const cyclesVal \u003d inputCycles.value;\n             const url \u003d new URL(window.location.href);\n             url.searchParams.set(\u0027b\u0027, bVal); url.searchParams.set(\u0027e\u0027, eVal); url.searchParams.set(\u0027d\u0027, dVal); url.searchParams.set(\u0027cycles\u0027, cyclesVal);\n             navigator.clipboard.writeText(url.toString()).then(() \u003d\u003e { alert(\u0027Share URL copied!\u0027); }).catch(err \u003d\u003e { console.error(\u0027Copy failed: \u0027, err); alert(\u0027Failed to copy URL.\u0027); });\n         });\n\n        // --- Initialization --- (Same as v2)\n        function initialize() {\n            const urlParams \u003d new URLSearchParams(window.location.search);\n            const bParam \u003d urlParams.get(\u0027b\u0027); const eParam \u003d urlParams.get(\u0027e\u0027); const dParam \u003d urlParams.get(\u0027d\u0027); const cyclesParam \u003d urlParams.get(\u0027cycles\u0027);\n            if (bParam !\u003d\u003d null) inputB.value \u003d bParam; if (eParam !\u003d\u003d null) inputE.value \u003d eParam; if (dParam !\u003d\u003d null) inputD.value \u003d dParam; if (cyclesParam !\u003d\u003d null) inputCycles.value \u003d cyclesParam;\n            drawModWheel(24); // Draw initial empty wheel\n            runButton.click(); // Run with potentially loaded params\n         }\n        initialize();\n\n    \u003c/script\u003e\n\n\u003c/body\u003e\n\u003c/html\u003e\n```\n\n**How it Works Now:**\n\n1.  When you click \"Run QA Operation(s)\", the `finalHarmonics` (aliquot parts of the final `a`) are calculated.\n2.  This `finalHarmonics` array is passed to the `drawModWheel` function.\n3.  Inside `drawModWheel`, after the standard wheel and points are drawn:\n    *   It maps the harmonic numbers (e.g., `[1, 2, 3, 4, 6, 8, 12]` if `a` rounds to 24) to their corresponding indices modulo 24 (e.g., `[1, 2, 3, 4, 6, 8, 12]`).\n    *   It retrieves the pre-calculated coordinates (`x`, `y`) for each of these indices.\n    *   It draws lines connecting these points sequentially (1 -\u003e 2 -\u003e 3 -\u003e 4 -\u003e 6 -\u003e 8 -\u003e 12 -\u003e 1), creating a polygon or path that represents the harmonic structure on the wheel.\n    *   The lines are drawn in semi-transparent red to stand out.\n\n**Try It Out:**\n\nRun the simulation with different inputs and cycle counts. Observe how the red harmonic links change based on the final `a` value. For example:\n\n*   If `a` rounds to **12**, you should see links connecting points 1, 2, 3, 4, 6.\n*   If `a` rounds to **13** (prime), it has no proper divisors, so no links will be drawn.\n*   If `a` rounds to **24**, you\u0027ll see links connecting 1, 2, 3, 4, 6, 8, 12.\n\nThis adds a beautiful and meaningful layer to the visualization!\n\nReady for the next step? Shall we tackle the **Reverse QA Transform (2)** or the **Animation (bold option)**? Or perhaps refine the harmonic link drawing (e.g., Bezier curves, different connection logic)?",
