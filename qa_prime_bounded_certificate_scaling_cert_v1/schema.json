{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QA_PRIME_BOUNDED_CERTIFICATE_SCALING_CERT.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cert_type",
    "certificate_id",
    "title",
    "created_utc",
    "claim",
    "evidence",
    "rows",
    "result",
    "digests"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "QA_PRIME_BOUNDED_CERTIFICATE_SCALING_CERT.v1"
    },
    "cert_type": {
      "type": "string",
      "const": "qa_prime_bounded_certificate_scaling_cert"
    },
    "certificate_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 200
    },
    "title": {
      "type": "string",
      "minLength": 8,
      "maxLength": 400
    },
    "created_utc": {
      "type": "string",
      "minLength": 20,
      "maxLength": 40
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interval_start",
        "predictor",
        "target_property",
        "scope",
        "honest_interpretation"
      ],
      "properties": {
        "interval_start": {
          "type": "integer",
          "minimum": 2
        },
        "predictor": {
          "type": "string",
          "const": "largest_prime_leq_sqrt_end"
        },
        "target_property": {
          "type": "string",
          "const": "minimal_pass_prime_max"
        },
        "scope": {
          "type": "string",
          "const": "empirical_tested_endpoints_only"
        },
        "honest_interpretation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_path",
        "artifact_canonical_hash",
        "experiment_id",
        "hypothesis",
        "success_criteria"
      ],
      "properties": {
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "artifact_canonical_hash": {
          "$ref": "#/definitions/sha256"
        },
        "experiment_id": {
          "type": "string",
          "minLength": 1
        },
        "hypothesis": {
          "type": "string",
          "minLength": 1
        },
        "success_criteria": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/row"
      }
    },
    "result": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "digests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_sha256"
      ],
      "properties": {
        "canonical_sha256": {
          "$ref": "#/definitions/sha256"
        }
      }
    }
  },
  "definitions": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "end",
        "sqrt_floor",
        "candidate_caps",
        "observed_minimal_pass_prime_max",
        "predicted_largest_prime_leq_sqrt_end",
        "matches_prediction"
      ],
      "properties": {
        "end": {
          "type": "integer",
          "minimum": 4
        },
        "sqrt_floor": {
          "type": "integer",
          "minimum": 2
        },
        "candidate_caps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 2
          }
        },
        "observed_minimal_pass_prime_max": {
          "type": "integer",
          "minimum": 2
        },
        "predicted_largest_prime_leq_sqrt_end": {
          "type": "integer",
          "minimum": 2
        },
        "matches_prediction": {
          "type": "boolean"
        }
      }
    }
  }
}
