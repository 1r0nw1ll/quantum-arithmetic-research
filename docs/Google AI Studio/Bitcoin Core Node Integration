tion/json\u0027}\n\n    try:\n        response \u003d requests.post(url, headers\u003dheaders, data\u003dpayload, auth\u003d(RPC_USER, RPC_PASSWORD))\n        response.raise_for_status() # Raise HTTPError for bad responses (4xx or 5xx)\n        rpc_response \u003d response.json()\n        if rpc_response.get(\u0027error\u0027) is not None:\n            raise Exception(f\"RPC Error: {rpc_response[\u0027error\u0027]}\")\n        return rpc_response[\u0027result\u0027]\n    except requests.exceptions.RequestException as e:\n        raise Exception(f\"HTTP Request failed: {e}\")\n    except Exception as e:\n        raise Exception(f\"RPC call failed: {e}\")\n\n\n# ----------------------------------------------------------------------------\n# Step 1: Tuple Generation (from numeric value)\n# ----------------------------------------------------------------------------\n# This function remains the same as it processes numeric values derived from header components\ndef qa_tuple(numeric_value):\n    # Ensure numeric_value is integer before modulo/division\n    numeric_value \u003d int(numeric_value)\n    b \u003d numeric_value % 9 or 1\n    e \u003d (numeric_value // 9) % 9 or 1\n    d \u003d b + e\n    a \u003d b + 2 * e\n    return [b, e, d, a] # Return as list for easier feature concatenation\n\n\n# ----------------------------------------------------------------------------\n# Step 2: QA Tuple to Hash Projection (Placeholder/Example)\n# This is where your specific RHPF/harmonic mapping logic would go.\n# For now, using a placeholder harmonic sum based on tuple values.\n# ----------------------------------------------------------------------------\ndef qa_tuple_to_harmonic_sum(qa_tuples_dict):\n    \"\"\"\n    Example placeholder: combine tuple components into a single numeric value.\n    Replace with your RHPF/harmonic projection logic.\n    Input: dict of tuples {component_name: [b, e, d, a]}\n    Output: single numeric value representing the harmonic projection.\n    \"\"\"\n    total \u003d 0\n    # Sum contributions from each tuple component in the block header\n    for t in qa_tuples_dict.values():\n        # Example placeholder logic: sum of tuple elements squared\n        total +\u003d (t[0]**2 + t[1]**2 + t[2]**2 + t[3]**2)\n        # Add modular contributions (example placeholder)\n        total +\u003d (t[3] % 24) * 100 + (t[3] % 72) * 10 + (t[3] % 144)\n    return total\n\n\n# ----------------------------------------------------------------------------\n# Step 3: Real Block Hash Calculator (SHA256)\n# Updated to accept header data dictionary from RPC\n# ----------------------------------------------------------------------------\ndef compute_real_hash(header_data):\n    # Need to get block hash by height first to pass to getblock 2\n    # This function should ideally accept the raw header bytes directly if possible\n    # or reconstruct them precisely from the RPC fields.\n    # For now, reconstructing from RPC output fields which should be byte-identical.\n    try:\n        # RPC returns hex strings for hash fields, need to convert to bytes (little-endian)\n        version_bytes \u003d int(header_data[\u0027version\u0027]).to_bytes(4, byteorder\u003d\u0027little\u0027)\n        prev_block_bytes \u003d bytes.fromhex(header_data[\u0027previousblockhash\u0027])[::-1] # RPC is big-endian hex string, needs little-endian bytes\n        merkle_root_bytes \u003d bytes.fromhex(header_data[\u0027merkle_root\u0027])[::-1]    # RPC is big-endian hex string, needs little-endian bytes\n        timestamp_bytes \u003d int(header_data[\u0027time\u0027]).to_bytes(4, byteorder\u003d\u0027little\u0027)\n        # RPC returns \u0027bits\u0027 as hex string, need to convert to int then bytes\n        bits_bytes \u003d int(header_data[\u0027bits\u0027], 16).to_bytes(4, byteorder\u003d\u0027little\u0027)\n        nonce_bytes \u003d int(header_data[\u0027nonce\u0027]).to_bytes(4, byteorder\u003d\u0027little\u0027)\n\n        header_bin \u003d (\n            version_bytes +\n            prev_block_bytes +\n            merkle_root_bytes +\n            timestamp_bytes +\n            bits_bytes +\n            nonce_bytes\n        )\n\n        hash1 \u003d hashlib.sha256(header_bin).digest()\n        hash2 \u003d hashlib.sha256(hash1).digest()\n        return hash2[::-1].hex() # Return big-endian hex string\n    except Exception as e:\n        print(f\"Error computing real hash: {e}\")\n        # Fallback to a placeholder or indicate failure\n        return \"error_computing_hash\"\n\n\n# ----------------------------------------------------------------------------\n# Step 4: Fetch Block Data using RPC\n# ----------------------------------------------------------------------------\ndef fetch_block_data_rpc(height):\n    try:\n        block_hash \u003d call_rpc(\u0027getblockhash\u0027, [height])\n        # Verbosity 2 gives the block header fields directly\n        block_data \u003d call_rpc(\u0027getblock\u0027, [block_hash, 2])\n\n        # Extract relevant header fields. Note: field names in RPC may differ slightly\n        # from Blockstream API or standard header structure representation.\n        # Common names are: version, previousblockhash, merkleroot, time, bits, nonce\n        # Need to handle potential KeyError if field names differ.\n        header_fields \u003d {\n            \u0027version\u0027: block_data.get(\u0027version\u0027),\n            \u0027previousblockhash\u0027: block_data.get(\u0027previousblockhash\u0027),\n            \u0027merkle_root\u0027: block_data.get(\u0027merkleroot\u0027), # Note: RPC uses \u0027merkleroot\u0027\n            \u0027time\u0027: block_data.get(\u0027time\u0027), # Note: RPC uses \u0027time\u0027 instead of \u0027timestamp\u0027\n            \u0027bits\u0027: block_data.get(\u0027bits\u0027),\n            \u0027nonce\u0027: block_data.get(\u0027nonce\u0027),\n            # Store height for results logging\n            \u0027height\u0027: height\n        }\n\n        # Ensure all necessary fields were found\n        required_fields \u003d [\u0027version\u0027, \u0027previousblockhash\u0027, \u0027merkle_root\u0027, \u0027time\u0027, \u0027bits\u0027, \u0027nonce\u0027]\n        if not all(header_fields.get(f) is not None for f in required_fields):\n             raise Exception(f\"Missing required header fields in RPC response for block {height}\")\n\n\n        return header_fields\n\n    except Exception as e:\n        print(f\"Failed to fetch block data for height {height} via RPC: {e}\")\n        return None # Indicate failure\n\n\n# ----------------------------------------------------------------------------\n# Step 5: Main Prediction Loop (Batch Testing)\n# Updated to use RPC fetcher and integrate the QA tuple generation and hash guess\n# ----------------------------------------------------------------------------\ndef batch_test_blocks_rpc(start_height, num_blocks):\n    results \u003d []\n\n    print(f\"\\nStarting RPC batch test for {num_blocks} blocks from height {start_height}...\")\n\n    for i in range(num_blocks):\n        height \u003d start_height + i\n        print(f\"\\nProcessing block {height}...\")\n\n        header_data \u003d fetch_block_data_rpc(height)\n\n        if header_data is None:\n            print(f\"Skipping block {height} due to fetch failure.\")\n            continue\n\n        # Generate QA tuples for header components\n        # Need to ensure header_data values are integers where expected by qa_tuple\n        try:\n            qa_tuples_dict \u003d {\n                \u0027version\u0027: qa_tuple(header_data[\u0027version\u0027]),\n                \u0027prev_block\u0027: qa_tuple(int(header_data[\u0027previousblockhash\u0027], 16)),\n                \u0027merkle_root\u0027: qa_tuple(int(header_data[\u0027merkle_root\u0027], 16)),\n                \u0027time\u0027: qa_tuple(header_data[\u0027time\u0027]),\n                \u0027bits\u0027: qa_tuple(int(header_data[\u0027bits\u0027], 16)),\n                \u0027nonce\u0027: qa_tuple(header_data[\u0027nonce\u0027])\n            }\n        except Exception as e:\n             print(f\"Error generating QA tuples for block {height}: {e}\")\n             continue\n\n\n        # Predict hash using your QA logic\n        try:\n            predicted_hash_numeric \u003d qa_tuple_to_harmonic_sum(qa_tuples_dict)\n            predicted_hash_hex \u003d hex(predicted_hash_numeric)[2:].zfill(64)\n        except Exception as e:\n             print(f\"Error predicting hash for block {height}: {e}\")\n             predicted_hash_hex \u003d \"error_predicting_hash\"\n             predicted_hash_numeric \u003d -1 # Use a sentinel value\n\n\n        # Compute the real hash\n        real_hash \u003d compute_real_hash(header_data)\n\n        error \u003d \"N/A\"\n        if real_hash !\u003d \"error_computing_hash\" and predicted_hash_numeric !\u003d -1:\n             try:\n                real_numeric \u003d int(real_hash, 16)\n                error \u003d abs(predicted_hash_numeric - real_numeric)\n             except Exception as e:\n                 error \u003d f\"Error calculating error: {e}\"\n\n\n        results.append({\n            \u0027block_height\u0027: height,\n            \u0027predicted_hash\u0027: predicted_hash_hex,\n            \u0027real_hash\u0027: real_hash,\n            \u0027error\u0027: str(error) # Save error as string to handle large values\n        })\n\n        print(f\"  Predicted Hash: {predicted_hash_hex[:20]}...\")\n        print(f\"  Real Hash:      {real_hash[:20]}...\")\n        print(f\"  Error:          {error}\")\n\n\n    # ------------------------------------------------------------------------\n    # Save Results\n    # ------------------------------------------------------------------------\n    results_df \u003d pd.DataFrame(results)\n    results_filename \u003d f\u0027qa_hash_prediction_rpc_results_{start_height}_to_{start_height+num_blocks-1}.csv\u0027\n    results_df.to_csv(results_filename, index\u003dFalse)\n    print(f\"\\nResults saved to {results_filename}\")\n\n    return results_df\n\n\n# ----------------------------------------------------------------------------\n# Execution (Ensure your Bitcoin Core node is running with RPC enabled)\n# ----------------------------------------------------------------------------\nif __name__ \u003d\u003d \"__main__\":\n    # --- Configure your test run ---\n    test_start_height \u003d 680000 # Start height for the test batch\n    test_num_blocks \u003d 10      # Number of blocks to process in this batch\n\n    # --- Run the batch test ---\n    results_dataframe \u003d batch_test_blocks_rpc(test_start_height, test_num_blocks)\n\n    # --- Optional: Analyze/Plot Results ---\n    # You can now use results_dataframe for plotting or further analysis\n    # based on the \u0027block_height\u0027 and \u0027error\u0027 columns.\n    # Example: Plotting code using the returned dataframe\n    if not results_dataframe.empty and \u0027error\u0027 in results_dataframe.columns:\n         # Convert \u0027error\u0027 column to numeric, coercing errors to NaN\n        results_dataframe[\u0027error_numeric\u0027] \u003d pd.to_numeric(results_dataframe[\u0027error\u0027], errors\u003d\u0027coerce\u0027)\n\n        if not results_dataframe[\u0027error_numeric\u0027].dropna().empty:\n            plt.figure(figsize\u003d(10, 6))\n            plt.plot(results_dataframe[\u0027block_height\u0027], results_dataframe[\u0027error_numeric\u0027], marker\u003d\u0027o\u0027, linestyle\u003d\u0027-\u0027, color\u003d\u0027blue\u0027)\n            plt.yscale(\u0027log\u0027)\n            plt.title(\u0027QA Hash Prediction Error vs Block Height (RPC)\u0027)\n            plt.xlabel(\u0027Block Height\u0027)\n            plt.ylabel(\u0027Absolute Error (log scale)\u0027)\n            plt.grid(True, which\u003d\u0027both\u0027, linestyle\u003d\u0027--\u0027, linewidth\u003d0.5)\n            plt.tight_layout()\n            plt.s