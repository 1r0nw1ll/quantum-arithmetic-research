{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "QA_EPISODE_REGIME_CERT.v1.0",
  "title": "QA Episode Regime Transitions Cert",
  "description": "Session-level cert over an ordered sequence of episode primary labels. Certifies transition matrix, drift declaration, and regime composition.",
  "type": "object",
  "required": [
    "schema_version",
    "cert_id",
    "episodes",
    "expected_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "QA_EPISODE_REGIME_CERT.v1.0"
    },
    "cert_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "episodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["episode_id", "primary_label"],
        "additionalProperties": false,
        "properties": {
          "episode_id": {
            "type": "string",
            "minLength": 1
          },
          "primary_label": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "expected_summary": {
      "type": "object",
      "required": [
        "episode_count",
        "escalation_count",
        "recovery_count",
        "neutral_count",
        "drift_declaration",
        "regime_sequence",
        "transition_matrix",
        "max_run_length",
        "max_run_label"
      ],
      "additionalProperties": false,
      "properties": {
        "episode_count": {
          "type": "integer",
          "minimum": 1
        },
        "escalation_count": {
          "type": "integer",
          "minimum": 0
        },
        "recovery_count": {
          "type": "integer",
          "minimum": 0
        },
        "neutral_count": {
          "type": "integer",
          "minimum": 0
        },
        "drift_declaration": {
          "type": "string",
          "enum": ["ESCALATING", "RECOVERING", "STABLE", "MIXED"]
        },
        "regime_sequence": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["ESCALATION", "RECOVERY", "NEUTRAL"]
          }
        },
        "transition_matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from_label", "to_label", "count"],
            "additionalProperties": false,
            "properties": {
              "from_label": {"type": "string", "minLength": 1},
              "to_label": {"type": "string", "minLength": 1},
              "count": {"type": "integer", "minimum": 1}
            }
          }
        },
        "max_run_length": {
          "type": "integer",
          "minimum": 1
        },
        "max_run_label": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
