y[\u0027loss\u0027]) for h in histories])\n    \n    # Initialize arrays for averaged metrics with padding\n    average_loss \u003d np.zeros(max_epochs)\n    average_accuracy \u003d np.zeros(max_epochs)\n    average_val_loss \u003d np.zeros(max_epochs)\n    average_val_accuracy \u003d np.zeros(max_epochs)\n\n    for history in histories:\n        loss \u003d np.array(history.history[\u0027loss\u0027])\n        accuracy \u003d np.array(history.history[\u0027accuracy\u0027])\n        val_loss \u003d np.array(history.history[\u0027val_loss\u0027])\n        val_accuracy \u003d np.array(history.history[\u0027val_accuracy\u0027])\n\n         # Padding to max_epochs length using zeros.\n        loss \u003d np.pad(loss, (0, max_epochs - len(loss)), \u0027constant\u0027)\n        accuracy \u003d np.pad(accuracy, (0, max_epochs - len(accuracy)), \u0027constant\u0027)\n        val_loss \u003d np.pad(val_loss, (0, max_epochs - len(val_loss)), \u0027constant\u0027)\n        val_accuracy \u003d np.pad(val_accuracy, (0, max_epochs - len(val_accuracy)), \u0027constant\u0027)\n\n        average_loss +\u003d loss\n        average_accuracy +\u003d accuracy\n        average_val_loss +\u003d val_loss\n        average_val_accuracy +\u003d val_accuracy\n    \n    average_loss /\u003d len(histories)\n    average_accuracy /\u003d len(histories)\n    average_val_loss /\u003d len(histories)\n    average_val_accuracy /\u003d len(histories)\n\n    plt.figure(figsize\u003d(12, 6))\n    plt.plot(smooth_curve(average_loss), label\u003d\u0027Train Loss\u0027)\n    plt.plot(smooth_curve(average_val_loss), label\u003d\u0027Validation Loss\u0027)\n    plt.xlabel(\u0027Epochs\u0027)\n    plt.ylabel(\u0027Loss\u0027)\n    plt.legend()\n    plt.title(\u0027Average CNN Loss Over Epochs (Cross-Validation)\u0027)\n    plt.show()\n\n    plt.figure(figsize\u003d(12, 6))\n    plt.plot(smooth_curve(average_accuracy), label\u003d\u0027Train Accuracy\u0027)\n    plt.plot(smooth_curve(average_val_accuracy), label\