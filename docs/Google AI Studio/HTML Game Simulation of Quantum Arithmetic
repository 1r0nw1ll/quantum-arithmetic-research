 border: 1px dashed #aab; border-radius: 4px; font-family: monospace; word-wrap: break-word; font-size: 0.9em; }\n        .sequence-item { border-bottom: 1px dotted #ccc; margin-bottom: 8px; padding-bottom: 8px; transition: background-color 0.3s ease; cursor: pointer; }\n        .sequence-item:last-child { border-bottom: none; }\n        .sequence-item.active { background-color: #d1ecf1; border-left: 3px solid #007bff; padding-left: 5px;}\n    \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\n    \u003cdiv id\u003d\"controls\" class\u003d\"panel\"\u003e\n        \u003ch3\u003eForward Simulation Controls\u003c/h3\u003e\n        \u003clabel for\u003d\"input-b\"\u003eInitial b:\u003c/label\u003e\n        \u003cinput type\u003d\"number\" id\u003d\"input-b\" value\u003d\"3\"\u003e\n        \u003clabel for\u003d\"input-e\"\u003eInitial e:\u003c/label\u003e\n        \u003cinput type\u003d\"number\" id\u003d\"input-e\" value\u003d\"4\"\u003e\n        \u003clabel for\u003d\"input-d\"\u003eInitial d:\u003c/label\u003e\n        \u003cinput type\u003d\"number\" id\u003d\"input-d\" value\u003d\"5\"\u003e\n        \u003clabel for\u003d\"input-cycles\"\u003eMax Cycles:\u003c/label\u003e\n        \u003cinput type\u003d\"number\" id\u003d\"input-cycles\" value\u003d\"10\" min\u003d\"1\" max\u003d\"100\"\u003e\n\n        \u003cdiv class\u003d\"control-group\"\u003e\n             \u003cbutton id\u003d\"generate-button\"\u003eGenerate Sequence / Reset\u003c/button\u003e\n             \u003cbutton id\u003d\"share-button\"\u003eCopy Share URL\u003c/button\u003e\n        \u003c/div\u003e\n\n        \u003c!-- Animation Controls --\u003e\n        \u003cdiv class\u003d\"control-group\"\u003e\n            \u003clabel for\u003d\"speed-slider\"\u003eAnimation Speed (ms/step): \u003cspan id\u003d\"speed-value\"\u003e500\u003c/span\u003ems\u003c/label\u003e\n            \u003cinput type\u003d\"range\" id\u003d\"speed-slider\" min\u003d\"50\" max\u003d\"2000\" value\u003d\"500\" step\u003d\"50\"\u003e\n            \u003cbutton id\u003d\"play-button\" disabled\u003ePlay ▶\u003c/button\u003e\n            \u003cbutton id\u003d\"pause-button\" disabled\u003ePause ⏸\u003c/button\u003e\n            \u003cbutton id\u003d\"reset-button\" disabled\u003eReset ⏮\u003c/button\u003e\n        \u003c/div\u003e\n\n        \u003cdiv id\u003d\"equation-viewer\"\u003eInitial state: a \u003d \u0026radic;[ b² + 2de + e² ]\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003c!-- New Panel for Reverse Operation --\u003e\n    \u003cdiv id\u003d\"reverse-controls\" class\u003d\"panel\"\u003e\n        \u003ch3\u003eReverse Operation\u003c/h3\u003e\n        \u003cp\u003eEnter a state (b\u0027, e\u0027, d\u0027) and find possible previous states (b, e, d).\u003c/p\u003e\n        \u003clabel for\u003d\"reverse-b\"\u003eInput b\u0027:\u003c/label\u003e\n        \u003cinput type\u003d\"number\" id\u003d\"reverse-b\" value\u003d\"4\"\u003e \u003c!-- Example starting values --\u003e\n        \u003clabel for\u003d\"reverse-e\"\u003eInput e\u0027:\u003c/label\u003e\n        \u003cinput type\u003d\"number\" id\u003d\"reverse-e\" value\u003d\"7\"\u003e\n        \u003clabel for\u003d\"reverse-d\"\u003eInput d\u0027:\u003c/label\u003e\n        \u003cinput type\u003d\"number\" id\u003d\"reverse-d\" value\u003d\"3\"\u003e \u003c!-- Example d\u0027 \u003d round(sqrt(sqrt(65))) \u003d round(sqrt(8.06)) \u003d 3 --\u003e\n\n        \u003cbutton id\u003d\"reverse-button\"\u003eFind Previous State(s)\u003c/button\u003e\n\n        \u003clabel style\u003d\"margin-top:15px;\"\u003ePossible Previous State(s):\u003c/label\u003e\n        \u003cdiv id\u003d\"reverse-output\"\u003eEnter values and click \"Find\".\u003c/div\u003e\n    \u003c/div\u003e\n\n\n    \u003cdiv id\u003d\"visualization\" class\u003d\"panel\"\u003e\n        \u003ch3\u003eVisualization (Mod-24 Wheel with Harmonic Links)\u003c/h3\u003e\n        \u003ccanvas id\u003d\"qaCanvas\" width\u003d\"400\" height\u003d\"400\"\u003e\u003c/canvas\u003e\n        \u003cdiv id\u003d\"viz-info\" style\u003d\"margin-top: 10px; font-style: italic;\"\u003eMod-24 Wheel\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv id\u003d\"output\" class\u003d\"panel\"\u003e\n        \u003ch3 id\u003d\"output-title\"\u003eCurrent State Output (Step 0)\u003c/h3\u003e\n        \u003cdiv\u003eState at Step \u003cspan id\u003d\"current-step-display\"\u003e0\u003c/span\u003e:\u003c/div\u003e\n        \u003cdiv\u003eQuNit:\u003cbr\u003e b\u003d\u003cspan id\u003d\"output-b\"\u003e?\u003c/span\u003e, e\u003d\u003cspan id\u003d\"output-e\"\u003e?\u003c/span\u003e, d\u003d\u003cspan id\u003d\"output-d\"\u003e?\u003c/span\u003e, a\u003d\u003cspan id\u003d\"output-a\"\u003e?\u003c/span\u003e\u003c/div\u003e\n        \u003cdiv\u003eMeasurement:\u003cbr\u003e Rounded a: \u003cspan id\u003d\"measure-a\"\u003e?\u003c/span\u003e\u003cbr\u003e b/e Ratio: \u003cspan id\u003d\"measure-ratio\"\u003e?\u003c/span\u003e\u003cbr\u003e Is (b+e) Prime?: \u003cspan id\u003d\"measure-prime\"\u003e?\u003c/span\u003e\u003cbr\u003e Probabilistic Collapse: \u003cspan id\u003d\"measure-collapse\"\u003e?\u003c/span\u003e\u003c/div\u003e\n        \u003cdiv\u003eHarmonics (Aliquot Parts of \u0027a\u0027):\u003cbr\u003e \u003cul id\u003d\"harmonics-list\"\u003e\u003c/ul\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv id\u003d\"sequence-output\" class\u003d\"panel\"\u003e\n        \u003ch3\u003eOperation Sequence (\u003cspan id\u003d\"total-steps-display\"\u003e0\u003c/span\u003e steps)\u003c/h3\u003e\n        \u003cdiv id\u003d\"sequence-list\"\u003eGenerate sequence to view steps...\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cscript\u003e\n        // --- DOM References --- (Added reverse controls/output)\n        const inputB \u003d document.getElementById(\u0027input-b\u0027); /* ... other forward sim controls ... */\n        const inputE \u003d document.getElementById(\u0027input-e\u0027);\n        const inputD \u003d document.getElementById(\u0027input-d\u0027);\n        const inputCycles \u003d document.getElementById(\u0027input-cycles\u0027);\n        const generateButton \u003d document.getElementById(\u0027generate-button\u0027);\n        const shareButton \u003d document.getElementById(\u0027share-button\u0027);\n        const playButton \u003d document.getElementById(\u0027play-button\u0027);\n        const pauseButton \u003d document.getElementById(\u0027pause-button\u0027);\n        const resetButton \u003d document.getElementById(\u0027reset-button\u0027);\n        const speedSlider \u003d document.getElementById(\u0027speed-slider\u0027);\n        const speedValueSpan \u003d document.getElementById(\u0027speed-value\u0027);\n        const canvas \u003d document.getElementById(\u0027qaCanvas\u0027);\n        const ctx \u003d canvas.getContext(\u00272d\u0027);\n        const vizInfo \u003d document.getElementById(\u0027viz-info\u0027);\n        const equationViewer \u003d document.getElementById(\u0027equation-viewer\u0027);\n        const outputTitle \u003d document.getElementById(\u0027output-title\u0027);\n        const currentStepDisp \u003d document.getElementById(\u0027current-step-display\u0027);\n        const outputB \u003d document.getElementById(\u0027output-b\u0027); /* ... other output fields ... */\n        const outputE \u003d document.getElementById(\u0027output-e\u0027);\n        const outputD \u003d document.getElementById(\u0027output-d\u0027);\n        const outputA \u003d document.getElementById(\u0027output-a\u0027);\n        const measureA \u003d document.getElementById(\u0027measure-a\u0027);\n        const measureRatio \u003d document.getElementById(\u0027measure-ratio\u0027);\n        const measurePrime \u003d document.getElementById(\u0027measure-prime\u0027);\n        const measureCollapse \u003d document.getElementById(\u0027measure-collapse\u0027);\n        const harmonicsList \u003d document.getElementById(\u0027harmonics-list\u0027);\n        const totalStepsDisp \u003d document.getElementById(\u0027total-steps-display\u0027);\n        const sequenceListDiv \u003d document.getElementById(\u0027sequence-list\u0027);\n\n        const reverseBInput \u003d document.getElementById(\u0027reverse-b\u0027);\n        const reverseEInput \u003d document.getElementById(\u0027reverse-e\u0027);\n        const reverseDInput \u003d document.getElementById(\u0027reverse-d\u0027);\n        const reverseButton \u003d document.getElementById(\u0027reverse-button\u0027);\n        const reverseOutputDiv \u003d document.getElementById(\u0027reverse-output\u0027);\n\n\n        // --- State Variables --- (Unchanged)\n        let fullSequence \u003d []; let currentStep \u003d 0; let isPlaying \u003d false;\n        let animationIntervalId \u003d null; let animationSpeedMs \u003d 500;\n\n        // --- QA Simulation Functions --- (Unchanged)\n        function calculateA(b, e, d) { if (isNaN(b) || isNaN(e) || isNaN(d)) return NaN; const i \u003d b*b + 2*d*e + e*e; return (i \u003e\u003d 0) ? Math.sqrt(i) : NaN; }\n        function qaTransform(q) { const a_p \u003d calculateA(q.b, q.e, q.d); if (isNaN(a_p)) return { b: NaN, e: NaN, d: NaN, a: NaN }; const b_o \u003d q.b + 1; const e_o \u003d q.e + q.b; const d_o \u003d (a_p \u003e\u003d 0) ? Math.round(Math.sqrt(a_p)) : 0; const a_o \u003d calculateA(b_o, e_o, d_o); return { b: b_o, e: e_o, d: d_o, a: a_o }; }\n        function collapseToMeasurement(a) { if (isNaN(a)) return NaN; const f \u003d Math.floor(a); const c \u003d Math.ceil(a); if (f \u003d\u003d\u003d c) return f; const p \u003d c - a; return Math.random() \u003c p ? f : c; }\n        function measure(q) { if (isNaN(q.a) || isNaN(q.b) || isNaN(q.e)) { return { rounded_a: \u0027N/A\u0027, ratio: \u0027N/A\u0027, primeRootCheck: \u0027N/A\u0027, collapsed_a: \u0027N/A\u0027 }; } const r \u003d (q.e !\u003d\u003d 0) ? (q.b / q.e).toFixed(3) : \u0027Div/0\u0027; const bpe \u003d q.b + q.e; return { rounded_a: Math.round(q.a), ratio: r, primeRootCheck: !isNaN(bpe) ? isPrime(Math.round(bpe)) : false, collapsed_a: collapseToMeasurement(q.a) }; }\n        function getAliquotParts(n) { if (isNaN(n) || n \u003c\u003d 0) return []; let num \u003d Math.round(n); let p \u003d []; for (let i \u003d 1; i \u003c\u003d num / 2; i++) { if (num % i \u003d\u003d\u003d 0) { p.push(i); } } return p; }\n        function isPrime(num) { if (isNaN(num)) return false; num \u003d Math.floor(Math.abs(num)); if (num \u003c\u003d 1) return false; if (num \u003c\u003d 3) return true; if (num % 2 \u003d\u003d\u003d 0 || num % 3 \u003d\u003d\u003d 0) return false; for (let i \u003d 5; i * i \u003c\u003d num; i \u003d i + 6) { if (num % i \u003d\u003d\u003d 0 || num % (i + 2) \u003d\u003d\u003d 0) return false; } return true; }\n        function drawModWheel(modulus \u003d 24, highlightValue \u003d null, harmonics \u003d []) { /* ... (Unchanged) ... */ const r \u003d Math.min(canvas.width, canvas.height)/2*0.8; const c \u003d {x: canvas.width/2, y: canvas.height/2}; const pr \u003d Math.min(15, Math.max(5, r/modulus*1.5)); ctx.clearRect(0,0,canvas.width,canvas.height); ctx.beginPath(); ctx.arc(c.x,c.y,r,0,2*Math.PI); ctx.strokeStyle\u003d\"#aaa\"; ctx.lineWidth\u003d1; ctx.stroke(); let hi\u003d-1; if(highlightValue!\u003d\u003dnull\u0026\u0026!isNaN(highlightValue)){hi\u003dMath.round(highlightValue)%modulus; if(hi\u003c0)hi+\u003dmodulus;} const pos\u003d{}; for(let i\u003d0;i\u003cmodulus;i++){let a\u003d(2*Math.PI*i/modulus)-(Math.PI/2); let x\u003dc.x+r*Math.cos(a); let y\u003dc.y+r*Math.sin(a); pos[i]\u003d{x,y}; ctx.beginPath(); ctx.arc(x,y,pr,0,2*Math.PI); if(i\u003d\u003d\u003dhi){ctx.fillStyle\u003d\"orange\";ctx.fill();ctx.strokeStyle\u003d\"black\";ctx.lineWidth\u003d2;}else{ctx.fillStyle\u003di%2\u003d\u003d\u003d0?\"lightblue\":\"lightgreen\";ctx.fill();ctx.strokeStyle\u003d\"#555\";ctx.lineWidth\u003d1;} ctx.stroke(); ctx.fillStyle\u003d\"black\"; ctx.font\u003d`${Math.max(9, Math.min(12, pr))}px sans-serif`; ctx.textAlign\u003d\"center\"; ctx.textBaseline\u003d\"middle\"; ctx.fillText(i,x,y);} if(harmonics\u0026\u0026harmonics.length\u003e\u003d2){const hIdx\u003dharmonics.map(h\u003d\u003eh%modulus).filter((v,i,s)\u003d\u003es.indexOf(v)\u003d\u003d\u003di).sort((a,b)\u003d\u003ea-b); if(hIdx.length\u003e\u003d2){ctx.beginPath();ctx.strokeStyle\u003d\"rgba(255,0,0,0.6)\";ctx.lineWidth\u003d2; const fi\u003dhIdx[0]; if(pos[fi]){ctx.moveTo(pos[fi].x,pos[fi].y); for(let i\u003d1;i\u003chIdx.length;i++){const ci\u003dhIdx[i]; if(pos[ci]){ctx.lineTo(pos[ci].x,pos[ci].y);}} ctx.lineTo(pos[fi].x,pos[fi].y);} ctx.stroke();}} const stepInfo \u003d (typeof currentStep !\u003d\u003d \u0027undefined\u0027 \u0026\u0026 currentStep \u003e\u003d 0) ? `step ${currentStep}` : \u0027current\u0027; if(hi!\u003d\u003d-1){vizInfo.textContent\u003d`Highlighting ${stepInfo} ~a mod ${modulus}\u003d${Math.round(highlightValue)} mod ${modulus}\u003d${hi}. Links show aliquot parts.`;}else if(highlightValue\u003d\u003d\u003dnull){vizInfo.textContent\u003d`Mod-${modulus} Wheel`;}else{vizInfo.textContent\u003d`Mod-${modulus} Wheel (Invalid \u0027a\u0027 for ${stepInfo})`;} }\n\n\n        // --- NEW: Reverse QA Transform Function ---\n        function findPreviousState(b_next, e_next, d_next) {\n            if (isNaN(b_next) || isNaN(e_next) || isNaN(d_next)) {\n                return { possibleStates: [], message: \"Invalid input values for b\u0027, e\u0027, or d\u0027.\" };\n            }\n\n            const b_prev \u003d b_next - 1;\n            const e_prev \u003d e_next - (b_next - 1); // derived from e_next \u003d e_prev + b_prev\n\n            const possible_d_prev \u003d [];\n            let message \u003d \"\";\n\n            // Handle the edge case where e_prev is 0\n            if (e_prev \u003d\u003d\u003d 0) {\n                const a_prev_expected \u003d Math.abs(b_prev); // a_prev \u003d sqrt(b_prev^2) \u003d |b_prev|\n                 const d_check \u003d Math.round(Math.sqrt(a_prev_expected));\n                 if (d_check \u003d\u003d\u003d d_next) {\n                     message \u003d `Calculated b\u003d${b_prev}, e\u003d0. In this case, \u0027d\u0027 is unconstrained by d\u0027\u003d${d_next}. Any previous \u0027d\u0027 is possible if d\u0027\u003d${d_check}.`;\n                     // We can\u0027t determine d_prev, so return an empty list but provide the message.\n                 } else {\n                      message \u003d `Calculated b\u003d${b_prev}, e\u003d0. Expected d\u0027\u003d${d_check} based on b, but received d\u0027\u003d${d_next}. No consistent previous state found.`;\n                 }\n                 return { possibleStates: [], message: message };\n            }\n\n\n            // Calculate bounds for the search based on the inequality derived from d_next \u003d round(sqrt(a_prev))\n            // (d_next - 0.5)^2 \u003c\u003d a_prev \u003c (d_next + 0.5)^2\n            // (d_next - 0.5)^2 \u003c\u003d b_prev^2 + 2*d_prev*e_prev + e_prev^2 \u003c (d_next + 0.5)^2\n\n            const K \u003d b_prev * b_prev + e_prev * e_prev;\n            const lower_a_sq \u003d Math.max(0, (d_next - 0.5) * (d_next - 0.5)); // Ensure \u003e\u003d 0\n            const upper_a_sq \u003d (d_next + 0.5) * (d_next + 0.5);\n\n            // Target range for 2 * d_prev * e_prev\n            const lower_2de \u003d lower_a_sq - K;\n            const upper_2de \u003d upper_a_sq - K;\n\n            let d_min, d_max;\n\n            // Calculate search range for d_prev, handling positive/negative e_prev\n            if (e_prev \u003e 0) {\n                d_min \u003d lower_2de / (2 * e_prev);\n                d_max \u003d upper_2de / (2 * e_prev);\n            } else { // e_prev \u003c 0\n                d_min \u003d upper_2de / (2 * e_prev); // Division by negative flips inequality\n                d_max \u003d lower_2de / (2 * e_prev);\n            }\n\n            // Determine integer search bounds\n            const search_start \u003d Math.ceil(d_min);\n            // The upper bound is exclusive, so floor(d_max - epsilon) or just floor if d_max itself is not the boundary\n             const search_end \u003d Math.floor(d_max - 1e-9); // Subtract small epsilon for strict inequality \u003c\n\n\n             // Limit search range to something reasonable to prevent performance issues if bounds are huge\n            const MAX_SEARCH_RANGE \u003d 2000; // Check +/- 1000 around search_start\n            const final_search_start \u003d Math.max(search_start - MAX_SEARCH_RANGE / 2, -MAX_SEARCH_RANGE); // Add some reasonable negative limit\n            const final_search_end \u003d Math.min(search_end, search_start + MAX_SEARCH_RANGE / 2, MAX_SEARCH_RANGE); // Add reasonable positive limit\n\n\n            // Iterate through the calculated integer range for d_prev\n            for (let d_guess \u003d final_search_start; d_guess \u003c\u003d final_search_end; d_guess++) {\n                 // Verify this d_guess actually falls within the computed bounds if range was clamped\n                 if (d_guess \u003c search_start || d_guess \u003e search_end) continue;\n\n                const a_check \u003d calculateA(b_prev, e_prev, d_guess);\n                if (!isNaN(a_check) \u0026\u0026 a_check \u003e\u003d 0) {\n                    const d_recalc \u003d Math.round(Math.sqrt(a_check));\n                    if (d_recalc \u003d\u003d\u003d d_next) {\n                        possible_d_prev.push(d_guess);\n                    }\n                }\n            }\n\n\n            // Format results\n            const possibleStates \u003d possible_d_prev.map(d_p \u003d\u003e ({ b: b_prev, e: e_prev, d: d_p }));\n\n            if (possibleStates.length \u003d\u003d\u003d 0) {\n                message \u003d `No consistent previous \u0027d\u0027 found for b\u003d${b_prev}, e\u003d${e_prev} within the search range [${final_search_start}, ${final_search_end}]. (Theoretical bounds: [${d_min.toFixed(2)}, ${d_max.toFixed(2)}))`;\n            } else if (possibleStates.length \u003d\u003d\u003d 1) {\n                message \u003d \"Unique previous state found.\";\n            } else {\n                message \u003d `Ambiguity found: ${possibleStates.length} possible previous \u0027d\u0027 values yield the same d\u0027\u003d${d_next}.`;\n            }\n\n            return { possibleStates, message };\n        }\n\n\n        // --- Update Display Functions --- (Mostly unchanged, added reverse output update)\n        function updateStaticDisplays(initialState) { updateEquationViewer(initialState.b, initialState.e, initialState.d); displaySequenceList(fullSequence); }\n        function updateDynamicDisplays(stepIndex) { /* ... (Unchanged) ... */ if (stepIndex \u003c 0 || stepIndex \u003e\u003d fullSequence.length) { console.error(\"Invalid step index:\", stepIndex); pauseAnimation(); return; } const state \u003d fullSequence[stepIndex]; const measurement \u003d measure(state); const harmonics \u003d getAliquotParts(state.a); outputTitle.textContent \u003d `Current State Output (Step ${stepIndex})`; currentStepDisp.textContent \u003d stepIndex; outputB.textContent \u003d isNaN(state.b)?\u0027Err\u0027:state.b; outputE.textContent \u003d isNaN(state.e)?\u0027Err\u0027:state.e; outputD.textContent \u003d isNaN(state.d)?\u0027Err\u0027:state.d; outputA.textContent \u003d isNaN(state.a)?\u0027Err\u0027:state.a.toFixed(3); measureA.textContent \u003d measurement.rounded_a; measureRatio.textContent \u003d measurement.ratio; measurePrime.textContent \u003d measurement.primeRootCheck ? \u0027Yes\u0027 : \u0027No\u0027; measureCollapse.textContent \u003d measurement.collapsed_a; harmonicsList.innerHTML \u003d \u0027\u0027; if (harmonics.length \u003e 0) { harmonics.forEach(part \u003d\u003e { const li \u003d document.createElement(\u0027li\u0027); li.textContent \u003d part; harmonicsList.appendChild(li); }); } else { harmonicsList.innerHTML \u003d isNaN(state.a) ? \u0027\u003cli\u003eError\u003c/li\u003e\u0027 : \u0027\u003cli\u003eNone\u003c/li\u003e\u0027; } drawModWheel(24, state.a, harmonics); highlightSequenceStep(stepIndex); }\n        function displaySequenceList(sequence) { sequenceListDiv.innerHTML \u003d \u0027\u0027; totalStepsDisp.textContent \u003d sequence.length -1; if (!sequence || sequence.length \u003d\u003d\u003d 0) { sequenceListDiv.textContent \u003d \u0027No sequence data.\u0027; return; } sequence.forEach((state, index) \u003d\u003e { const itemDiv \u003d document.createElement(\u0027div\u0027); itemDiv.classList.add(\u0027sequence-item\u0027); itemDiv.id \u003d `step-${index}`; itemDiv.innerHTML \u003d `\u003cstrong\u003eStep ${index}:\u003c/strong\u003e b\u003d${isNaN(state.b)?\u0027Err\u0027:state.b}, e\u003d${isNaN(state.e)?\u0027Err\u0027:state.e}, d\u003d${isNaN(state.d)?\u0027Err\u0027:state.d}, a\u003d${isNaN(state.a)?\u0027Err\u0027:state.a.toFixed(3)}`; itemDiv.addEventListener(\u0027click\u0027, () \u003d\u003e { pauseAnimation(); currentStep \u003d index; updateDynamicDisplays(currentStep); updateAnimationButtons(); }); sequenceListDiv.appendChild(itemDiv); }); }\n        function highlightSequenceStep(stepIndex) { const activeItems \u003d sequenceListDiv.querySelectorAll(\u0027.sequence-item.active\u0027); activeItems.forEach(item \u003d\u003e item.classList.remove(\u0027active\u0027)); const currentItem \u003d document.getElementById(`step-${stepIndex}`); if (currentItem) { currentItem.classList.add(\u0027active\u0027); currentItem.scrollIntoView({ behavior: \u0027smooth\u0027, block: \u0027nearest\u0027 }); } }\n        function updateEquationViewer(b, e, d) { if (isNaN(b) || isNaN(e) || isNaN(d)) { equationViewer.textContent \u003d \"a \u003d √[ b² + 2de + e² ] - Invalid inputs\"; return; } const bStr\u003db.toString(); const eStr\u003de.toString(); const dStr\u003dd.toString(); const aValue\u003dcalculateA(b,e,d); const aStr \u003d isNaN(aValue)?\u0027Error\u0027:aValue.toFixed(4); equationViewer.innerHTML \u003d `Initial State Formula:\u003cbr\u003e a \u003d \u0026radic;[ b² + 2de + e² ]\u003cbr\u003e a \u003d \u0026radic;[ (${bStr})² + 2×(${dStr})×(${eStr}) + (${eStr})² ] ≈ ${aStr}`; }\n        function updateAnimationButtons() { const hasSequence \u003d fullSequence.length \u003e 1; playButton.disabled \u003d !hasSequence || isPlaying || currentStep \u003e\u003d fullSequence.length - 1; pauseButton.disabled \u003d !hasSequence || !isPlaying; resetButton.disabled \u003d !hasSequence || currentStep \u003d\u003d\u003d 0; }\n        function updateReverseOutput(result) {\n             reverseOutputDiv.innerHTML \u003d \u0027\u0027; // Clear previous results\n             if (result.message) {\n                  const msgP \u003d document.createElement(\u0027p\u0027);\n                  msgP.textContent \u003d `Status: ${result.message}`;\n                  reverseOutputDiv.appendChild(msgP);\n             }\n             if (result.possibleStates \u0026\u0026 result.possibleStates.length \u003e 0) {\n                  const list \u003d document.createElement(\u0027ul\u0027);\n                  result.possibleStates.forEach(state \u003d\u003e {\n                       const item \u003d document.createElement(\u0027li\u0027);\n                       item.innerHTML \u003d `b\u003d\u003cspan\u003e${state.b}\u003c/span\u003e, e\u003d\u003cspan\u003e${state.e}\u003c/span\u003e, d\u003d\u003cspan\u003e${state.d}\u003c/span\u003e`;\n                       list.appendChild(item);\n                  });\n                  reverseOutputDiv.appendChild(list);\n             } else if (!result.message) { // Should not happen if message logic is correct, but fallback\n                  reverseOutputDiv.textContent \u003d \"No results returned.\";\n             }\n        }\n\n        // --- Animation Control Functions --- (Unchanged)\n        function playAnimation() { if (isPlaying || currentStep \u003e\u003d fullSequence.length - 1) return; isPlaying \u003d true; if (animationIntervalId) clearInterval(animationIntervalId); animationIntervalId \u003d setInterval(() \u003d\u003e { currentStep++; if (currentStep \u003c fullSequence.length) { updateDynamicDisplays(currentStep); updateAnimationButtons(); } else { pauseAnimation(); currentStep \u003d fullSequence.length - 1; updateAnimationButtons(); } }, animationSpeedMs); updateAnimationButtons(); }\n        function pauseAnimation() { if (!isPlaying) return; isPlaying \u003d false; if (animationIntervalId) { clearInterval(animationIntervalId); animationIntervalId \u003d null; } updateAnimationButtons(); }\n        function resetSimulation() { pauseAnimation(); currentStep \u003d 0; if (fullSequence.length \u003e 0) { updateDynamicDisplays(currentStep); } else { /* handle empty sequence */ } updateAnimationButtons(); }\n\n        // --- Event Listeners --- (Added reverse button listener)\n        generateButton.addEventListener(\u0027click\u0027, () \u003d\u003e { pauseAnimation(); const bVal\u003dparseInt(inputB.value, 10); const eVal\u003dparseInt(inputE.value, 10); const dVal\u003dparseInt(inputD.value, 10); const maxCycles\u003dparseInt(inputCycles.value, 10); if(isNaN(bVal) || isNaN(eVal) || isNaN(dVal) || isNaN(maxCycles) || maxCycles \u003c 1) { alert(\"Invalid inputs.\"); return; } const initialState \u003d { b: bVal, e: eVal, d: dVal, a: calculateA(bVal, eVal, dVal) }; fullSequence \u003d [initialState]; let currentState \u003d initialState; for (let i \u003d 0; i \u003c maxCycles; i++) { currentState \u003d qaTransform(currentState); fullSequence.push(currentState); if (isNaN(currentState.a)) { console.error(`Error at cycle ${i + 1}.`); break; } } currentStep \u003d 0; isPlaying \u003d false; updateStaticDisplays(initialState); updateDynamicDisplays(currentStep); updateAnimationButtons(); });\n        playButton.addEventListener(\u0027click\u0027, playAnimation);\n        pauseButton.addEventListener(\u0027click\u0027, pauseAnimation);\n        resetButton.addEventListener(\u0027click\u0027, res