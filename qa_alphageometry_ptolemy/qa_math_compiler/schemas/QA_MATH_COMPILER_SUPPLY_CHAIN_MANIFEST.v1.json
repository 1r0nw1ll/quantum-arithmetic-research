{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "QA_MATH_COMPILER_SUPPLY_CHAIN_MANIFEST.v1",
  "title": "QA Math Compiler Supply Chain Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "manifest_id",
    "created_utc",
    "hash_algorithm",
    "portable_artifacts",
    "portable_root_sha256",
    "platform_receipts",
    "invariant_diff",
    "manifest_sha256"
  ],
  "properties": {
    "schema_id": {"const": "QA_MATH_COMPILER_SUPPLY_CHAIN_MANIFEST.v1"},
    "manifest_id": {"type": "string", "minLength": 1},
    "created_utc": {"type": "string"},
    "hash_algorithm": {"const": "sha256"},
    "portable_artifacts": {
      "type": "object",
      "required": ["file_count", "total_size_bytes", "files"],
      "properties": {
        "file_count": {"type": "integer", "minimum": 1},
        "total_size_bytes": {"type": "integer", "minimum": 1},
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/fileRecord"}
        }
      }
    },
    "portable_root_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "platform_receipts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "platform",
          "machine",
          "lean_version",
          "lean_git_commit",
          "toolchain_prefix_name",
          "binaries",
          "libraries",
          "platform_root_sha256"
        ],
        "properties": {
          "platform": {"type": "string", "minLength": 1},
          "machine": {"type": "string", "minLength": 1},
          "lean_version": {"type": "string", "minLength": 1},
          "lean_git_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
          "toolchain_prefix_name": {"type": "string", "minLength": 1},
          "binaries": {
            "type": "array",
            "minItems": 3,
            "items": {
              "allOf": [
                {"$ref": "#/$defs/fileRecord"},
                {
                  "type": "object",
                  "required": ["name"],
                  "properties": {"name": {"type": "string", "minLength": 1}}
                }
              ]
            }
          },
          "libraries": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/fileRecord"}
          },
          "platform_root_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "invariant_diff": {"type": "object"},
    "manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "$defs": {
    "fileRecord": {
      "type": "object",
      "required": ["path", "size_bytes", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "size_bytes": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  }
}
