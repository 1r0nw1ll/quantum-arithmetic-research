nimport tensorflow as tf\nfrom tensorflow.keras import layers, models, callbacks\nfrom tqdm.notebook import tqdm\nimport tensorflow_addons as tfa # For Cutout augmentation\n\n# Confirm GPU is active and get core count\ntry:\n    tpu \u003d tf.distribute.cluster_resolver.TPUClusterResolver()\n    tf.config.experimental_connect_to_cluster(tpu)\n    tf.tpu.experimental.initialize_tpu_system(tpu)\n    strategy \u003d tf.distribute.TPUStrategy(tpu)\n    print(\u0027Running on TPU\u0027)\nexcept ValueError:\n    strategy \u003d tf.distribute.get_strategy()\n    print(\u0027Running on GPU\u0027 if len(tf.config.list_physical_devices(\u0027GPU\u0027)) \u003e 0 else \u0027Running on CPU\u0027)\nCPU_WORKERS \u003d os.cpu_count()\nprint(f\"TensorFlow Version: {tf.__version__}\")\nprint(f\"Available CPU cores: {CPU_WORKERS}\")\n\n\n# --- [QA HARMONIC \u0026 GEOMETRIC UTILITIES - TENSORFLOW NATIVE] ---\nprint(\"\\n--- Defining the TensorFlow-Native Quantum Arithmetic Engine ---\")\nSTENCILS_24 \u003d None\ndef get_stencils():\n    global STENCILS_24\n    if STENCILS_24 is not None: return STENCILS_24\n    def _rot90(K, k): return np.rot90(K, k)\n    B0\u003dnp.array([[1,0,-1],[2,0,-2],[1,0,-1]],dtype\u003dnp.float32); B1\u003dnp.array([[1,2,1],[0,0,0],[-1,-2,-1]],dtype\u003dnp.float32); B2\u003dnp.array([[2,1,0],[1,0,-1],[0,-1,-2]],dtype\u003dnp.float32); B3\u003dnp.array([[0,1,2],[-1,0,1],[-2,-1,0]],dtype\u003dnp.float32)\n    seeds\u003d[B0,B1,B2,B3]; mixes\u003d[(1,0),(2,1),(1,1),(1,2),(1,-1),(2,-1)]; stencils\u003d[]\n    for s_idx,K in enumerate(seeds):\n        for r in range(4):\n            Kr\u003d_rot90(K,r); Kn_base\u003dseeds[(s_idx+1)%4]; Kn\u003d_rot90(Kn_base,r)\n            for(a,b)in mixes:\n                M\u003da*Kr+b*Kn; flat\u003dM.ravel(); g\u003dnp.gcd.reduce(flat.astype(np.int32)) if np.any(flat) else 1; M\u003d(M//g) if g else M; stencils.append(M.astype(np.float32))\n                if len(stencils)\u003d\u003d24: STENCILS_24 \u003d stencils; return STENCILS_24\n    STENCILS_24 \u003d stencils; return STENCILS_24\n\nclass QAFeatureLayer(layers.Layer):\n    def __init__(self, **kwargs):\n        super().__init__(name\u003d\"qa_feature_layer\", **kwargs)\n        stencils \u003d get_stencils()\n        self.kernels \u003d tf.constant(np.transpose(np.stack(stencils), (1, 2, 0))[:, :, np.newaxis, :], dtype\u003dtf.float32)\n        mask \u003d np.ones((28,28), dtype\u003dnp.float32); mask[5:23, 5:23] \u003d 0\n        self.perimeter_mask \u003d tf.constant(mask[np.newaxis, :, :, np.newaxis])\n\n    @tf.function\n    def call(self, images):\n        paddings \u003d tf.constant([[0, 0], [1, 1], [1, 1], [0, 0]])\n        padded_images \u003d tf.pad(images, paddings, \"SYMMETRIC\")\n        responses_map \u003d tf.nn.conv2d(padded_images, self.kernels, strides\u003d[1, 1, 1, 1], padding\u003d\"VALID\")\n        responses_std \u003d tf.math.reduce_std(responses_map, axis\u003d[1, 2])\n        qa_full \u003d responses_std / (tf.norm(responses_std, axis\u003d-1, keepdims\u003dTrue) + 1e-6)\n        center_images \u003d images[:, 7:21, 7:21, :]\n        padded_center \u003d tf.pad(center_images, paddings, \"SYMMETRIC\")\n        center_responses_map \u003d tf.nn.conv2d(padded_center, self.kernels, strides\u003d[1, 1, 1, 1], padding\u003d\"VALID\")\n        center_responses_std \u003d tf.math.reduce_std(center_responses_map, axis\u003d[1, 2])\n        qa_center \u003d center_responses_std / (tf.norm(center_responses_std, axis\u003d-1, keepdims\u003dTrue) + 1e-6)\n        perimeter_images \u003d images * self.perimeter_mask\n        padded_perimeter \u003d tf.pad(perimeter_images, paddings, \"SYMMETRIC\")\n        perimeter_responses_map \u003d tf.nn.conv2d(padded_perimeter, self.kernels, strides\u003d[1, 1, 1, 1], padding\u003d\"VALID\")\n        perimeter_responses_std \u003d tf.math.reduce_std(perimeter_responses_map, axis\u003d[1, 2])\n        qa_perimeter \u003d perimeter_responses_std / (tf.norm(perimeter_responses_std, axis\u003d-1, keepdims\u003dTrue) + 1e-6)\n        multi_scale_vector \u003d tf.concat([qa_full, qa_center, qa_perimeter], axis\u003d-1)\n        b \u003d responses_std[:, 0]; e \u003d responses_std[:, 6]\n        d \u003d b + e; a \u003d b + 2 * e\n        qa_tuple \u003d tf.stack([b, e, d, a], axis\u003d-1)\n        qa_tuple_norm \u003d qa_tuple / (tf.norm(qa_tuple, axis\u003d-1, keepdims\u003dTrue) + 1e-6)\n        return multi_scale_vector, qa_tuple_norm\n\n# --- [CUSTOM KERAS COMPONENTS \u0026 MODEL ARCHITECTURE] ---\nclass QAConv24(layers.Layer):\n    def __init__(self, out_ch\u003d32, use_bias\u003dFalse, name\u003d\"QAConv24\", **kwargs):\n        super().__init__(name\u003dname, **kwargs); self.out_ch\u003dout_ch; self.use_bias\u003duse_bias\n        stencils \u003d get_stencils(); K\u003dnp.stack(stencils,axis\u003d0)[:,:,:,np.newaxis]; K\u003dnp.transpose(K,(1,2,3,0))\n        self.K_fixed\u003dtf.constant(K,dtype\u003dtf.float32)\n        self.mixer\u003dself.add_weight(name\u003d\"mixer_w\",shape\u003d(1,1,24,self.out_ch),initializer\u003d\"glorot_uniform\",trainable\u003dTrue)\n        self.bias\u003dself.add_weight(name\u003d\"mixer_b\",shape\u003d(self.out_ch,),initializer\u003d\"zeros\",trainable\u003dTrue) if use_bias else None\n    def call(self,x):\n        x24\u003dtf.nn.conv2d(x,self.K_fixed,strides\u003d1,padding\u003d\"SAME\"); y\u003dtf.nn.conv2d(x24,self.mixer,strides\u003d1,padding\u003d\"SAME\")\n        return tf.nn.bias_add(y,self.bias) if self.bias is not None else y\n\ndef resnet_block(x, filters, kernel_size\u003d3, stride\u003d1):\n    shortcut \u003d x\n    y \u003d layers.Conv2D(filters, kernel_size, strides\u003dstride, padding\u003d\"same\")(x)\n    y \u003d layers.BatchNormalization()(y); y \u003d layers.Activation(\"relu\")(y)\n    y \u003d layers.Conv2D(filters, kernel_size, strides\u003d1, padding\u003d\"same\")(y)\n    y \u003d layers.BatchNormalization()(y)\n    if stride !\u003d 1 or x.shape[-1] !\u003d filters:\n        shortcut \u003d layers.Conv2D(filters, 1, strides\u003dstride, padding\u003d\"same\")(x)\n        shortcut \u003d layers.BatchNormalization()(shortcut)\n    y \u003d layers.add([y, shortcut]); y \u003d layers.Activation(\"relu\")(y)\n    return y\n\ndef build_qa_resnet(num_classes\u003d10):\n    img_inp \u003d layers.Input(shape\u003d(28, 28, 1), name\u003d\"image_input\")\n    qa_multi_scale_inp \u003d layers.Input(shape\u003d(72,), name\u003d\"qa_multi_scale_input\")\n    qa_tuple_inp \u003d layers.Input(shape\u003d(4,), name\u003d\"qa_tuple_input\")\n    x \u003d QAConv24(out_ch\u003d64)(img_inp); x \u003d layers.BatchNormalization()(x); x \u003d layers.Activation(\"relu\")(x)\n    x \u003d resnet_block(x, 64); x \u003d resnet_block(x, 64)\n    x \u003d resnet_block(x, 128, stride\u003d2); x \u003d resnet_block(x, 128)\n    x \u003d resnet_block(x, 256, stride\u003d2); x \u003d resnet_block(x, 256)\n    core_features \u003d layers.GlobalAveragePooling2D(name\u003d\"core_features\")(x)\n    final_concat \u003d layers.concatenate([core_features, qa_multi_scale_inp, qa_tuple_inp])\n    h_class \u003d layers.Dense(512, activation\u003d\"relu\")(final_concat)\n    h_class \u003d layers.BatchNormalization()(h_class); h_class \u003d layers.Dropout(0.6)(h_class) # Increased Dropout\n    class_output \u003d layers.Dense(num_classes, activation\u003d\"softmax\", name\u003d\"class_output\")(h_class)\n    h_qa \u003d layers.Dense(128, activation\u003d\"relu\")(core_features)\n    qa_output \u003d layers.Dense(72, name\u003d\"qa_output\")(h_qa)\n    model \u003d models.Model(inputs\u003d[img_inp, qa_multi_scale_inp, qa_tuple_inp], outputs\u003d[class_output, qa_output])\n    return model\n\n# --- [PHASE 1: HIGH-PERFORMANCE TF.DATA PIPELINE] ---\nprint(\"\\n--- [PHASE 1] Building Optimized tf.data Pipeline ---\")\nQA_FEATURE_LAYER \u003d QAFeatureLayer()\ndef process_batch(x, y):\n    qa_multi, qa_tuple \u003d QA_FEATURE_LAYER(x)\n    inputs \u003d {\u0027image_input\u0027: x, \u0027qa_multi_scale_input\u0027: qa_multi, \u0027qa_tuple_input\u0027: qa_tuple}\n    outputs \u003d {\u0027class_output\u0027: y, \u0027qa_output\u0027: qa_multi}\n    return inputs, outputs\n\n(x_train, y_train), (x_test, y_test) \u003d tf.keras.datasets.fashion_mnist.load_data()\nx_train \u003d x_train.astype(\u0027float32\u0027) / 255.0; x_test \u003d x_test.astype(\u0027float32\u0027) / 255.0\nx_train \u003d x_train[..., np.newaxis]; x_test \u003d x_test[..., np.newaxis]\n\n# --- [NEW] Aggressive Augmentation Pipeline ---\nclass Cutout(layers.Layer):\n    def __init__(self, mask_size, **kwargs):\n        super(Cutout, self).__init__(**kwargs)\n        self.mask_size \u003d mask_size\n    def call(self, images, training\u003dFalse):\n        if not training: return images\n        return tfa.image.random_cutout(images, mask_size\u003d(self.mask_size, self.mask_size))\n\naugmentation_layers \u003d tf.keras.Sequential([\n    layers.RandomRotation(factor\u003d0.08), # ~30 degrees\n    layers.RandomTranslation(height_factor\u003d0.1, width_factor\u003d0.1),\n    layers.RandomZoom(height_factor\u003d0.2, width_factor\u003d0.2),\n    layers.RandomContrast(factor\u003d0.2),\n    Cutout(mask_size\u003d8)\n])\n\nBATCH_SIZE \u003d 512 # Larger batch size for T4 GPU\ntrain_ds_raw \u003d tf.data.Dataset.from_tensor_slices((x_train, y_train))\ntest_ds_raw \u003d tf.data.Dataset.from_tensor_slices((x_test, y_test))\ntrain_ds_aug \u003d train_ds_raw.map(lambda x, y: (augmentation_layers(x, training\u003dTrue), y), num_parallel_calls\u003dtf.data.AUTOTUNE)\ntrain_ds_combined \u003d train_ds_raw.concatenate(train_ds_aug)\n\nprint(\"Processing and caching datasets...\")\ntrain_ds \u003d train_ds_combined.cache().shuffle(120000).batch(BATCH_SIZE).map(process_batch, num_parallel_calls\u003dtf.data.AUTOTUNE).prefetch(tf.data.AUTOTUNE)\ntest_ds \u003d test_ds_raw.cache().batch(BATCH_SIZE).map(process_batch, num_parallel_calls\u003dtf.data.AUTOTUNE).prefetch(tf.data.AUTOTUNE)\nprint(\"Data pipelines are ready.\")\n\n# --- [PHASE 2: TRAINING] ---\nprint(\"\\n\\n--- [PHASE 2] Starting Ensemble Training ---\")\nNUM_MODELS \u003d 3; EPOCHS \u003d 150; ENSEMBLE_TAG \u003d \"sota_resnet_run\"\nCLASS_NAMES \u003d [\u0027T-shirt/top\u0027, \u0027Trouser\u0027, \u0027Pullover\u0027, \u0027Dress\u0027, \u0027Coat\u0027, \u0027Sandal\u0027, \u0027Shirt\u0027, \u0027Sneaker\u0027, \u0027Bag\u0027, \u0027Ankle boot\u0027]\n\nfor model_index in range(1, NUM_MODELS + 1):\n    print(f\"\\n--- Training Model {model_index}/{NUM_MODELS} ---\")\n    with strategy.scope():\n        model \u003d build_qa_resnet()\n        # --- [NEW] Advanced Optimizer and Scheduler ---\n        total_steps \u003d math.ceil(120000 / BATCH_SIZE) * EPOCHS\n        lr_schedule \u003d tf.keras.optimizers.schedules.CosineDecay(initial_learning_rate\u003d1e-3, decay_steps\u003dtotal_steps, alpha\u003d1e-6)\n        optimizer \u003d tfa.optimizers.AdamW(weight_decay\u003d1e-5, learning_rate\u003dlr_schedule)\n        \n        model.compile(optimizer\u003doptimizer,\n                      loss\u003d{\u0027class_output\u0027: \u0027sparse_categorical_crossentropy\u0027, \u0027qa_output\u0027: \u0027mse\u0027},\n                      loss_weights\u003d{\u0027class_output\u0027: 1.0, \u0027qa_output\u0027: 0.25},\n                      metrics\u003d{\u0027class_output\u0027: \u0027accuracy\u0027})\n                      \n    save_path \u003d f\"{ENSEMBLE_TAG}_model_{model_index}.keras\"\n    callbacks_list \u003d [\n        callbacks.ModelCheckpoint(filepath\u003dsave_path, monitor\u003d\u0027val_class_output_accuracy\u0027, mode\u003d\u0027max\u0027, save_best_only\u003dTrue, verbose\u003d1),\n        callbacks.EarlyStopping(monitor\u003d\u0027val_loss\u0027, patience\u003d20, restore_best_weights\u003dTrue) # Increased patience\n    ]\n    model.fit(train_ds, epochs\u003dEPOCHS, verbose\u003d1, validation_data\u003dtest_ds, callbacks\u003dcallbacks_list)\n    print(f\"\\nTraining for model {model_index} complete. Best model saved to {save_path}\")\n\n# --- [PHASE 3: EVALUATION] ---\nprint(\"\\n\\n--- [PHASE 3] Starting Final Ensemble Evaluation with TTA ---\")\n# ... (Evaluation code will be added here once training is successful)\nprint(\"\\n\\nExecution complete. The best saved model for each training run is ready for analysis.\")\n```",
