{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "QA_ALGEBRA_BRIDGE_CERT.v1.schema.json",
  "title": "QA Algebra Bridge Certificate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_utc",
    "subject",
    "semantics",
    "claims",
    "fixtures",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "QA_ALGEBRA_BRIDGE_CERT.v1"
    },
    "cert_id": {
      "type": "string",
      "minLength": 6
    },
    "created_utc": {
      "type": "string",
      "minLength": 10
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semantics_id", "generator_semantics_ref", "word_application_order"],
      "properties": {
        "semantics_id": {"type": "string", "const": "QA_ALGEBRA_SEMANTICS.v1"},
        "generator_semantics_ref": {"type": "string", "const": "QA_GENERATORS_SIGMA_SHEAR.v1"},
        "word_application_order": {"type": "string", "const": "left_to_right"}
      }
    },
    "semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generator_defs", "core_properties", "semantics_sha256"],
      "properties": {
        "generator_defs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sigma", "mu", "R", "lambda_k", "nu"],
          "properties": {
            "sigma": {"type": "string"},
            "mu": {"type": "string"},
            "R": {"type": "string"},
            "lambda_k": {"type": "string"},
            "nu": {"type": "string"}
          }
        },
        "core_properties": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "semantics_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generator_behavior",
        "word_convention",
        "component_bridge",
        "semantics_hash_binding"
      ],
      "properties": {
        "generator_behavior": {"type": "boolean"},
        "word_convention": {"type": "boolean"},
        "component_bridge": {"type": "boolean"},
        "semantics_hash_binding": {"type": "boolean"}
      }
    },
    "fixtures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generator_probes", "word_probes", "component_probes"],
      "properties": {
        "generator_probes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["op", "state", "expected_ok", "expected_fail_type"],
            "properties": {
              "op": {"type": "string", "enum": ["sigma", "mu", "R", "lambda_k", "nu"]},
              "state": {"$ref": "#/definitions/vector2"},
              "k": {"type": "integer", "minimum": 1},
              "expected_ok": {"type": "boolean"},
              "expected_value": {"$ref": "#/definitions/vector2"},
              "expected_fail_type": {"type": "string", "enum": ["", "NOT_IN_NATURAL_DOMAIN", "ODD_BLOCK"]}
            }
          }
        },
        "word_probes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["word", "seed", "expected_state"],
            "properties": {
              "word": {"type": "string", "pattern": "^[LR]*$"},
              "seed": {"$ref": "#/definitions/vector2"},
              "expected_state": {"$ref": "#/definitions/vector2"}
            }
          }
        },
        "component_probes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "expected_scale", "expected_normalized", "expected_word"],
            "properties": {
              "state": {"$ref": "#/definitions/vector2"},
              "expected_scale": {"type": "integer", "minimum": 1},
              "expected_normalized": {"$ref": "#/definitions/vector2"},
              "expected_word": {"type": "string", "pattern": "^[LR]*$"}
            }
          }
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "failures", "invariant_diff_map"],
      "properties": {
        "ok": {"type": "boolean"},
        "failures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["gate", "fail_type", "path", "reason"],
            "properties": {
              "gate": {"type": "integer", "minimum": 1},
              "fail_type": {"type": "string"},
              "path": {"type": "string"},
              "reason": {"type": "string"}
            }
          }
        },
        "invariant_diff_map": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entries", "rollup_sha256"],
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["gate", "fail_type", "path", "reason"],
                "properties": {
                  "gate": {"type": "integer", "minimum": 1},
                  "fail_type": {"type": "string"},
                  "path": {"type": "string"},
                  "reason": {"type": "string"}
                }
              }
            },
            "rollup_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        }
      }
    }
  },
  "definitions": {
    "vector2": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "integer"}
    }
  }
}
