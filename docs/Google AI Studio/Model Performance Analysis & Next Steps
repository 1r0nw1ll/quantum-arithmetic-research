h residual connections and L2 regularization \"\"\"\n    \n    inputs \u003d Input(shape\u003d(input_dim,))\n    x \u003d Dense(128, activation\u003d\u0027selu\u0027, kernel_regularizer\u003dregularizers.l2(l2_lambda))(inputs)\n    x \u003d BatchNormalization()(x)\n    x \u003d Dropout(dropout_rate)(x)\n\n    # Residual Connection\n    residual \u003d Dense(128, activation\u003d\u0027selu\u0027, kernel_regularizer\u003dregularizers.l2(l2_lambda))(x)\n    residual \u003d BatchNormalization()(residual)\n    residual \u003d Dense(128, activation\u003d\u0027selu\u0027, kernel_regularizer\u003dregularizers.l2(l2_lambda))(residual)\n    x \u003d Add()([x, residual])\n\n    x \u003d Dense(64, activation\u003d\u0027selu\u0027, kernel_regularizer\u003dregularizers.l2(l2_lambda))(x)\n    x \u003d Dropout(dropout_rate)(x)\n    outputs \u003d Dense(1, activation\u003d\u0027linear\u0027)(x)\n\n    model \u003d Model(inputs\u003dinputs, outputs\u003doutputs)\n    return model\n\n# Main Execution\nif __name__ \u003d\u003d \"__main__\":\n    print(\"Beginning data generation\")\n    features, labels \u003d generate_dataset(num_samples\u003d5000)\n\n    X_train, X_test, y_train, y_test \u003d train_test_split(features, labels, test_size\u003d0.2, random_state\u003d42)\n\n    scaler \u003d StandardScaler()\n    X_train_scaled \u003d scaler.fit_transform(X_train)\n    X_test_scaled \u003d scaler.transform(X_test)\n    \n    # Define hyperparameter ranges\n    l2_lambdas \u003d [0.0005, 0.001, 0.005]\n    dropout_rates \u003d [0.2, 0.3, 0.4]\n    \n    best_mae \u003d float(\u0027inf\u0027)\n    best_params \u003d None\n    \n    # Perform Grid Search\n    for l2_lambda, dropout_rate in itertools.product(l2_lambdas, dropout_rates):\n        print(f\"Testing: L2\u003d{l2_lambda}, Dropout\u003d{dropout_rate}\")\n        \n        model \u003d build_model(input_dim\u003dfeatures.shape[1], l2_lambda\u003dl2_lambda, dropout_rate\u003ddropout_rate)\n        optimizer \u003d Adam(learning_rate\u003d0.001, clipnorm\u003d1.0)\n        model.compile(optimizer\u003doptimizer, loss\u003d\u0027mse\u0027, metrics\u003d[\u0027mae\u0027])\n\n        # Learning rate scheduler and early stopping\n        reduce_lr \u003d ReduceLROnPlateau(monitor\u003d\u0027val_loss\u0027, factor\u003d0.2, patience\u003d5, min_lr\u003d1e-7)\n        early_stopping \u003d tf.keras.callbacks.EarlyStopping(monitor\u003d\u0027val_loss\u0027, patience\u003d7, restore_best_weights\u003dTrue)\n\n        history \u003d model.fit(\n            X_train_scaled, y_train, epochs\u003d50, batch_size\u003d32, \n            validation_data\u003d(X_test_scaled, y_test), \n            callbacks\u003d[reduce_lr, early_stopping], verbose\u003d0\n        )\n\n        loss, mae \u003d model.evaluate(X_test_scaled, y_test, verbose\u003d0)\n        print(f\"Test Mean Absolute Error: {mae}\")\n        \n        if mae \u003c best_mae:\n            best_mae \u003d mae\n            best_params \u003d {\u0027l2_lambda\u0027: l2_lambda, \u0027dropout_rate\u0027: dropout_rate}\n            \n    print(\"\\nBest Parameters:\", best_params)\n    print(\"Best Test Mean Absolute Error:\", best_mae)\n\n    # Train final model with best parameters\n    best_model \u003d build_model(input_dim\u003dfeatures.shape[1], l2_lambda\u003dbest_params[\u0027l2_lambda\u0027], dropout_rate\u003dbest_params[\u0027dropout_rate\u0027])\n    optimizer \u003d Adam(learning_rate\u003d0.001, clipnorm\u003d1.0)\n    best_model.compile(optimizer\u003doptimizer, loss\u003d\u0027mse\u0027, metrics\u003d[\u0027mae\u0027])\n    \n    history \u003d best_model.fit(\n        X_train_scaled, y_train, epochs\u003d50, batch_size\u003d32, \n        validation_data\u003d(X_test_scaled, y_test), \n        callbacks\u003d[reduce_lr, early_stopping], verbose\u003d1  # Set verbose\u003d1 for the final run\n    )\n    \n    # Plot the training history of the best model\n    plt.plot(history.history[\u0027loss\u0027], label\u003d\u0027train_loss\u0027)\n    plt.plot(history.history[\u0027val_loss\u0027], label\u003d\u0027val_loss\u0027)\n    plt.xlabel(\"Epoch\")\n    plt.ylabel(\"Loss\")\n    plt.legend()\n    plt.show()\n```\n\nRun the script to find the optimized parameters and their corresponding test MAE.\n",
