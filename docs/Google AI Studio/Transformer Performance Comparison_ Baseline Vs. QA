   # --- QA triangle (Euclidean basis) ---\n        A1,A2,A3 \u003d qa_tuple_to_triangle(b,e,d,a)\n        tri_csv_data \u003d emit_triangle_batch_to_csv([(A1,A2,A3)], None, write_file\u003dFalse)[0] # Get single row dict\n\n        # --- Chromo Euler centers ---\n        centers \u003d euler_pack(A1,A2,A3)\n        cross \u003d cross_color_checks(A1,A2,A3)\n        tri_csv_data.update({\n            \"blue_O_x\":centers[\"blue\"][\"O\"][0] if centers[\"blue\"][\"O\"] else np.nan,\n            \"blue_O_y\":centers[\"blue\"][\"O\"][1] if centers[\"blue\"][\"O\"] else np.nan,\n            \"blue_C_x\":centers[\"blue\"][\"C\"][0] if centers[\"blue\"][\"C\"] else np.nan,\n            \"blue_C_y\":centers[\"blue\"][\"C\"][1] if centers[\"blue\"][\"C\"] else np.nan,\n            \"blue_N_x\":centers[\"blue\"][\"N\"][0] if centers[\"blue\"][\"N\"] else np.nan,\n            \"blue_N_y\":centers[\"blue\"][\"N\"][1] if centers[\"blue\"][\"N\"] else np.nan,\n            \"blue_G_x\":centers[\"blue\"][\"G\"][0] if centers[\"blue\"][\"G\"] else np.nan,\n            \"blue_G_y\":centers[\"blue\"][\"G\"][1] if centers[\"blue\"][\"G\"] else np.nan,\n            \"blue_euler\":centers[\"blue\"][\"euler_collinear\"],\n            \"red_euler\":centers[\"red\"][\"euler_collinear\"],\n            \"green_euler\":centers[\"green\"][\"euler_collinear\"],\n            \"cross_ObCrOg\":cross[\"ObCrOg_collinear\"],\n            \"cross_CbNrCg\":cross[\"CbNrCg_collinear\"]\n        })\n\n        # --- UHG Null Point Analysis ---\n        uhg_point \u003d qa_tuple_to_uhg_point(b, e, d, a)\n        q_self \u003d uhg_self_quadrance(uhg_point)\n        is_null_uhg \u003d abs(q_self) \u003c 1e-9\n\n        tri_csv_data.update({\n            \"UHG_x\": uhg_point[0],\n            \"UHG_y\": uhg_point[1],\n            \"UHG_z\": uhg_point[2],\n            \"UHG_Self_Q\": q_self,\n            \"UHG_Is_Null\": is_null_uhg\n        })\n        \n        csv_rows.append(tri_csv_data)\n        uhg_points