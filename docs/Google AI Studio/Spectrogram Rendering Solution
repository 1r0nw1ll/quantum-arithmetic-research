rain_test_split\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.neural_network import MLPClassifier\nfrom sklearn.metrics import accuracy_score, classification_report, confusion_matrix\nfrom sklearn.impute import SimpleImputer # \u003c-- Added Imputer\nimport matplotlib.pyplot as plt\nimport seaborn as sns # For plotting confusion matrix\nfrom imblearn.over_sampling import SMOTE # Import SMOTE\n\nprint(\"Libraries imported successfully.\")\n```\n\n---\n\n**(Cell 4: Markdown)**\n\n```markdown\n## 1. Define Parameters and Sequence Generation Functions\n```\n\n---\n\n**(Cell 5: Code) - Parameters \u0026 Sequence Functions**\n\n```python\n# --- Parameters ---\nN_TERMS \u003d 1000 # Using 1000 terms\n\n# Define what constitutes a \"resonant\" state for labeling (y)\nRESONANCE_CRITERIA \u003d {1, 8, 9}\n\n# --- Sequence Generation Functions ---\n\ndef generate_fibonacci(n):\n    \"\"\"Generates the first n Fibonacci numbers (starting 0, 1).\"\"\"\n    if n \u003c\u003d 0: return []\n    if n \u003d\u003d 1: return [0]\n    sequence \u003d [0, 1]\n    while len(sequence) \u003c n:\n        next_val \u003d sequence[-1] + sequence[-2]\n        sequence.append(next_val)\n    # Use float64 for larger range, handle potential large numbers\n    return np.array(sequence[:n], dtype\u003dnp.float64)\n\ndef generate_cubes(n):\n    \"\"\"Generates the first n cube numbers (0^3, 1^3, 2^3, ...).\"\"\"\n    # Use float64 for consistency and larger range\n    return np.array([float(i**3) for i in range(n)], dtype\u003dnp.float64)\n\ndef get_digital_root(num):\n    \"\"\"Calculates the digital root of a non-negative integer.\"\"\"\n    try:\n        if not np.isfinite(num):\n             return 0\n        n \u003d abs(int(num))\n    except (OverflowError, ValueError):\n        return 0 # Fallback for extreme values\n\n    if n \u003d\u003d 0: return 0\n    return 1 + (n - 1) % 9\n\ndef generate_digital_root_cycle(n):\n    \"\"\"Generates the digital root sequence for 1, 2, 3,... up to length n.\"\"\"\n    return np.array([float(get_digital_root(i)) for i in range(1, n + 1)], dtype\u003dnp.float64)\n\nprint(f\"Parameters set: N_TERMS\u003d{N_TERMS}\")\nprint(f\"Resonance criteria based on Digital Root values: {RESONANCE_CRITERIA}\")\n```\n\n---\n\n**(Cell 6: Markdown)**\n\n```markdown\n## 2. Generate Sequences and Create Dataset (X, y)\n```\n\n---\n\n**(Cell 7: Code) - Generate Data \u0026 Create X, y**\n\n```python\n# --- Generate the core sequences ---\nfib_seq \u003d generate_fibonacci(N_TERMS)\ncube_seq \u003d generate_cubes(N_TERMS)\ndr_seq \u003d generate_digital_root_cycle(N_TERMS)\n\nprint(\"Sequences Generated:\")\nprint(f\"Fibonacci (last 5): {fib_seq[-5:]}\") # Show last few for magnitude check\nprint(f\"Cubes (last 5):     {cube_seq[-5:]}\")\nprint(f\"Digital Root (first 15): {dr_seq[:15]}\")\nprint(\"-\" * 20)\n\n# --- Create Feature Matrix X ---\nif not (len(fib_seq) \u003d\u003d N_TERMS and len(cube_seq) \u003d\u003d N_TERMS and len(dr_seq) \u003d\u003d N_TERMS):\n    raise ValueError(f\"All sequences must have length {N_TERMS} for stacking.\")\n\nX \u003d np.stack([fib_seq, cube_seq, dr_seq], axis\u003d1)\n\n# Handle potential infinite values BEFORE splitting/scaling\ninitial_finite_check \u003d np.all(np.isfinite(X))\nprint(f\"Is dataset finite BEFORE pre-processing? {initial_finite_check}\")\nif not initial_finite_check:\n    print(\"Warning: Non-finite values (inf or NaN) detected in initial feature matrix X.\")\n    print(\"Replacing non-finite values with 0. Consider adjusting sequence generation if issues persist.\")\n    X \u003d np.nan_to_num(X, nan\u003d0.0, posinf\u003dnp.finfo(np.float64).max, neginf\u003dnp.finfo(np.float64).min) # Replace inf with large finite numbers instead of 0\n\n\nprint(f\"Feature matrix X created with shape: {X.shape}\")\nprint(\"First 5 rows of X:\")\nprint(X[:5])\nprint(\"-\" * 20)\n\n# --- Create Label Vector y ---\ny \u003d np.array([1 if dr_val in RESONANCE_CRITERIA else 0 for dr_val in dr_seq], dtype\u003dint)\n\nprint(f\"Label vector y created with shape: {y.shape}\")\nprint(f\"Distribution of labels: Class 0: {np.sum(y \u003d\u003d 0)}, Class 1: {np.sum(y \u003d\u003d 1)}\")\nif np.sum(y \u003d\u003d 0) \u003d\u003d 0 or np.sum(y \u003d\u003d 1) \u003d\u003d 0:\n     raise ValueError(\"Dataset contains only one class. Cannot train classifier.\")\nelif np.sum(y \u003d\u003d 0) \u003c 5 or np.sum(y \u003d\u003d 1) \u003c 5:\n     print(\"\\nWarning: Very few samples in one of the classes.\")\n\n```\n\n---\n\n**(Cell 8: Markdown)**\n\n```markdown\n## 3. Preprocess Data (Split, Scale, and Impute)\n```\n\n---\n\n**(Cell 9: Code) - Split, Scale \u0026 Impute**\n\n```python\n# --- Split Data into Training and Testing sets ---\ntry:\n    X_train, X_test, y_train, y_test \u003d train_test_split(\n        X, y,\n        test_size\u003d0.3, # 30% for testing\n        random_state\u003d42, # For reproducibility\n        stratify\u003dy      # Preserve class proportions in split\n    )\n    print(\"Data split into training and testing sets:\")\n    print(f\"X_train shape: {X_train.shape}, y_train shape: {y_train.shape}\")\n    print(f\"X_test shape: {X_test.shape}, y_test shape: {y_test.shape}\")\n    print(f\"Test set distribution: Class 0: {sum(y_test\u003d\u003d0)}, Class 1: {sum(y_test\u003d\u003d1)}\")\nexcept ValueError as e:\n    raise ValueError(f\"Error during stratified train_test_split: {e}. Check class distribution.\") from e\n\nprint(\"-\" * 20)\n\n# --- Scale Features ---\nscaler \u003d StandardScaler()\n# Fit scaler ONLY on the training data\nX_train_scaled \u003d scaler.fit_transform(X_train)\n# Apply the SAME transformation to the test data\nX_test_scaled \u003d scaler.transform(X_test)\nprint(\"Features scaled using StandardScaler.\")\n\n# --- Check for NaNs AFTER Scaling ---\nprint(f\"NaNs in X_train_scaled BEFORE imputation: {np.sum(np.isnan(X_train_scaled))}\")\nprint(f\"NaNs in X_test_scaled BEFORE imputation: {np.sum(np.isnan(X_test_scaled))}\")\n\n# --- Impute Missing Values (NaNs potentially created by scaling large numbers) ---\nif np.any(np.isnan(X_train_scaled)) or np.any(np.isnan(X_test_scaled)):\n    print(\"\\nNaNs detected after scaling. Applying SimpleImputer...\")\n    # Use median strategy as it\u0027s less sensitive to outliers than mean\n    imputer \u003d SimpleImputer(strategy\u003d\u0027median\u0027)\n\n    # Fit imputer ONLY on the scaled training data\n    X_train_scaled \u003d imputer.fit_transform(X_train_scaled)\n    # Apply the SAME imputer transformation to the scaled test data\n    X_test_scaled \u003d imputer.transform(X_test_scaled)\n\n    # --- Check for NaNs AFTER Imputation ---\n    print(f\"NaNs in X_train_scaled AFTER imputation: {np.sum(np.isnan(X_train_scaled))}\")\n    print(f\"NaNs in X_test_scaled AFTER imputation: {np.sum(np.isnan(X_test_scaled))}\")\nelse:\n    print(\"\\nNo NaNs detected after scaling. Imputation step skipped.\")\n\nprint(\"\\nSample of scaled (and potentially imputed) training data (first 3 rows):\")\nprint(X_train_scaled[:3])\n```\n\n---\n\n**(Cell 10: Markdown)**\n\n```markdown\n## 4. Apply SMOTE and Train the Neural Network (MLPClassifier)\n```\n\n---\n\n**(Cell 11: Code) - SMOTE \u0026 Train**\n\n```python\n# --- Apply SMOTE to Resample the Training Data ---\nprint(f\"\\nOriginal training set shape: {X_train_scaled.shape}\")\nprint(f\"Original training set distribution: Class 0: {sum(y_train\u003d\u003d0)}, Class 1: {sum(y_train\u003d\u003d1)}\")\n\n# Instantiate SMOTE\nsmote \u003d SMOTE(random_state\u003d42)\n\nprint(\"\\nApplying SMOTE to balance the training data...\")\n# Apply SMOTE ONLY to the (scaled and imputed) training data\nX_train_resampled, y_train_resampled \u003d smote.fit_resample(X_train_scaled, y_train)\n\nprint(f\"Resampled training set shape: {X_train_resampled.shape}\")\nprint(f\"Resampled training set distribution: Class 0: {sum(y_train_resampled\u003d\u003d0)}, Class 1: {sum(y_train_resampled\u003d\u003d1)}\")\nprint(\"-\" * 20)\n\n\n# --- Define the MLP Model ---\nmlp \u003d MLPClassifier(\n    hidden_layer_sizes\u003d(64, 32),\n    activation\u003d\u0027relu\u0027,\n    solver\u003d\u0027adam\u0027,\n    alpha\u003d0.0001,\n    max_iter\u003d500,\n    random_state\u003d42,\n    early_stopping\u003dTrue,\n    n_iter_no_change\u003d15 # Patience for early stopping\n)\n\n# --- Train the Model on the RESAMPLED Data ---\nprint(\"Training MLPClassifier on RESAMPLED data...\")\nmlp.fit(X_train_resampled, y_train_resampled) # Use the imputed and resampled data\n\nprint(\"Training complete.\")\nif hasattr(mlp, \u0027n_iter_\u0027):\n    print(f\"Number of iterations run: {mlp.n_iter_}\")\nif hasattr(mlp, \u0027best_loss_\u0027): # Check if early stopping was used effectively\n    print(f\"Best validation loss achieved: {mlp.best_loss_ if mlp.best_loss_ is not None else \u0027N/A (no early stopping validation)\u0027}\")\n```\n\n---\n\n**(Cell 12: Markdown)**\n\n```markdown\n## 5. Evaluate the Model (on Original Imputed Test Set)\n```\n\n---\n\n**(Cell 13: Code) - Evaluate**\n\n```python\n# --- Make Predictions on the ORIGINAL Scaled and Imputed Test Set ---\n# Ensure X_test_scaled is the imputed version from Cell 9\ny_pred \u003d mlp.predict(X_test_scaled)\n\n# --- Calculate Accuracy ---\naccuracy \u003d accuracy_score(y_test, y_pred)\nprint(f\"Model Accuracy on Original Test Set: {accuracy:.4f}\")\nprint(\"-\" * 20)\n\n# --- Classification Report ---\nprint(\"Classification Report (on Original Test Set):\")\nprint(classification_report(y_test, y_pred, target_names\u003d[\u0027Class 0 (Transitional)\u0027, \u0027Class 1 (Resonant)\u0027], zero_division\u003d0))\nprint(\"-\" * 20)\n\n\n# --- Confusion Matrix ---\nprint(\"Confusion Matrix (on Original Test Set):\")\ncm \u003d confusion_matrix(y_test, y_pred)\nprint(cm)\nprint(\"-\" * 20)\n\n# --- Plot Confusion Matrix ---\nplt.figure(figsize\u003d(6, 5))\nsns.heatmap(cm, annot\u003dTrue, fmt\u003d\u0027d\u0027, cmap\u003d\u0