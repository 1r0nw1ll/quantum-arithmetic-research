{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "QA_STRUCTURAL_ALGEBRA_CERT.v1.schema.json",
  "title": "QA Structural Algebra Certificate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_utc",
    "subject",
    "claims",
    "fixtures",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "QA_STRUCTURAL_ALGEBRA_CERT.v1"
    },
    "cert_id": {
      "type": "string",
      "minLength": 6
    },
    "created_utc": {
      "type": "string",
      "minLength": 10
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seed", "N", "generators", "algebra_bridge_semantics_sha256"],
      "properties": {
        "seed": {"$ref": "#/definitions/vector2"},
        "N": {"type": "integer", "minimum": 1},
        "generators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["sigma", "mu", "R", "lambda_k", "nu"]
          }
        },
        "algebra_bridge_semantics_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Must match qa_algebra_bridge_cert_v1.semantics_anchor.BRIDGE_SEMANTICS_SHA256 (enforced by validator Gate 1)."
        },
        "failure_algebra_anchor_ref": {
          "type": "string",
          "description": "Optional soft bridge. If present, validator verifies qa_failure_algebra_structure_cert_v1.failure_algebra_anchor.FAILURE_ALGEBRA_ANCHOR_REF."
        },
        "failure_algebra_anchor_rollup_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Optional soft bridge rollup. If present, validator verifies qa_failure_algebra_structure_cert_v1.failure_algebra_anchor.FAILURE_ALGEBRA_ANCHOR_ROLLUP_SHA256."
        }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": ["normal_form", "uniqueness", "scaling_components", "guarded_contraction"],
      "properties": {
        "normal_form": {"type": "boolean"},
        "uniqueness": {"type": "boolean"},
        "scaling_components": {"type": "boolean"},
        "guarded_contraction": {"type": "boolean"}
      }
    },
    "fixtures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roundtrip_samples", "nu_guard_samples", "scale_samples"],
      "properties": {
        "roundtrip_samples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "expected_word", "expected_roundtrip"],
            "properties": {
              "state": {"$ref": "#/definitions/vector2"},
              "expected_word": {
                "type": "string",
                "pattern": "^[LR]*$"
              },
              "expected_roundtrip": {"$ref": "#/definitions/vector2"}
            }
          }
        },
        "nu_guard_samples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "expected_ok", "expected_fail_type"],
            "properties": {
              "state": {"$ref": "#/definitions/vector2"},
              "expected_ok": {"type": "boolean"},
              "expected_value": {"$ref": "#/definitions/vector2"},
              "expected_fail_type": {
                "type": "string",
                "enum": [
                  "NOT_IN_NATURAL_DOMAIN",
                  "NOT_COPRIME",
                  "REVERSE_STEP_INVALID",
                  "ODD_BLOCK",
                  "NOT_UNIQUE",
                  ""
                ]
              }
            }
          }
        },
        "scale_samples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["state", "expected_normalized", "expected_scale"],
            "properties": {
              "state": {"$ref": "#/definitions/vector2"},
              "expected_normalized": {"$ref": "#/definitions/vector2"},
              "expected_scale": {"type": "integer", "minimum": 1}
            }
          }
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "failures", "invariant_diff_map"],
      "properties": {
        "ok": {"type": "boolean"},
        "failures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["gate", "fail_type", "path", "reason"],
            "properties": {
              "gate": {"type": "integer", "minimum": 1},
              "fail_type": {"type": "string"},
              "path": {"type": "string"},
              "reason": {"type": "string"}
            }
          }
        },
        "invariant_diff_map": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entries", "rollup_sha256"],
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["gate", "fail_type", "path", "reason"],
                "properties": {
                  "gate": {"type": "integer", "minimum": 1},
                  "fail_type": {"type": "string"},
                  "path": {"type": "string"},
                  "reason": {"type": "string"}
                }
              }
            },
            "rollup_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
          }
        }
      }
    }
  },
  "definitions": {
    "vector2": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "integer"}
    }
  }
}
