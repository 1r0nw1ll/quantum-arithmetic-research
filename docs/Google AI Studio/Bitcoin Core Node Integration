er\u003d\u0027little\u0027)\n        nonce_bytes \u003d int(nonce).to_bytes(4, byteorder\u003d\u0027little\u0027)\n        header_bin \u003d (\n            version_bytes +\n            prev_block_bytes +\n            merkle_root_bytes +\n            timestamp_bytes +\n            bits_bytes +\n            nonce_bytes\n        )\n        if len(header_bin) !\u003d 80:\n            raise Exception(f\"Constructed header has incorrect length: {len(header_bin)} bytes\")\n        return header_bin\n    except Exception as e:\n        print(f\"Error building block header: {e}\")\n        return None\n\ndef double_sha256(data):\n    \"\"\"Performs the Bitcoin double SHA256 hash.\"\"\"\n    if data is None:\n        return None\n    try:\n        hash1 \u003d hashlib.sha256(data).digest()\n        hash2 \u003d hashlib.sha256(hash1).digest()\n        return hash2[::-1].hex()\n    except Exception as e:\n        print(f\"Error computing double SHA256: {e}\")\n        return \"error_hashing\"\n\ndef hex_to_target(bits_hex):\n    \"\"\"Converts the compact difficulty \u0027bits\u0027 hex string to the 256-bit target integer.\"\"\"\n    try:\n        bits_int \u003d int(bits_hex, 16)\n        exponent \u003d bits_int \u003e\u003e 24\n        mantissa \u003d bits_int \u0026 0x007fffff\n        if (bits_int \u0026 0x00800000) !\u003d 0:\n             mantissa \u003d -mantissa\n        target \u003d mantissa \u003c\u003c (8 * (exponent - 3))\n        if target \u003c 0:\n            target \u003d 0\n        return target\n    except Exception as e:\n        print(f\"Error converting bits \u0027{bits_hex}\u0027 to target: {e}\")\n        return 0\n\n# ----------------------------------------------------------------------------\n# QA Guided Nonce Generation with Modular Filtering and Data Yield (Corrected)\n# Now correctly yields original b, e, d, a that generated the offset.\n# ----------------------------------------------------------------------------\ndef qa_guided_nonce_stream_da