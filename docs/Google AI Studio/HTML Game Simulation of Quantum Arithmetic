put type\u003d\"number\" id\u003d\"reverse-b\" value\u003d\"4\"\u003e\n        \u003clabel for\u003d\"reverse-e\"\u003eInput e\u0027:\u003c/label\u003e \u003cinput type\u003d\"number\" id\u003d\"reverse-e\" value\u003d\"7\"\u003e\n        \u003clabel for\u003d\"reverse-d\"\u003eInput d\u0027:\u003c/label\u003e \u003cinput type\u003d\"number\" id\u003d\"reverse-d\" value\u003d\"3\"\u003e\n        \u003cbutton id\u003d\"reverse-button\"\u003eFind Previous State(s)\u003c/button\u003e\n        \u003clabel style\u003d\"margin-top:15px;\"\u003ePossible Previous State(s):\u003c/label\u003e\n        \u003cdiv id\u003d\"reverse-output\"\u003eEnter values and click \"Find\".\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv id\u003d\"visualization\" class\u003d\"panel\"\u003e\n        \u003ch3\u003eVisualization\u003c/h3\u003e\n        \u003c!-- Added Resonance Toggle --\u003e\n        \u003cdiv style\u003d\"margin-bottom: 10px; text-align: center;\"\u003e\n             \u003clabel for\u003d\"show-resonances\"\u003eShow Resonant Intervals:\u003c/label\u003e\n             \u003cinput type\u003d\"checkbox\" id\u003d\"show-resonances\" checked\u003e\n        \u003c/div\u003e\n        \u003ccanvas id\u003d\"qaCanvas\" width\u003d\"400\" height\u003d\"400\"\u003e\u003c/canvas\u003e\n        \u003cdiv id\u003d\"viz-info\" style\u003d\"margin-top: 10px; font-style: italic;\"\u003eMod-24 Wheel\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv id\u003d\"output\" class\u003d\"panel\"\u003e\n        \u003c!-- Output Panel (unchanged) --\u003e\n        \u003ch3 id\u003d\"output-title\"\u003eCurrent State Output (Step 0)\u003c/h3\u003e\n        \u003cdiv\u003eState at Step \u003cspan id\u003d\"current-step-display\"\u003e0\u003c/span\u003e:\u003c/div\u003e\n        \u003cdiv\u003eQuNit:\u003cbr\u003e b\u003d\u003cspan id\u003d\"output-b\"\u003e?\u003c/span\u003e, e\u003d\u003cspan id\u003d\"output-e\"\u003e?\u003c/span\u003e, d\u003d\u003cspan id\u003d\"output-d\"\u003e?\u003c/span\u003e, a\u003d\u003cspan id\u003d\"output-a\"\u003e?\u003c/span\u003e\u003c/div\u003e\n        \u003cdiv\u003eMeasurement:\u003cbr\u003e Rounded a: \u003cspan id\u003d\"measure-a\"\u003e?\u003c/span\u003e\u003cbr\u003e b/e Ratio: \u003cspan id\u003d\"measure-ratio\"\u003e?\u003c/span\u003e\u003cbr\u003e Is (b+e) Prime?: \u003cspan id\u003d\"measure-prime\"\u003e?\u003c/span\u003e\u003cbr\u003e Probabilistic Collapse: \u003cspan id\u003d\"measure-collapse\"\u003e?\u003c/span\u003e\u003c/div\u003e\n        \u003cdiv\u003eHarmonics (Aliquot Parts of \u0027a\u0027):\u003cbr\u003e \u003cul id\u003d\"harmonics-list\"\u003e\u003c/ul\u003e\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv id\u003d\"sequence-output\" class\u003d\"panel\"\u003e\n        \u003c!-- Sequence Panel (unchanged) --\u003e\n        \u003ch3\u003eOperation Sequence (\u003cspan id\u003d\"total-steps-display\"\u003e0\u003c/span\u003e steps)\u003c/h3\u003e\n        \u003cdiv id\u003d\"sequence-list\"\u003eGenerate sequence to view steps...\u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cscript\u003e\n        // --- DOM References --- (Added resonance toggle)\n        /* ... existing DOM refs ... */\n        const showResonancesCheckbox \u003d document.getElementById(\u0027show-resonances\u0027);\n        /* ... existing DOM refs ... */\n        const reverseBInput \u003d document.getElementById(\u0027reverse-b\u0027); const reverseEInput \u003d document.getElementById(\u0027reverse-e\u0027); const reverseDInput \u003d document.getElementById(\u0027reverse-d\u0027); const reverseButton \u003d document.getElementById(\u0027reverse-button\u0027); const reverseOutputDiv \u003d document.getElementById(\u0027reverse-output\u0027);\n\n        // --- State Variables --- (Unchanged)\n        let fullSequence \u003d []; let currentStep \u003d 0; let isPlaying \u003d false;\n        let animationIntervalId \u003d null; let animationSpeedMs \u003d 500;\n\n        // --- Constants for Resonance Mapping ---\n        const resonanceRatios \u003d {\n            \"Octave Up (2:1)\": 2,\n            \"Octave Down (1:2)\": 1/2,\n            \"Perfect 5th (3:2)\": 3/2,\n            \"Perfect 4th (4:3)\": 4/3,\n            \"Major 3rd (5:4)\": 5/4,\n            \"Minor 3rd (6:5)\": 6/5,\n            \"Inv P5 (2:3)\": 2/3, // Inverted intervals\n            \"Inv P4 (3:4)\": 3/4,\n            \"Inv M3 (4:5)\": 4/5,\n            \"Inv m3 (5:6)\": 5/6,\n            \"Tritone (√2:1)\": Math.SQRT2, // Example non-perfect ratio\n             \"Inv Tritone (1:√2)\": 1/Math.SQRT2,\n        };\n        const resonanceColors \u003d {\n            \"Octave Up (2:1)\": \"#8A2BE2\", // BlueViolet\n            \"Octave Down (1:2)\": \"#8A2BE2\",\n            \"Perfect 5th (3:2)\": \"#0000FF\", // Blue\n            \"Inv P5 (2:3)\": \"#0000FF\",\n            \"Perfect 4th (4:3)\": \"#228B22\", // ForestGreen\n            \"Inv P4 (3:4)\": \"#228B22\",\n            \"Major 3rd (5:4)\": \"#FFA500\", // Orange\n            \"Inv M3 (4:5)\": \"#FFA500\",\n            \"Minor 3rd (6:5)\": \"#008080\", // Teal\n            \"Inv m3 (5:6)\": \"#008080\",\n            \"Tritone (√2:1)\": \"#FF4500\", // OrangeRed\n            \"Inv Tritone (1:√2)\": \"#FF4500\",\n        };\n         const RESONANCE_TOLERANCE \u003d 0.1; // How close targetValue % modulus must be to an integer index\n\n        // --- QA Simulation Functions --- (Unchanged)\n        function calculateA(b, e, d) { if (isNaN(b) || isNaN(e) || isNaN(d)) return NaN; const i \u003d b*b + 2*d*e + e*e; return (i \u003e\u003d 0) ? Math.sqrt(i) : NaN; }\n        function qaTransform(q) { const a_p \u003d calculateA(q.b, q.e, q.d); if (isNaN(a_p)) return { b: NaN, e: NaN, d: NaN, a: NaN }; const b_o \u003d q.b + 1; const e_o \u003d q.e + q.b; const d_o \u003d (a_p \u003e\u003d 0) ? Math.round(Math.sqrt(a_p)) : 0; const a_o \u003d calculateA(b_o, e_o, d_o); return { b: b_o, e: e_o, d: d_o, a: a_o }; }\n        function collapseToMeasurement(a) { if (isNaN(a)) return NaN; const f \u003d Math.floor(a); const c \u003d Math.ceil(a); if (f \u003d\u003d\u003d c) return f; const p \u003d c - a; return Math.random() \u003c p ? f : c; }\n        function measure(q) { if (isNaN(q.a) || isNaN(q.b) || isNaN(q.e)) { return { rounded_a: \u0027N/A\u0027, ratio: \u0027N/A\u0027, primeRootCheck: \u0027N/A\u0027, collapsed_a: \u0027N/A\u0027 }; } const r \u003d (q.e !\u003d\u003d 0) ? (q.b / q.e).toFixed(3) : \u0027Div/0\u0027; const bpe \u003d q.b + q.e; return { rounded_a: Math.round(q.a), ratio: r, primeRootCheck: !isNaN(bpe) ? isPrime(Math.round(bpe)) : false, collapsed_a: collapseToMeasurement(q.a) }; }\n        function getAliquotParts(n) { if (isNaN(n) || n \u003c\u003d 0) return []; let num \u003d Math.round(n); let p \u003d []; for (let i \u003d 1; i \u003c\u003d num / 2; i++) { if (num % i \u003d\u003d\u003d 0) { p.push(i); } } return p; }\n        function isPrime(num) { if (isNaN(num)) return false; num \u003d Math.floor(Math.abs(num)); if (num \u003c\u003d 1) return false; if (num \u003c\u003d 3) return true; if (num % 2 \u003d\u003d\u003d 0 || num % 3 \u003d\u003d\u003d 0) return false; for (let i \u003d 5; i * i \u003c\u003d num; i \u003d i + 6) { if (num % i \u003d\u003d\u003d 0 || num % (i + 2) \u003d\u003d\u003d 0) return false; } return true; }\n        function findPreviousState(b_next, e_next, d_next) { /* ... (Unchanged from v2.3) ... */ if(isNaN(b_next)||isNaN(e_next)||isNaN(d_next)){return{possibleStates:[],message:\"Invalid input.\"};} const b_prev\u003db_next-1; const e_prev\u003de_next-(b_next-1); if(e_prev\u003d\u003d\u003d0){const a_p\u003dMath.abs(b_prev); const d_c\u003dMath.round(Math.sqrt(a_p)); let msg\u003d(d_c\u003d\u003d\u003dd_next)?`b\u003d${b_prev}, e\u003d0. Any previous \u0027d\u0027 is possible if d\u0027\u003d${d_c}.`:`b\u003d${b_prev}, e\u003d0. Expected d\u0027\u003d${d_c}, received d\u0027\u003d${d_next}. Inconsistent.`; return{possibleStates:[],message:msg};} const K\u003db_prev*b_prev+e_prev*e_prev; const lower_a_sq\u003dMath.max(0,(d_next-0.5)*(d_next-0.5)); const upper_a_sq\u003d(d_next+0.5)*(d_next+0.5); const lower_2de\u003dlower_a_sq-K; const upper_2de\u003dupper_a_sq-K; let d_min,d_max; if(e_prev\u003e0){d_min\u003dlower_2de/(2*e_prev);d_max\u003dupper_2de/(2*e_prev);}else{d_min\u003dupper_2de/(2*e_prev);d_max\u003dlower_2de/(2*e_prev);} const search_start\u003dMath.ceil(d_min); const search_end\u003dMath.floor(d_max-1e-9); const MAX_SR\u003d2000; const final_ss\u003dMath.max(search_start-MAX_SR/2,-MAX_SR); const final_se\u003dMath.min(search_end,search_start+MAX_SR/2,MAX_SR); const possible_d_prev\u003d[]; for(let d_guess\u003dfinal_ss;d_guess\u003c\u003dfinal_se;d_guess++){if(d_guess\u003csearch_start||d_guess\u003esearch_end)continue; const a_check\u003dcalculateA(b_prev,e_prev,d_guess); if(!isNaN(a_check)\u0026\u0026a_check\u003e\u003d0){const d_recalc\u003dMath.round(Math.sqrt(a_check)); if(d_recalc\u003d\u003d\u003dd_next){possible_d_prev.push(d_guess);}}} const possibleStates\u003dpossible_d_prev.map(d_p\u003d\u003e({b:b_prev,e:e_prev,d:d_p})); let message; if(possibleStates.length\u003d\u003d\u003d0){message\u003d`No consistent \u0027d\u0027 found for b\u003d${b_prev}, e\u003d${e_prev} in range [${final_ss}, ${final_se}]. (Bounds: [${d_min.toFixed(2)}, ${d_max.toFixed(2)}])`;}else if(possibleStates.length\u003d\u003d\u003d1){message\u003d\"Unique previous state found.\";}else{message\u003d`Ambiguity: ${possibleStates.length} possible \u0027d\u0027 values yield d\u0027\u003d${d_next}.`;} return{possibleStates,message}; }\n\n        // --- Visualization Function --- (MODIFIED)\n        function drawModWheel(modulus \u003d 24, highlightValue \u003d null, harmonics \u003d [], showResonances \u003d false) { // Added showResonances parameter\n            const radius \u003d Math.min(canvas.width, canvas.height) / 2 * 0.8;\n            const center \u003d { x: canvas.width / 2, y: canvas.height / 2 };\n            const pointRadius \u003d Math.min(15, Math.max(5, radius / modulus * 1.5));\n\n            ctx.clearRect(0, 0, canvas.width, canvas.height);\n            ctx.beginPath(); ctx.arc(center.x, center.y, radius, 0, 2 * Math.PI);\n            ctx.strokeStyle \u003d \"#aaa\"; ctx.lineWidth \u003d 1; ctx.stroke();\n\n            let primaryIndex \u003d -1;\n             if (highlightValue !\u003d\u003d null \u0026\u0026 !isNaN(highlightValue)) {\n                 primaryIndex \u003d Math.round(highlightValue) % modulus;\n                 if (primaryIndex \u003c 0) primaryIndex +\u003d modulus;\n             }\n\n            const positions \u003d {};\n            // Draw points and store positions\n            for (let i \u003d 0; i \u003c modulus; i++) {\n                let angle \u003d (2 * Math.PI * i / modulus) - (Math.PI / 2);\n                let x \u003d center.x + radius * Math.cos(angle); let y \u003d center.y + radius * Math.sin(angle);\n                positions[i] \u003d { x, y };\n                ctx.beginPath(); ctx.arc(x, y, pointRadius, 0, 2 * Math.PI);\n                if (i \u003d\u003d\u003d primaryIndex) { ctx.fillStyle \u003d \"orange\"; ctx.fill(); ctx.strokeStyle \u003d \"black\"; ctx.lineWidth \u003d 2; }\n                else { ctx.fillStyle \u003d i % 2 \u003d\u003d\u003d 0 ? \"lightblue\" : \"lightgreen\"; ctx.fill(); ctx.strokeStyle \u003d \"#555\"; ctx.lineWidth \u003d 1; }\n                ctx.stroke();\n                ctx.fillStyle \u003d \"black\"; ctx.font \u003d `${Math.max(9, Math.min(12, pointRadius))}px sans-serif`;\n                ctx.textAlign \u003d \"center\"; ctx.textBaseline \u003d \"middle\"; ctx.fillText(i, x, y);\n            }\n\n            // Draw Harmonic Links (Aliquot parts)\n            if (harmonics \u0026\u0026 harmonics.length \u003e\u003d 2) {\n                const harmonicIndices \u003d harmonics.map(h \u003d\u003e h % modulus).filter((v, i, s) \u003d\u003e s.indexOf(v) \u003d\u003d\u003d i).sort((a, b) \u003d\u003e a - b);\n                if (harmonicIndices.length \u003e\u003d 2) {\n                    ctx.beginPath(); ctx.strokeStyle \u003d \"rgba(255, 0, 0, 0.5)\"; ctx.lineWidth \u003d 2; // Red links\n                    const firstIdx \u003d harmonicIndices[0];\n                    if (positions[firstIdx]) {\n                        ctx.moveTo(positions[firstIdx].x, positions[firstIdx].y);\n                        for (let i \u003d 1; i \u003c harmonicIndices.length; i++) { const currIdx \u003d harmonicIndices[i]; if (positions[currIdx]) ctx.lineTo(positions[currIdx].x, positions[currIdx].y); }\n                        ctx.lineTo(positions[firstIdx].x, positions[firstIdx].y);\n                    }\n                    ctx.stroke();\n                }\n            }\n\n            // --- NEW: Draw Resonance Links ---\n            if (showResonances \u0026\u0026 primaryIndex !\u003d\u003d -1 \u0026\u0026 positions[primaryIndex]) {\n                const originPos \u003d positions[primaryIndex];\n\n                for (const [name, ratio] of Object.entries(resonanceRatios)) {\n                    const targetValue \u003d primaryIndex * ratio;\n                    let targetIndexRaw \u003d targetValue % modulus;\n                    if (targetIndexRaw \u003c 0) targetIndexRaw +\u003d modulus; // Ensure positive modulo result\n\n                    // Find closest integer index within tolerance\n                    const roundedIndex \u003d Math.round(targetIndexRaw) % modulus;\n                    if (Math.abs(targetIndexRaw - roundedIndex) \u003c\u003d RESONANCE_TOLERANCE || Math.abs(targetIndexRaw - (roundedIndex - modulus)) \u003c\u003d RESONANCE_TOLERANCE || Math.abs(targetIndexRaw - (roundedIndex + modulus)) \u003c\u003d RESONANCE_TOLERANCE) { // Check proximity\n                         const resonantIndex \u003d roundedIndex;\n\n                        if (resonantIndex !\u003d\u003d primaryIndex \u0026\u0026 positions[resonantIndex]) {\n                            const targetPos \u003d positions[resonantIndex];\n                            const color \u003d resonanceColors[name] || \"#888888\"; // Default gray\n\n                            ctx.beginPath();\n                            ctx.moveTo(originPos.x, originPos.y);\n                            ctx.lineTo(targetPos.x, targetPos.y);\n                            ctx.strokeStyle \u003d color;\n                            ctx.lineWidth \u003d 1.5;\n                            ctx.setLineDash([4, 2]); // Dashed line for resonances\n                            ctx.stroke();\n                            ctx.setLineDash([]); // Reset line dash\n\n                            // Add label (optional, can get cluttered)\n                             // const midX \u003d (originPos.x + targetPos.x) / 2;\n                             // const midY \u003d (originPos.y + targetPos.y) / 2;\n                             // ctx.fillStyle \u003d color;\n                             // ctx.font \u003d \"9px sans-serif\";\n                             // ctx.textAlign \u003d \"center\";\n                             // ctx.textBaseline \u003d \"bottom\";\n                             // ctx.fillText(name.split(\" (\")[0], midX, midY - 2); // Display short name\n                        }\n                    }\n                }\n            }\n            // --- End Resonance Links ---\n\n            // Update viz-info text\n            const stepInfo \u003d (typeof currentStep !\u003d\u003d \u0027undefined\u0027 \u0026\u0026 currentStep \u003e\u003d 0) ? `step ${currentStep}` : \u0027current\u0027;\n             let resonanceInfo \u003d showResonances ? \"Resonances shown.\" : \"\";\n             if (primaryIndex !\u003d\u003d -1) { vizInfo.textContent \u003d `Highlighting ${stepInfo} ~a mod ${modulus}\u003d${Math.round(highlightValue)} mod ${modulus}\u003d${primaryIndex}. Aliquots linked (red). ${resonanceInfo}`; }\n             else if (highlightValue \u003d\u003d\u003d null) { vizInfo.textContent \u003d `Mod-${modulus} Wheel`; }\n             else { vizInfo.textContent \u003d `Mod-${modulus} Wheel (Invalid \u0027a\u0027 for ${stepInfo})`; }\n        }\n\n        // --- Update Display Functions --- (Unchanged except drawModWheel call)\n        function updateStaticDisplays(initialState) { updateEquationViewer(initialState.b, initialState.e, initialState.d); displaySequenceList(fullSequence); }\n        function updateDynamicDisplays(stepIndex) { if (stepIndex \u003c 0 || stepIndex \u003e\u003d fullSequence.length) { /*...*/ return; } const state \u003d fullSequence[stepIndex]; const measurement \u003d measure(state); const harmonics \u003d getAliquotParts(state.a); /*... update outputs ...*/ /* MODIFIED CALL */ drawModWheel(24, state.a, harmonics, showResonancesCheckbox.checked); highlightSequenceStep(stepIndex); }\n        function displaySequenceList(sequence) { /* ... (Unchanged) ... */ sequenceListDiv.innerHTML\u003d\u0027\u0027; totalStepsDisp.textContent\u003dsequence.length-1; if(!sequence||sequence.length\u003d\u003d\u003d0){sequenceListDiv.textContent\u003d\u0027No sequence data.\u0027;return;} sequence.forEach((state,index)\u003d\u003e{const itemDiv\u003ddocument.createElement(\u0027div\u0027); itemDiv.classList.add(\u0027sequence-item\u0027); itemDiv.id\u003d`step-${index}`; itemDiv.innerHTML\u003d`\u003cstrong\u003eStep ${index}:\u003c/strong\u003e b\u003d${isNaN(state.b)?\u0027Err\u0027:state.b}, e\u003d${isNaN(state.e)?\u0027Err\u0027:state.e}, d\u003d${isNaN(state.d)?\u0027Err\u0027:state.d}, a\u003d${isNaN(state.a)?\u0027Err\u0027:state.a.toFixed(3)}`; itemDiv.addEventListener(\u0027click\u0027,()\u003d\u003e{pauseAnimation();currentStep\u003dindex;updateDynamicDisplays(currentStep);updateAnimationButtons();}); sequenceListDiv.appendChild(itemDiv);}); }\n        function highlightSequenceStep(stepIndex) { /* ... (Unchanged) ... */ const activeItems\u003dsequenceListDiv.querySelectorAll(\u0027.sequence-item.active\u0027); activeItems.forEa