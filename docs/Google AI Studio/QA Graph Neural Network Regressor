f the molecule first, then adapts it for specific tasks.\n\n---\n### File 1: `qagcn.py` (Corrected and Finalized)\n\nThis is the pure, arithmetically-constrained convolution layer, now corrected to enforce the tuple law internally without needing external context.\n\n```python\n# qagcn.py\nimport torch\nfrom torch import nn\nfrom torch_geometric.nn import MessagePassing\nfrom torch_geometric.utils import add_self_loops, degree\n\nclass QAConstraintConv(MessagePassing):\n    \"\"\"\n    A QA-aware Graph Convolutional Layer that enforces arithmetic constraints internally.\n\n    This layer takes a hidden state, which is conceptually composed of four equal parts\n    [b, e, d, a]. It learns updates for the primitive components (b and e) via\n    message passing and then deterministically reconstructs the derived components\n    (d and a) using the QA laws. This ensures the output is always arithmetically valid.\n    \"\"\"\n    def __init__(self, channels):\n        super().__init__(aggr\u003d\"add\")\n        if channels % 4 !\u003d 0:\n            raise ValueError(\"Channels must be divisible by 4 to represent [b, e, d, a].\")\n        \n        self.primitive_channels \u003d channels // 4\n        \n        # We learn a single linear transformation for the full hidden state\n        self.lin \u003d nn.Linear(channels, channels)\n\n    def forward(self, x, edge_index):\n        \"\"\"\n        Args:\n            x (torch.Tensor): Node features [num_nodes, channels].\n            edge_index (torch.LongTensor): Graph connectivity [2, num_edges].\n        \"\"\"\n        # Add self-loops and compute normalization\n        edge_index, _ \u003d add_self_loops(edge_index, num_nodes\u003dx.size(0))\n        row, col \u003d edge_index\n        deg \u003d degree(col, x.size(0), dtype\u003dx.dtype)\n        deg_inv_sqrt \u003d deg.pow(-0.5)\n        deg_inv_sqrt[deg_inv_sqrt \u003d\u003d float(\"inf\")] \u003d 0\n        norm \u003d deg_inv_sqrt[row] * deg_inv_sqrt[col]\n\n        # Project the full hidden state\n        x \u003d self.lin(x)\n\n        # Propagate messages across the full hidden state\n        x_aggr \u003d self.propagate(edge_index, x\u003dx, norm\u003dnorm)\n\n        # --- Enforce QA Constraints Post-Aggregation ---\n        # Split the aggregated result into the four conceptual components\n        b_new, e_new, _, _ \u003d torch.chunk(x_aggr, 4, dim\u003d-1)\n\n        # Reconstruct d and a based on the updated primitives\n        d_new \u003d b_new + e_new\n        a_new \u003d b_new + 2 * e_new\n\n        # Concatenate to form the final arithmetically-valid output\n        return torch.cat([b_new, e_new, d_new, a_new], dim\u003d-1)\n\n    def message(self, x_j, norm):\n        return norm.view(-1, 1) * x_j```\n\n---\n### File 2: `qa_gnn_regressor.py` (with Corrected Architecture)\n\nThis version implements the more efficient shared embedding architecture and correctly uses the new `QAConstraintConv`.\n\n```python\n# qa_gnn_regressor.py\nimport os\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom torch_geometric.loader import DataLoader\nfrom torch_geometric.data import InMemoryDataset\nfrom torch_geometric.nn import global_mean_pool\nimport numpy as np\n\n# Import the corrected, self-contained QA layer\nfrom qagcn import QAConstraintConv\n\n# -------------------------------\n# Dataset Wrapper (Unchanged)\n# -------------------------------\nclass QAQM9Dataset(InMemoryDataset):\n    def __init__(self, root, transform\u003dNone, pre_transform\u003dNone, pre_filter\u003dNone):\n        super().__init__(root, transform, pre_transform, pre_filter)\n        self.data, self.slices, self.mean, self.std \u003d torch.load(self.processed_paths[0], weights_only\u003dFalse)\n    @property\n    def raw_file_names(self): return []\n    @property\n    def processed_file_names(self): return [\u0027data_qaqm9.pt\u0027]\n    def download(self): pass\n    def process(self): pass\n\n# -------------------------------\n# Residue Embedding Module (Unchanged)\n# -------------------------------\nclass ResidueEmbedding(nn.Module):\n    def __init__(self, modulo, embed_dim):\n        super().__init__()\n        self.modulo \u003d modulo\n        self.embed \u003d nn.Embedding(modulo, embed_dim)\n    def forward(self, atom_identifiers):\n        return self.embed(torch.remainder(atom_identifiers, self.modulo).long())\n\n# -------------------------------\n# QA-GNN with Shared Embedding and Expert Layers (NEW ARCHITECTURE)\n# -------------------------------\nclass QAGNNMultiHead(nn.Module):\n    def __init__(self, num_node_features, hidden_dim, num_properties\u003d19):\n        super().__init__()\n        if hidden_dim % 4 !\u003d 0:\n            raise ValueError(\"hidden_dim must be divisible by 4.\")\n        self.num_properties \u003d num_properties\n\n        # --- Shared GNN Backbone ---\n        self.res24_embed \u003d ResidueEmbedding(24, 16)\n        self.res72_embed \u003d ResidueEmbedding(72, 16)\n        augmented_feature_dim \u003d num_node_features + 16 + 16\n        self.feature_proj \u003d nn.Linear(augmented_feature_dim, hidden_dim)\n\n        self.conv1 \u003d QAConstraintConv(hidden_dim)\n        self.conv2 \u003d QAConstraintConv(hidden_dim)\n\n        # --- Property Conditioning \u0026 Specialization ---\n        self.property_embedding \u003d nn.Embedding(num_properties, hidden_dim)\n        self.property_groups \u003d {\n            \u0027energy\u0027: [6, 7, 8, 9, 10, 11],\n            \u0027electronic\u0027: [0, 1, 2, 3, 4, 5],\n            \u0027physical\u0027: [12, 13, 14, 15, 16, 17, 18]\n        }\n        self.expert_mlps \u003d nn.ModuleDict({\n            name: nn.Sequential(nn.Linear(hidden_dim, hidden_dim), nn.ReLU())\n            for name in self.property_groups.keys()\n        })\n        self.heads \u003d nn.ModuleList([\n            nn.Sequential(nn.Linear(hidden_dim, hidden_dim // 2), nn.ReLU(), nn.Linear(hidden_dim // 2, 1))\n            for _ in range(num_properties)\n        ])\n\n    def forward(self, data):\n        x, edge_index, batch \u003d data.x, data.edge_index, data.batch\n        \n        # --- 1. Compute Shared QA-Consistent Graph Embedding (ONCE) ---\n        atomic_proxy \u003d x[:, 0]\n        res24 \u003d self.res24_embed(atomic_proxy)\n        res72 \u003d self.res72_embed(atomic_proxy)\n        augmented_x \u003d torch.cat([x.float(), res24, res72], dim\u003d-1)\n        \n        h \u003d F.relu(self.feature_proj(augmented_x))\n        h \u003d F.relu(self.conv1(h, edge_index))\n        h \u003d F.relu(self.conv2(h, edge_index))\n        \n        # This is the single, shared, QA-valid graph embedding\n        h_graph \u003d global_mean_pool(h, batch)\n\n        # --- 2. Condition, Specialize, and Predict ---\n        all_property_outputs \u003d [None] * self.num_properties\n        for group_name, indices in self.property_groups.items():\n            expert_mlp \u003d self.expert_mlps[group_name]\n            for i in indices:\n                # Get property embedding (\"Question\")\n                q_emb \u003d self.property_embedding(torch.tensor(i, device\u003dh_graph.device))\n                # Condition the shared embedding\n                h_conditioned \u003d h_graph + q_emb\n                # Route through the specialized expert MLP\n                h_specialized \u003d expert_mlp(h_conditioned)\n                # Get the final prediction\n                all_property_outputs[i] \u003d self.heads[i](h_specialized)\n        \n        return torch.cat(all_property_outputs, dim\u003d-1)\n\n# -------------------------------\n# Training, Evaluation, and Main (Unchanged)\n# -------------------------------\ndef train(model, loader, optimizer, device, dataset_mean, dataset_std):\n    model.train()\n    total_loss \u003d 0\n    for data in loader:\n        data \u003d data.to(device)\n        optimizer.zero_grad()\n        out_norm \u003d model(data)\n        target_norm \u003d (data.y - dataset_mean) / dataset_std\n        loss \u003d F.mse_loss(out_norm, target_norm)\n        loss.backward()\n        optimizer.step()\n        total_loss +\u003d loss.item() * data.num_graphs\n    return total_loss / len(loader.dataset)\n\ndef test(model, loader, dataset_mean, dataset_std, device):\n    model.eval()\n    per_property_se \u003d torch.zeros(model.num_properties, device\u003ddevice)\n    with torch.no_grad():\n        for data in loader:\n            data \u003d data.to(device)\n            pred_norm \u003d model(data)\n            pred_denorm \u003d pred_norm * dataset_std + dataset_mean\n            true_denorm \u003d data.y\n            se \u003d (pred_denorm - true_denorm).pow(2)\n            per_property_se +\u003d se.sum(dim\u003d0)\n    per_property_mse \u003d per_property_se / len(loader.dataset)\n    avg_mse \u003d per_property_mse.mean().item()\n    return avg_mse, per_property_mse.cpu().numpy()\n\ndef main():\n    print(\"Starting QA-GNN Regressor training...\")\n    device \u003d torch.device(\u0027cuda\u0027 if torch.cuda.is_available() else \u0027cpu\u0027)\n    print(f\"Using device: {device}\")\n    \n    dataset_root \u003d \u0027data/qa_qm9\u0027\n    if not os.path.exists(os.path.join(dataset_root, \u0027processed\u0027, \u0027data_qaqm9.pt\u0027)):\n        print(f\"\\nError: Dataset file not found.\")\n        return\n\n    dataset \u003d QAQM9Dataset(root\u003ddataset_root)\n    print(f\"Dataset loaded successfully. Total examples: {len(dataset)}\")\n    \n    train_size \u003d int(0.9 * len(dataset))\n    test_size \u003d len(dataset) - train_size\n    print(f\"Using {train_size}/{test_size} split.\")\n        \n    train_dataset, test_dataset \u003d torch.utils.data.random_split(dataset, [train_size, test_size])\n    train_loader \u003d DataLoader(train_dataset, batch_size\u003d64, shuffle\u003dTrue)\n    test_loader \u003d DataLoader(test_dataset, batch_size\u003d64, shuffle\u003dFalse)\n    \n    data_mean \u003d dataset.mean.to(device)\n    data_std \u003d dataset.std.to(device)\n\n    model \u003d QAGNNMultiHead(\n        num_node_features\u003d4,\n        hidden_dim\u003d128,\n        num_properties\u003d19\n    ).to(device)\n    \n    optimizer \u003d torch.optim.Adam(model.parameters(), lr\u003d1e-3)\n    \n    print(\"\\n--- Starting Training ---\")\n    for epoch in range(1, 31):\n        train_loss \u003d train(model, train_loader, optimizer, device, data_mean, data_std)\n        test_avg_mse, test_per_prop_mse \u003d test(model, test_loader, data_mean, data_std, device)\n        \n        print(f\"\\nEpoch {epoch:02d} | Train MSE (normalized): {train_loss:.6f} | Test MSE (de-normalized): {test_avg_mse:.6f}\")\n        print(\"Per-target Test MSE (de-normalized):\")\n        formatted_mse \u003d np.array2string(test_per_prop_mse, formatter\u003d{\u0027float_kind\u0027:lambda x: \"%.6f\" % x})\n        print(formatted_mse)\n        print(\"-\" * 80)\n\nif __name__ \u003d\u003d \"__main__\":\n    main()```",
