rom tensorflow.keras import layers, models, callbacks\nfrom scipy.ndimage import rotate\nfrom tqdm.notebook import tqdm\n\n# Confirm GPU is active and get core count\ntry:\n    tpu \u003d tf.distribute.cluster_resolver.TPUClusterResolver()\n    tf.config.experimental_connect_to_cluster(tpu)\n    tf.tpu.experimental.initialize_tpu_system(tpu)\n    strategy \u003d tf.distribute.TPUStrategy(tpu)\n    print(\u0027Running on TPU\u0027)\nexcept ValueError:\n    strategy \u003d tf.distribute.get_strategy()\n    print(\u0027Running on GPU\u0027 if len(tf.config.list_physical_devices(\u0027GPU\u0027)) \u003e 0 else \u0027Running on CPU\u0027)\n\nCPU_WORKERS \u003d os.cpu_count()\nprint(f\"TensorFlow Version: {tf.__version__}\")\nprint(f\"Available CPU cores: {CPU_WORKERS}\")\n\n\n# --- [QA HARMONIC \u0026 GEOMETRIC UTILITIES] ---\nprint(\"\\n--- Defining the Quantum Arithmetic Engine ---\")\nSTENCILS_24 \u003d None\ndef get_stencils():\n    global STENCILS_24\n    if STENCILS_24 is not None: return STENCILS_24\n    def _rot90(K, k): return np.rot90(K, k)\n    B0\u003dnp.array([[1,0,-1],[2,0,-2],[1,0,-1]],dtype\u003dint); B1\u003dnp.array([[1,2,1],[0,0,0],[-1,-2,-1]],dtype\u003dint); B2\u003dnp.array([[2,1,0],[1,0,-1],[0,-1,-2]],dtype\u003dint); B3\u003dnp.array([[0,1,2],[-1,0,1],[-2,-1,0]],dtype\u003dint)\n    seeds\u003d[B0,B1,B2,B3]; mixes\u003d[(1,0),(2,1),(1,1),(1,2),(1,-1),(2,-1)]; stencils\u003d[]\n    for s_idx,K in enumerate(seeds):\n        for r in range(4):\n            Kr\u003d_rot90(K,r); Kn_base\u003dseeds[(s_idx+1)%4]; Kn\u003d_rot90(Kn_base,r)\n            for(a,b)in mixes:\n                M\u003da*Kr+b*Kn; flat\u003dM.ravel(); g\u003dint(np.gcd.reduce(flat)) if np.any(flat) else 1; M\u003d(M//g) if g else M; stencils.append(M.astype(int))\n                if len(stencils)\u003d\u003d24: STENCILS_24 \u003d stencils; return STENCILS_24\n    STENCILS_24 \u003d stencils; return STENCILS_24\n\n# --- [CUSTOM KERAS COMPONENTS \u0026 MODEL ARCHITECTURE] ---\nclass StdDevLayer(layers.Layer):\n    def __init__(self, **kwargs): super(StdDevLayer, self).__init__(**kwargs)\n    def call(self, inputs): return tf.math.reduce_std(inputs, axis\u003d[1, 2])\n\nclass QAConv24(layers.Layer):\n    def __init__(self, out_ch\u003d32, use_bias\u003dFalse, name\u003d\"QAConv24\", **kwargs):\n        super().__init__(name\u003dname, **kwargs); self.out_ch\u003dout_ch; self.use_bias\u003duse_bias\n        stencils \u003d get_stencils(); K\u003dnp.stack(stencils,axis\u003d0)[:,:,:,np.newaxis]; K\u003dnp.transpose(K,(1,2,3,0))\n        self.K_fixed\u003dtf.constant(K,dtype\u003dtf.float32)\n        self.mixer\u003dself.add_weight(name\u003d\"mixer_w\",shape\u003d(1,1,24,self.out_ch),initializer\u003d\"glorot_uniform\",trainable\u003dTrue)\n        self.bias\u003dself.add_weight(name\u003d\"mixer_b\",shape\u003d(self.out_ch,),initializer\u003d\"zeros\",trainable\u003dTrue) if use_bias else None\n    def call(self,x):\n        x24\u003dtf.nn.conv2d(x,self.K_fixed,strides\u003d1,padding\u003d\"SAME\"); y\u003dtf.nn.conv2d(x24,self.mixer,strides\u003d1,padding\u003d\"SAME\")\n        return tf.nn.bias_add(y,self.bias) if self.bias is not None else y\n\ndef qa_softmax(x, mod\u003d24): return tf.nn.softmax(tf.pow(x, mod / 8.0))\n\ndef build_sovereign_cnn(num_classes\u003d10):\n    img_inp \u003d layers.Input(shape\u003d(28, 28, 1), name\u003d\"image_input\")\n    qa_multi_scale_inp \u003d layers.Input(shape\u003d(72,), name\u003d\"qa_multi_scale_input\")\n    qa_tuple_inp \u003d layers.Input(shape\u003d(4,), name\u003d\"qa_tuple_input\")\n    x \u003d QAConv24(out_ch\u003d32)(img_inp); x \u003d layers.BatchNormalization()(x); x \u003d layers.Activation(\"relu\")(x)\n    m \u003d layers.Conv2D(64, 3, padding\u003d\"same\")(x); m \u003d layers.BatchNormalization()(m); m \u003d layers.Activation(\"relu\")(m)\n    m \u003d layers.MaxPool2D(2)(m); m \u003d layers.Dropout(0.3)(m)\n    m \u003d layers.Conv2D(128, 3, padding\u003d\"same\")(m); m \u003d layers.BatchNormalization()(m); m \u003d layers.Activation(\"relu\")(m)\n    m \u003d layers.MaxPool2D(2)(m); m \u003d layers.Dropout(0.4)(m)\n    core_features \u003d layers.GlobalAveragePooling2D(name\u003d\"core_features\")(m)\n    final_concat \u003d layers.concatenate([core_features, qa_multi_scale_inp, qa_tuple_inp])\n    h_class \u003d layers.Dense(128, activation\u003d\"relu\")(final_concat)\n    h_class \u003d layers.BatchNormalization()(h_class); h_class \u003d layers.Dropout(0.5)(h_class)\n    class_output \u003d layers.Dense(num_classes, activation\u003dqa_softmax, name\u003d\"class_output\")(h_class)\n    h_qa \u003d layers.Dense(128, activation\u003d\"relu\")(core_features)\n    qa_output \u003d layers.Dense(72, name\u003d\"qa_output\")(h_qa)\n    model \u003d models.Model(inputs\u003d[img_inp, qa_multi_scale_inp, qa_tuple_inp], outputs\u003d[class_output, qa_output])\n    return model\n\n# --- [PHASE 1: GPU-ACCELERATED QA FEATURE ENGINE] ---\nprint(\"\\n--- [PHASE 1] Building GPU-Accelerated QA Feature Engine ---\")\n\ndef build_qa_feature_extractor():\n    stencils \u003d get_stencils()\n    kernels \u003d np.transpose(np.stack(stencils), (1, 2, 0))[:, :, np.newaxis, :]\n    inp \u003d layers.Input(shape\u003d(28, 28, 1))\n    conv \u003d layers.Conv2D(24, (3,3), padding\u003d\u0027same\u0027, use_bias\u003dFalse,\n                         kernel_initializer\u003dtf.constant_initializer(kernels),\n                         trainable\u003dFalse)(inp)\n    std_devs \u003d StdDevLayer()(conv)\n    model \u003d models.Model(inp, std_devs)\n    return model\n\n# This function now takes GPU-computed responses and does the fast final assembly\ndef assemble_qa_features(responses, X_uint8):\n    qa_full \u003d responses / (np.linalg.norm(responses) + 1e-6)\n    multi_scale_vector \u003d np.concatenate([qa_full, qa_full, qa_full]) # Simplified for speed\n    b \u003d responses[0]; e \u003d responses[6]\n    d \u003d b + e; a \u003d b + 2 * e\n    qa_tuple \u003d np.array([b, e, d, a], dtype\u003dnp.float32)\n    qa_tuple_norm \u003d qa_tuple / (np.linalg.norm(qa_tuple) + 1e-6)\n    return multi_scale_vector, qa_tuple_norm\n\n# Instantiate the GPU feature extractor\nQA_FEATURE_EXTRACTOR \u003d build_qa_feature_extractor()\n\n# --- [PHASE 2: HIGH-PERFORMANCE TF.DATA PIPELINE] ---\nprint(\"\\n--- [PHASE 2] Building Optimized tf.data Pipeline ---\")\n\ndef process_batch(x, y):\n    # This function will be mapped across the dataset\n    x_u8 \u003d tf.cast(x * 255.0, tf.uint8)\n    \n    # 1. Get GPU-computed responses\n    responses \u003d QA_FEATURE_EXTRACTOR(x, training\u003dFalse)\n    \n    # 2. Assemble final features (run in a tf.py_function)\n    def assemble(responses_np, x_u8_np):\n        qa_multi_list \u003d []\n        qa_tuple_list \u003d []\n        for i in range(responses_np.shape[0]):\n            multi, tupl \u003d assemble_qa_features(responses_np[i], x_u8_np[i].squeeze())\n            qa_multi_list.append(multi)\n            qa_tuple_list.append(tupl)\n        return np.array(qa_multi_list, dtype\u003dnp.float32), np.array(qa_tuple_list, dtype\u003dnp.float32)\n\n    qa_multi, qa_tuple \u003d tf.py_function(\n        assemble, [responses, x_u8], [tf.float32, tf.float32]\n    )\n    \n    # Set shapes for Keras\n    qa_multi.set_shape((x.shape[0], 72))\n    qa_tuple.set_shape((x.shape[0], 4))\n    \n    inputs \u003d {\u0027image_input\u0027: x, \u0027qa_multi_scale_input\u0027: qa_multi, \u0027qa_tuple_input\u0027: qa_tuple}\n    outputs \u003d {\u0027class_output\u0027: y, \u0027qa_output\u0027: qa_multi}\n    return inputs, outputs\n\n# Load raw data\n(x_train, y_train), (x_test, y_test) \u003d tf.keras.datasets.fashion_mnist.load_data()\nx_train \u003d x_train.astype(\u0027float32\u0027) / 255.0\nx_test \u003d x_test.astype(\u0027float32\u0027) / 255.0\nx_train \u003d x_train[..., np.newaxis]\nx_test \u003d x_test[..., np.newaxis]\n\n# Create tf.data.Dataset objects\ntrain_ds_raw \u003d tf.data.Dataset.from_tensor_slices((x_train, y_train))\ntest_ds_raw \u003d tf.data.Dataset.from_tensor_slices((x_test, y_test))\n\n# Augmentation layers\naugmentation_layers \u003d tf.keras.Sequential([\n    layers.RandomRotation(factor\u003d15/360), # 15 degrees\n    layers.RandomTranslation(height_factor\u003d0.075, width_factor\u003d0.075)\n])\n\n# Build the final pipelines\nBATCH_SIZE \u003d 128\ntrain_ds_aug \u003d train_ds_raw.map(lambda x, y: (augmentation_layers(x, training\u003dTrue), y), num_parallel_calls\u003dtf.data.AUTOTUNE)\ntrain_ds_combined \u003d train_ds_raw.concatenate(train_ds_aug)\n\nprint(\"Processing and caching datasets... (This will run on the first epoch)\")\ntrain_ds \u003d train_ds_combined.cache().shuffle(120000).batch(BATCH_SIZE).map(process_batch, num_parallel_calls\u003dtf.data.AUTOTUNE).prefetch(tf.data.AUTOTUNE)\ntest_ds \u003d test_ds_raw.cache().batch(BATCH_SIZE).map(process_batch, num_parallel_calls\u003dtf.data.AUTOTUNE).prefetch(tf.data.AUTOTUNE)\nprint(\"Data pipelines are ready.\")\n\n\n# --- [PHASE 3: TRAINING] ---\nprint(\"\\n\\n--- [PHASE 3] Starting Ensemble Training ---\")\nNUM_MODELS \u003d 3; EPOCHS \u003d 72; ENSEMBLE_TAG \u003d \"sovereign_run\"\nCLASS_NAMES \u003d [\u0027T-shirt/top\u0027, \u0027Trouser\u0027, \u0027Pullover\u0027, \u0027Dress\u0027, \u0027Coat\u0027, \u0027Sandal\u0027, \u0027Shirt\u0027, \u0027Sneaker\u0027, \u0027Bag\u0027, \u0027Ankle boot\u0027]\n\nfor model_index in range(1, NUM_MODELS + 1):\n    print(f\"\\n--- Training Model {model_index}/{NUM_MODELS} ---\")\n    \n    with strategy.scope():\n        model \u003d build_sovereign_cnn()\n        model.compile(\n            optimizer\u003dtf.keras.optimizers.Adam(learning_rate\u003d1e-3),\n            loss\u003d{\u0027class_output\u0027: \u0027sparse_categorical_crossentropy\u0027, \u0027qa_output\u0027: \u0027mse\u0027},\n            loss_weights\u003d{\u0027class_output\u0027: 1.0, \u0027qa_output\u0027: 0.2},\n            metrics\u003d{\u0027class_output\u0027: \