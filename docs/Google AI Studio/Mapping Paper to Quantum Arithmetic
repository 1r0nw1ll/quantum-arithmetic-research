turns the 24 canonical integer stencils.\"\"\"\n    global STENCILS_24\n    if STENCILS_24 is not None:\n        return STENCILS_24\n\n    def _rot90(K, k): return np.rot90(K, k)\n    B0\u003dnp.array([[1,0,-1],[2,0,-2],[1,0,-1]],dtype\u003dint); B1\u003dnp.array([[1,2,1],[0,0,0],[-1,-2,-1]],dtype\u003dint); B2\u003dnp.array([[2,1,0],[1,0,-1],[0,-1,-2]],dtype\u003dint); B3\u003dnp.array([[0,1,2],[-1,0,1],[-2,-1,0]],dtype\u003dint)\n    seeds\u003d[B0,B1,B2,B3]; mixes\u003d[(1,0),(2,1),(1,1),(1,2),(1,-1),(2,-1)]; stencils\u003d[]\n    for s_idx,K in enumerate(seeds):\n        for r in range(4):\n            Kr\u003d_rot90(K,r); Kn_base\u003dseeds[(s_idx+1)%4]; Kn\u003d_rot90(Kn_base,r)\n            for(a,b)in mixes:\n                M\u003da*Kr+b*Kn; flat\u003dM.ravel(); g\u003dint(np.gcd.reduce(flat)) if np.any(flat) else 1; M\u003d(M//g) if g else M; stencils.append(M.astype(int))\n                if len(stencils)\u003d\u003d24:\n                    STENCILS_24 \u003d stencils\n                    return STENCILS_24\n    STENCILS_24 \u003d stencils\n    return STENCILS_24\n\ndef toroidal_shift_np(X, dy, dx):\n    return np.roll(np.roll(X, dy, axis\u003d0), dx, axis\u003d1)\n\ndef conv3_toroidal_std(X_uint8, K):\n    if X_uint8.size \u003d\u003d 0 or X_uint8.ndim !\u003d 2 or X_uint8.shape[0] \u003c 3 or X_uint8.shape[1] \u003c 3:\n        return 0.0\n    X \u003d X_uint8.astype(np.int32)\n    acc \u003d np.zeros_like(X, dtype\u003dnp.int32)\n    for dy in (-1,0,1):\n        for dx in (-1,0,1):\n            acc +\u003d int(K[dy+1,dx+1]) * toroidal_shift_np(X,dy,dx)\n    return np.std(acc)\n\ndef get_qa_vector(image_patch_u8):\n    stencils \u003d get_stencils()\n    responses \u003d np.array([conv3_toroidal_std(image_patch_u8, K) for K in stencils])\n    return responses.astype(np.float32) / (np.linalg.norm(responses) + 1e-6)\n\ndef get_full_qa_features(X_uint8):\n    stencils \u003d get_stencils()\n    qa_full \u003d get_qa_vector(X_uint8)\n    qa_center \u003d get_qa_vector(X_uint8[7:21, 7:21])\n    perimeter_img \u003d X_uint8.copy()\n    perimeter_img[5:23, 5:23] \u003d 0\n    qa_perimeter \u003d get_qa_vector(perimeter_img)\n    multi_scale_vector \u003d np.concatenate([qa_full, qa_center, qa_perimeter])\n    b \u003d conv3_toroidal_std(X_uint8, stencils[0])\n    e \u003d conv3_toroidal_std(X_uint8, stencils[6])\n    d \u003d b + e; a \u003d b + 2 * e\n    qa_tuple \u003d np.array([b, e, d, a], dtype\u003dnp.float32)\n    qa_tuple_norm \u003d qa_tuple / (np.linalg.norm(qa_tuple) + 1e-6)\n    return multi_scale_vector, qa_tuple_norm\n\n# --- [CUSTOM KERAS COMPONENTS \u0026 MODEL ARCHITECTURE] ---\n\nclass StdDevLayer(layers.Layer):\n    def __init__(self, **kwargs):\n        super(StdDevLayer, self).__init__(**kwargs)\n    def call(self, inputs):\n        return tf.math.reduce_std(inputs, axis\u003d[1, 2])\n\nclass QAConv24(layers.Layer):\n    def __init__(self, out_ch\u003d32, use_bias\u003dFalse, name\u003d\"QAConv24\", **kwargs):\n        super().__init__(name\u003dname, **kwargs)\n        self.out_ch\u003dout_ch\n        self.use_bias\u003duse_bias\n        stencils \u003d get_stencils()\n        K\u003dnp.stack(stencils,axis\u003d0)[:,:,:,np.newaxis]\n        K\u003dnp.transpose(K,(1,2,3,0))\n        self.K_fixed\u003dtf.constant(K,dtype\u003dtf.float32)\n        self.mixer\u003dself.add_weight(name\u003d\"mixer_w\",shape\u003d(1,1,24,self.out_ch),initializer\u003d\"glorot_uniform\",trainable\u003dTrue)\n        self.bias\u003dself.add_weight(name\u003d\"mixer_b\",shape\u003d(self.out_ch,),initializer\u003d\"zeros\",trainable\u003dTrue) if use_bias else None\n    def call(self,x):\n        x24\u003dtf.nn.conv2d(x,self.K_fixed,strides\u003d1,padding\u003d\"SAME\")\n        y\u003dtf.nn.conv2d(x24,self.mixer,strides\u003d1,padding\u003d\"SAME\")\n        return tf.nn.bias_add(y,self.bias) if self.bias is not None else y\n\ndef qa_softmax(x, mod\u003d24):\n    return tf.nn.softmax(tf.pow(x, mod / 8.0))\n\ndef build_sovereign_cnn(num_classes\u003d10):\n    img_inp \u003d layers.Input(shape\u003d(28, 28, 1), name\u003d\"image_input\")\n    qa_multi_scale_inp \u003d layers.Input(shape\u003d(72,), name\u003d\"qa_multi_scale_input\")\n    qa_tuple_inp \u003d layers.Input(shape\u003d(4,), name\u003d\"qa_tuple_input\")\n    x \u003d QAConv24(out_ch\u003d32)(img_inp)\n    x \u003d layers.BatchNormalization()(x)\n    x \u003d layers.Activation(\"relu\")(x)\n    m \u003d layers.Conv2D(64, 3, padding\u003d\"same\")(x)\n    m \u003d layers.BatchNormalization()(m)\n    m \u003d layers.Activation(\"relu\")(m)\n    m \u003d layers.MaxPool2D(2)(m)\n    m \u003d layers.Dropout(0.3)(m)\n    m \u003d layers.Conv2D(128, 3, padding\u003d\"same\")(m)\n    m \u003d layers.BatchNormalization()(m)\n    m \u003d layers.Activation(\"relu\")(m)\n    m \u003d layers.MaxPool2D(2)(m)\n    m \u003d layers.Dropout(0.4)(m)\n    core_features \u003d layers.GlobalAveragePooling2D(name\u003d\"core_features\")(m)\n    final_concat \u003d layers.concatenate([core_features, qa_multi_scale_inp, qa_tuple_inp])\n    h_class \u003d layers.Dense(128, activation\u003d\"relu\")(final_concat)\n    h_class \u003d layers.BatchNormalization()(h_class)\n    h_class \u003d layers.Dropout(0.5)(h_class)\n    class_output \u003d layers.Dense(num_classes, activation\u003dqa_softmax, name\u003d\"class_output\")(h_class)\n    h_qa \u003d layers.Dense(128, activation\u003d\"relu\")(core_features)\n    qa_output \u003d layers.Dense(72, name\u003d\"qa_output\")(h_qa)\n    model \u003d models.Model(inputs\u003d[img_inp, qa_multi_scale_inp, qa_tuple_inp], outputs\u003d[class_output, qa_output])\n    return model\n\n# --- [MEMORY-SAFE DATA GENERATOR] ---\n\nclass PrecomputedDataGenerator(tf.keras.utils.Sequence):\n    def __init__(self, file_path, batch_size, shuffle\u003dTrue):\n        self.file_path \u003d file_path\n        self.batch_size \u003d batch_size\n        self.shuffle \u003d shuffle\n        self.data \u003d np.load(self.file_path