{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "QA_FAILURE_ALGEBRA_STRUCTURE_CLASSIFICATION_CERT.v1.schema.json",
  "title": "QA Failure Algebra Structure Classification Cert v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "cert_id",
    "created_utc",
    "family87_ref",
    "carrier",
    "forms",
    "compose_table",
    "claimed"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "QA_FAILURE_ALGEBRA_STRUCTURE_CLASSIFICATION_CERT"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "cert_id": {
      "type": "string",
      "minLength": 6
    },
    "created_utc": {
      "type": "string",
      "minLength": 10
    },
    "family87_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "cert_sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "cert_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "carrier": {
      "type": "array",
      "minItems": 2,
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "forms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "enum": [
          "serial",
          "parallel",
          "feedback"
        ]
      },
      "uniqueItems": true
    },
    "compose_table": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "form",
          "a",
          "b",
          "comp"
        ],
        "properties": {
          "form": {
            "type": "string",
            "enum": [
              "serial",
              "parallel",
              "feedback"
            ]
          },
          "a": {
            "type": "string",
            "minLength": 1
          },
          "b": {
            "type": "string",
            "minLength": 1
          },
          "comp": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "preorder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "leq"
      ],
      "properties": {
        "leq": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "a",
              "b"
            ],
            "properties": {
              "a": {
                "type": "string",
                "minLength": 1
              },
              "b": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "claimed": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "closure_holds",
        "associativity_holds",
        "per_form_claims"
      ],
      "properties": {
        "closure_holds": {
          "type": "boolean"
        },
        "associativity_holds": {
          "type": "boolean"
        },
        "per_form_claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "form",
              "identity",
              "absorber",
              "commutative",
              "monotone"
            ],
            "properties": {
              "form": {
                "type": "string",
                "enum": [
                  "serial",
                  "parallel",
                  "feedback"
                ]
              },
              "identity": {
                "type": ["string", "null"],
                "minLength": 1
              },
              "absorber": {
                "type": ["string", "null"],
                "minLength": 1
              },
              "commutative": {
                "type": "boolean"
              },
              "monotone": {
                "type": ["boolean", "null"]
              }
            }
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
