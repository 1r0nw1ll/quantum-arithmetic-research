 still proceed, but the semi-minor axis will be zero.\n        \n        # 1. Dynamically generate the tuple from the point\n        props \u003d self._calculate_properties_for_point(x, y)\n\n        if props is None:\n            return # Exit if tuple is invalid (e.g., negative sqrt)\n\n        print(\"\\n--- Analyzing Point ({:.2f}, {:.2f}) ---\".format(x, y))\n        print(\"Generated QA Tuple: (b\u003d{:.2f}, e\u003d{:.2f}, d\u003d{:.2f}, a\u003d{:.2f})\".format(\n            props[\u0027b\u0027], props[\u0027e\u0027], props[\u0027d\u0027], props[\u0027a\u0027]))\n        \n        # 2. Render the canonical geometry for this specific tuple\n        self._render_canonical_geometry(props)\n\n    def _calculate_properties_for_point(self, b, e):\n        \"\"\"Calculate all algebraic and geometric properties for the seed (b,e).\"\"\"\n        d \u003d b + e\n        a \u003d d + e\n\n        # Ensure we don\u0027t take the square root of a negative number\n        if a * b \u003c 0:\n            print(f\"Error: The product \u0027ab\u0027 ({a*b:.2f}) is negative. Cannot form a real ellipse.\")\n            return None\n            \n        return {\n            \u0027b\u0027: b, \u0027e\u0027: e, \u0027d\u0027: d, \u0027a\u0027: a,\n            \u0027semi_major_axis\u0027: d**2,\n            \u0027semi_minor_axis\u0027: d * np.sqrt(a * b),\n            \u0027focal_distance\u0027: d * e,\n            \u0027semi_latus_rectum\u0027: a * b\n        }\n\n    def _render_canonical_geometry(self, props):\n        \"\"\"Renders a complete, labeled diagram of the local QA geometry.\"\"\"\n        fig, ax \u003d plt.subplots(figsize\u003d(10, 8))\n\n        # Generate and plot the ellipse\n        theta \u003d np.linspace(0, 2 * np.pi, 400)\n        x_ellipse \u003d props[\u0027semi_major_axis\u0027] * np.cos(theta)\n        y_ellipse \u003d props[\u0027semi_minor_axis\u0027] * np.sin(theta)\n        ax.plot(x_ellipse, y_ellipse, \u0027b-\u0027, label\u003d\u0027Local QA Ellipse\u0027)\n\n        # Plot Foci and Center\n        foci_x \u003d [-props[\u0027focal_distance\u0027], props[\u0027focal_distance\u0027]]\n        ax.scatter(foci_x, [0, 0], color\u003d\u0027red\u0027, s\u003d50, zorder\u003d10, label\u003d\u0027Foci\u0027)\n        ax.scatter(0, 0, color\u003d\u0027black\u0027, s\u003d50, zorder\u003d10)\n\n        # Draw and Label Axes and Distances\n        maj_axis \u003d props[\u0027semi_major_axis\u0027]\n        foc_dist \u003d props[\u0027focal_distance\u0027]\n        \n        ax.plot([0, maj_axis], [0, 0], \u0027k--\u0027, alpha\u003d0.5, label\u003df\"Semi-Major Axis (d²) \u003d {maj_axis:.2f}\")\n        ax.plot([0, 0], [0, props[\u0027semi_minor_axis\u0027]], \u0027k--\u0027, alpha\u003d0.5, label\u003df\"Semi-Minor Axis (d*√ab) \u003d {props[\u0027semi_minor_axis\u0027]:.2f}\")\n        ax.plot([foc_dist, foc_dist], [0, props[\u0027semi_latus_rectum\u0027]], \u0027orange\u0027, linestyle\u003d\u0027--\u0027, label\u003df\"Semi-Latus Rectum (ab) \u003d {props[\u0027semi_latus_rectum\u0027]:.2f}\")\n\n        # Styling\n        ax.set_aspect(\u0027equal\u0027, adjustable\u003d\u0027box\u0027)\n        ax.grid(True, linestyle\u003d\u0027:\u0027, alpha\u003d0.6)\n        title_str \u003d (f\"Local Harmonic Field for Point (x\u003d{props[\u0027b\u0027]:.2f}, y\u003d{props[\u0027e\u0027]:.2f})\\n\"\n                     f\"Generated Tuple: (b\u003d{props[\u0027b\u0027]:.2f}, e\u003d{props[\u0027e\u0027]:.2f}, d\u003d{props[\u0027d\u0027]:.2f}, a\u003d{props[\u0027a\u0027]:.2f})\")\n        ax.set_title(title_str)\n        ax.legend()\n        plt.show()\n\n# --- Example Usage ---\n# Instantiate the engine\nlocal_field_engine \u003d QALocalFieldEngine()\n\n# Analyze a specific point in space, for example (3, 1)\nlocal_field_engine.analyze_and_render_point(x\u003d3, y\u003d1)\n\n# Analyze a different point to see its unique geometry\nlocal_field_engine.analyze_and_render_point(x\u003d2, y\u003d3)\n```",
