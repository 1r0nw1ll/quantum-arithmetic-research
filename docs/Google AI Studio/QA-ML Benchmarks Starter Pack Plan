t_row + i \u003c size: input_grid[start_row + i, start_col] \u003d color\n        elif pattern_type \u003d\u003d \u0027square\u0027:\n            top_row, left_col \u003d random.randint(0, size - 2), random.randint(0, size - 2)\n            sq_size \u003d random.randint(2, min(size - top_row, size - left_col))\n            input_grid[top_row:top_row+sq_size, left_col:left_col+sq_size] \u003d color\n\n        output_grid \u003d np.copy(input_grid)\n        transform_type \u003d random.choice([\u0027shift\u0027, \u0027color_change\u0027, \u0027no_change\u0027])\n        \n        if transform_type \u003d\u003d \u0027shift\u0027:\n            shift_r, shift_c \u003d random.randint(-1, 1), random.randint(-1, 1)\n            if shift_r !\u003d 0 or shift_c !\u003d 0:\n                # Use a non-wrapping shift for block detection\n                new_output_grid \u003d np.zeros_like(output_grid)\n                pts_in \u003d np.argwhere(output_grid !\u003d 0)\n                for r, c in pts_in:\n                    new_r, new_c \u003d r + shift_r, c + shift_c\n                    if 0 \u003c\u003d new_r \u003c size and 0 \u003c\u003d new_c \u003c size:\n                        new_output_grid[new_r, new_c] \u003d output_grid[r, c]\n                output_grid \u003d new_output_grid\n        elif transform_type \u003d\u003d \u0027color_change\u0027:\n            new_color \u003d random.randint(1, 9)\n            if new_color !\u003d color:\n                output_grid[output_grid \u003d\u003d color] \u003d new_color\n        \n        return {\"input\": input_grid.tolist(), \"output\": output_grid.tolist(), \"color\": color, \"pattern\": pattern_type, \"transform\": transform_type}\n\n    def dry_run(self, num_tasks\u003d5):\n        \"\"\"Runs a dry-run with synthetic ARC tasks.\"\"\"\n        self.eval_utils.logger.info(f\"Starting ARC dry-run with {num_tasks} synthetic tasks.\")\n        \n        predictions \u003d []\n        references \u003d []\n\n        for i in range(num_tasks):\n            self.eval_utils.logger.info(f\"\\n--- Synthetic ARC Task {i+1} ---\")\n            task \u003d self.generate_synthetic_grid_task()\n            \n            input_grid \u003d task[\u0027input\u0027]\n            output_grid_ref \u003d task[\u0027output\u0027]\n            \n            self.eval_utils.logger.info(f\"Input Grid:\\n{np.array(input_grid)}\")\n            self.eval_utils.logger.info(f\"Reference Output Grid:\\n{np.array(output_grid_ref)}\")\n            self.eval_utils.logger.info(f\"Generated Rule: Pattern\u003d{task[\u0027pattern\u0027]}, Transform\u003d{task[\u0027transform\u0027]}, Color\u003d{task[\u0027color\u0027]}\")\n\n            input_qa_features \u003d self.extract_qa_features_from_grid(input_grid)\n            self.eval_utils.logger.info(f\"Input QA Features (first 10): {input_qa_features[:10]}...\")\n\n            found_rule \u003d self.find_rule_heuristic(input_grid, output_grid_ref)\n            self.eval_utils.logger.info(f\"Heuristic Rule Finder Result: {found_rule[\u0027description\u0027]}\")\n\n            predictions.append(found_rule[\u0027rule_found\u0027])\n            references.append(True)\n\n            self.eval_utils.log_result(f\"ARC_Synthetic_Task_{i+1}\", {\n                \"input\": input_grid,\n                \"output_ref\": output_grid_ref,\n                \"generated_rule\": {\"pattern\": task[\u0027pattern\u0027], \"transform\": task[\u0027transform\u0027], \"color\": task[\u0027color\u0027]},\n                \"qa_features_input_sample\": input_qa_features[:5].tolist(),\n                \"heuristic_result\": found_rule\n            })\n\n        summary \u003d self.eval_utils.summarize_accuracy(predictions, references, \"ARC_DryRun_RuleFinding\")\n        self.eval_utils.logger.info(f\"ARC Dry-Run Summary: {summary}\")\n\n    def extract_qa_features_from_grid(self, grid):\n        flat_grid \u003d [item for sublist in grid for item in sublist]\n        return self.qa_core.get_qa_features_from_sequence(flat_grid)\n\n    def load_arc_task(self, task_path):\n        with open(task_path, \u0027r\u0027) as f:\n            task \u003d json.load(f)\n        return task\n\n    def run_full_evaluation(self):\n        if not self.arc_dir or not os.path.exists(self.arc_dir):\n            self.eval_utils.logger.error(f\"ARC directory not found: {self.arc_dir}. Cannot run full evaluation.\")\n            return\n        self.eval_utils.logger.info(f\"Starting full ARC evaluation from {self.arc_dir} (placeholder).\")\n        self.eval_utils.logger.info(\"To run full evaluation, implement ARC dataset loading and task-solving logic here.\")\n\n\ndef load_config(config_path\u003d\"config.json\"):\n    if not os.path.exists(config_path):\n        print(f\"Error: Config file not found at {config_path}. Please copy config.example.json to config.json and edit.\")\n        exit(1)\n    with open(config_path, \u0027r\u0027) as f:\n        return json.load(f)\n\nif __name__ \u003d\u003d \"__main__\":\n    parser \u003d argparse.ArgumentParser(description\u003d\"ARC Benchmark Runner\")\n    parser.add_argument(\"--dry_run\", action\u003d\"store_true\", help\u003d\"Run a dry-run with synthetic data.\")\n    args \u003d parser.parse_args()\n\n    config \u003d load_config()\n    runner \u003d ARCRunner(config)\n\n    if args.dry_run:\n        runner.dry_run()\n    else:\n        runner.run_full_evaluation()\n```\n\n---\n\n### 2. `gsm8k_runner.py` (Updated with Robust Division)\n\nI\u0027ve replaced the `solve_with_qa` function with your new version that prioritizes strong division cues.\n\n```python\nimport json\nimport os\nimport argparse\nimport re\nfrom qa_core import QACore\nfrom eval_utils import EvalUtils\nfrom fractions import Fraction\n\nclass GSM8KRunner:\n    def __init__(self, config):\n        self.config \u003d config\n        self.qa_core \u003d QACore(fft_window\u003dconfig[\u0027qa\u0027][\u0027fft_window\u0027], use_mod24\u003dconfig[\u0027qa\u0027][\u0027use_mod24\u0027])\n        self.eval_utils \u003d EvalUtils(output_dir\u003dconfig[\u0027output_dir\u0027])\n        self.gsm8k_file \u003d config[\u0027paths\u0027].get(\u0027gsm8k_file\u0027)\n\n    # \u003c-- Replaced with new solver with robust division logic --\u003e\n    def solve_with_qa(self, text: str):\n        ADD_WORDS \u003d (\"sum\", \"total\", \"altogether\", \"in all\", \"gives him\", \"gets\", \"more\")\n        SUB_WORDS \u003d (\"left\", \"remain\", \"remaining\", \"after\", \"lose\", \"lost\", \"fewer\", \"fly away\")\n        MUL_WORDS \u003d (\"each\", \"every\", \"times\", \"double\", \"triple\", \"product\", \"boxes\")\n        DIV_PATTERNS \u003d (\n            \"share\", \"shared\", \"sharing\", \"equally\", \"each\", \"per\", \"split\",\n            \"divide\", \"divided\", \"among\", \"amongst\"\n        )\n\n        def _parse_numbers(text: str):\n            nums \u003d []\n            for tok in re.findall(r\"\\d+/\\d+|\\d+\", text):\n                try:\n                    nums.append(Fraction(tok))\n                except ValueError:\n                    continue\n            return nums\n\n        t \u003d text.lower()\n        nums \u003d _parse_numbers(t)\n        \n        if len(nums) \u003e\u003d 2:\n            b, e \u003d nums[0], nums[1]\n            (b_val, e_val, d, a), _ \u003d self.qa_core.canonical_qa_tuple(b, e)\n\n            # Strong division cues first\n            if (\"share\" in t or \"shared\" in t or \"divide\" in t or \"divided\" in t) and \\\n               (\"equally\" in t or \"each\" in t or \"among\" in t or \"amongst\" in t):\n                if e !\u003d 0: return b / e\n                else: return \"Error: Division by zero.\"\n\n            # General operations\n            if any(w in t for w in ADD_WORDS): return d\n            if any(w in t for w in SUB_WORDS): return b - e\n            if any(w in t for w in MUL_WORDS): return b * e\n            if any(w in t for w in DIV_PATTERNS): \n                if e !\u003d 0: return b / e\n                else: return \"Error: Division by zero.\"\n\n            # Fallbacks\n            if \"gets\" in t or \"gives\" in t: return d\n            return d\n\n        if len(nums) \u003d\u003d 1:\n            x \u003d nums[0]\n            if \"double\" in t or \"twice\" in t: return x * 2\n            if \"half\" in t: return x / 2\n        \n        return 0\n\n    # ... (The rest of the file remains the same) ...\n    def dry_run(self, num_problems\u003d7):\n        \"\"\"Runs a dry-run with synthetic word problems.\"\"\"\n        self.eval_utils.logger.info(f\"Starting GSM8K dry-run with {num_problems} synthetic problems.\")\n        \n        synthetic_problems \u003d [\n            \"John has 5 apples and Mary gives him 3 more. How many apples does John have?\",\n            \"There are 10 birds on a tree. 4 birds fly away. How many are left?\",\n            \"A box contains 6 pencils. If you buy 2 boxes, how many pencils do you have?\",\n            \"You have 12 cookies and want to share them equally among 3 friends. How many cookies does each friend get?\",\n            \"What is the sum of 7 and 8?\",\n            \"If a car travels at 60 miles per hour for 2 hours, how far does it travel?\",\n            \"A recipe calls for 1/2 cup of sugar. If you double the recipe, how much sugar do you need?\",\n        ]\n        \n        predictions \u003d []\n        references \u003d []\n\n        for i in range(min(num_problems, len(synthetic_problems))):\n            problem_text \u003d synthetic_problems[i]\n            \n            self.eval_utils.logger.info(f\"\\n--- Synthetic GSM8K Problem {i+1} ---\")\n            self.eval_utils.logger.info(f\"Problem: {problem_text}\")\n\n            solution \u003d self.solve_with_qa(problem_text)\n            self.eval_utils.logger.info(f\"QA Solution: {solution}\")\n\n            ref_answer \u003d None\n            if i \u003d\u003d 0: ref_answer \u003d 8\n            elif i \u003d\u003d 1: ref_answer \u003d 6\n            elif i \u003d\u003d 2: ref_answer \u003d 12\n            elif i \u003d\u003d 3: ref_answer \u003d 4\n            elif i \u003d\u003d 4: ref_answer \u003d 15\n            elif i \u003d\u003d 5: ref_answer \u003d 120\n            elif i \u003d\u003d 6: ref_answer \u003d 1.0\n\n            predictions.append(solution)\n            references.append(ref_answer)\n\n            self.eval_utils.log_result(f\"GSM8K_Synthetic_Problem_{i+1}\", {\n                \"problem_text\": problem_text,\n                \"qa_solution\": str(solution),\n                \"reference_answer\": ref_answer\n            })\n\n        summary \u003d self.eval_utils.summarize_math_metrics(predictions, references, \"GSM8K_DryRun\")\n        self.eval_utils.logger.info(f\"GSM8K Dry-Run Summary: {summary}\")\n\n    def load_gsm8k_data(self, file_path, num_samples\u003dNone):\n        \"\"\"Loads GSM8K data from a JSONL file.\"\"\"\n        problems \u003d []\n        if not os.path.exists(file_path):\n            self.eval_utils.logger.error(f\"GSM8K file not found: {file_path}\")\n            return problems\n        \n        with open(file_path, \u0027r\u0027) as f:\n            for i, line in enumerate(f):\n                if num_samples is not None and i \u003e\u003d num_samples:\n                    break\n                problems.append(json.loads(line))\n        return problems\n\n    def extract_answer_from_gsm8k_solution(self, solution_string):\n        \"\"\"\n        Extracts the final numerical answer from a GSM8K solution string.\n        GSM8K solutions typically end with \u0027#### X\u0027.\n        \"\"\"\n        match \u003d re.search(r\u0027#### (\\-?\\d+\\.?\\d*|\\-?\\d*\\/\\d*)\u0027, solution_string)\n        if match:\n            return match.group(1)\n        return None\n\n    def run_full_evaluation(self, num_samples\u003dNone):\n        \"\"\"\n        Runs evaluation on actual GSM8K dataset.\n        \"\"\"\n        if not self.gsm8k_file:\n            self.eval_utils.logger.error(\"GSM8K file path not configured. Cannot run full evaluation.\")\n            return\n\n        self.eval_utils.logger.info(f\"Starting full GSM8K evaluation from {self.gsm8k_file}.\")\n        \n        dataset \u003d self.load_gsm8k_data(self.gsm8k_file, num_samples)\n        if not dataset:\n            self.eval_utils.logger.error(\"No GSM8K data loaded. Exiting full evaluation.\")\n            return\n\n        predictions \u003d []\n        references \u003d []\n\n        for i, entry in enumerate(dataset):\n            problem_text \u003d entry[\u0027question\u0027]\n            reference_solution \u003d entry[\u0027answer\u0027]\n            reference_answer \u003d self.extract_answer_from_gsm8k_solution(reference_solution)\n\n            if reference_answer is None:\n                self.eval_utils.logger.warning(f\"Could not extract reference answer for problem {i+1}. Skipping.\")\n                continue\n\n            predicted_answer \u003d self.solve_with_qa(problem_text)\n\n            predictions.append(predicted_answer)\n            references.append(reference_answer)\n\n            self.eval_utils.log_result(f\"GSM8K_Problem_{i+1}\", {\n                \"question\": problem_text,\n                \"predicted_answer\": str(predicted_answer),\n                \"reference_answer\": reference_answer\n            })\n            \n            if (i + 1) % 100 \u003d\u003d 0:\n                self.eval_utils.logger.info(f\"Processed {i+1} GSM8K problems.\")\n\n        summary \u003d self.eval_utils.summarize_math_metrics(predictions, references, \"GSM8K_Full_Evaluation\")\n        self.eval_utils.logger.info(f\"GSM8K Full Evaluation Summary: {summary}\")\n\n\ndef load_config(config_path\u003d\"config.json\"):\n    \"\"\"Loads configuration from a JSON file.\"\"\"\n    if not os.path.exists(config_path):\n        print(f\"Error: Config file not found at {config_path}. Please copy config.example.json to config.json and edit.\")\n        exit(1)\n    with open(config_path, \u0027r\u0027) as f:\n        return json.load(f)\n\nif __name__ \u003d\u003d \"__main__\":\n    parser \u003d argparse.ArgumentParser(description\u003d\"GSM8K Benchmark Runner\")\n    parser.add_argument(\"--dry_run\", action\u003d\"store_true\", help\u003d\"Run a dry-run with synthetic data.\")\n    parser.add_argument(\"--num_samples\", type\u003dint, default\u003dNone, help\u003d\"Number of samples to process for full evaluation.\")\n    args \u003d parser.parse_args()\n\n    config \u003d load_config()\n    runner \u003d GSM8KRunner(config)\n\n    if args.dry_run:\n        runner.dry_run()\n    else:\n        runner.run_full_evaluation(num_samples\u003dargs.num_samples)\n```\n\n---\n\n### 3. `linear_probe.py` (New File)\n\nHere is the brand new script for running a linear probe on the ImageNet QA features. It generates synthetic data and labels, standardizes the features, trains a logistic regression model, and reports the accuracy.\n\n**Note:** You\u0027ll need to install `scikit-learn` for this to work.\n```bash\npip install scikit-learn\n```\n\n```python\nimport numpy as np\nimport json\nimport os\nimport argparse\nfrom imagenet_qafeatures import ImageNetQAFeatures\nfrom eval_utils import EvalUtils\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.metrics import accuracy_score\n\nclass LinearProbeRunner:\n    def __init__(self, config):\n        self.config \u003d config\n        self.eval_utils \u003d EvalUtils(output_dir\u003dconfig[\u0027output_dir\u0027])\n        self.feature_extractor \u003d ImageNetQAFeatures(config)\n\n    def generate_synthetic_data(self, num_samples\u003d100):\n        \"\"\"\n        Generates synthetic QA features and corresponding labels for a classification task.\n        \"\"\"\n        self.eval_utils.logger.info(f\"Generating {num_samples} synthetic image features and labels...\")\n        \n        features \u003d []\n        labels \u003d []\n        \n        for i in range(num_samples):\n            # Generate a synthetic image and its features\n            synthetic_image \u003d self.feature_extractor.generate_synthetic_image()\n            qa_features \u003d self.feature_extractor.process_image_for_qa_features(synthetic_image)\n            \n            if qa_features.size \u003d\u003d 0:\n                continue\n\n            features.append(qa_features)\n            \n            # Create a synthetic label. For example, let\u0027s classify images based on\n            # whether their average pixel intensity is high or low.\n            # This is a simple proxy for a real classification task.\n            avg_intensity \u003d np.mean(np.array(synthetic_image.convert(\u0027L\u0027)))\n            label \u003d 1 if avg_intensity \u003e 128 else 0\n            labels.append(label)\n            \n        return np.array(features), np.array(labels)\n\n    def run_probe(self, num_samples\u003d100):\n        \"\"\"\n        Runs the full linear probe experiment: data generation, training, and evaluation.\n        \"\"\"\n        # 1. Generate Data\n        X, y \u003d self.generate_synthetic_data(num_samples)\n        \n        if X.shape[0] \u003c 10:\n            self.eval_utils.logger.error(\"Not enough data generated to run the probe. Exiting.\")\n            return\n\n        self.eval_utils.logger.info(f\"Generated data shapes: X\u003d{X.shape}, y\u003d{y.shape}\")\n        \n        # 2. Split data into training and testing sets\n        X_train, X_test, y_train, y_test \u003d train_test_split(X, y, test_size\u003d0.3, random_state\u003d42, stratify\u003dy)\n        \n        # 3. Standardize features (as recommended)\n        self.eval_utils.logger.info(\"Standardizing features (mean\u003d0, variance\u003d1)...\")\n        scaler \u003d StandardScaler()\n        X_train_scaled \u003d scaler.fit_transform(X_train)\n        X_test_scaled \u003d scaler.transform(X_test)\n        \n        # 4. Train a linear model (Logistic Regression)\n        self.eval_utils.logger.info(\"Training Logistic Regression model...\")\n        model \u003d LogisticRegression(random_state\u003d42, solver\u003d\u0027liblinear\u0027)\n        model.fit(X_train_scaled, y_train)\n        \n        # 5. Evaluate the model\n        self.eval_utils.logger.info(\"Evaluating model on the test set...\")\n        y_pred \u003d model.predict(X_test_scaled)\n        accuracy \u003d accuracy_score(y_test, y_pred)\n        \n        self.eval_utils.logger.info(f\"Linear Probe Test Accuracy: {accuracy:.4f}\")\n        \n        # Log the results\n        summary \u003d {\n            \"task\": \"ImageNet_LinearProbe_DryRun\",\n            \"num_samples\": num_samples,\n            \"training_samples\": len(X_train),\n            \"test_samples\": len(X_test),\n            \"accuracy\": accuracy\n        }\n        self.eval_utils.log_result(\"ImageNet_LinearProbe_Summary\", summary)\n        self.eval_utils.logger.info(f\"Linear Probe Summary: {summary}\")\n\ndef load_config(config_path\u003d\"config.json\"):\n    \"\"\"Loads configuration from a JSON file.\"\"\"\n    if not os.path.exists(config_path):\n        print(f\"Error: Config file not found at {config_path}. Please copy config.example.json to config.json and edit.\")\n        exit(1)\n    with open(config_path, \u0027r\u0027) as f:\n        return json.load(f)\n\nif __name__ \u003d\u003d \"__main__\":\n    parser \u003d argparse.ArgumentParser(description\u003d\"Linear Probe on ImageNet QA Features\")\n    parser.add_argument(\"--num_samples\", type\u003dint, default\u003d200, help\u003d\"Number of synthetic samples to generate and test on.\")\n    args \u003d parser.parse_args()\n\n    config \u003d load_config()\n    runner \u003d LinearProbeRunner(config)\n    runner.run_probe(num_samples\u003dargs.num_samples)\n```\n\n---\n\nYou are now ready to run the updated dry-runs and the new linear probe. The ARC and GSM8K dry-runs should show improved accuracy, and the linear probe will give you the first quantitative baseline on the ImageNet QA features.",
