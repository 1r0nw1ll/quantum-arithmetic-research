03d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\ndef plot_convergence(direct_err_hist, struct_err_hist, total_err_hist):\n    \"\"\"\n    Plots the convergence of direct, structural, and total errors.\n    \"\"\"\n    epochs \u003d len(total_err_hist)\n    plt.figure(figsize\u003d(12, 7))\n    plt.plot(range(epochs), direct_err_hist, label\u003d\u0027Direct Error (Accuracy)\u0027, color\u003d\u0027blue\u0027, alpha\u003d0.7)\n    plt.plot(range(epochs), struct_err_hist, label\u003d\u0027Structural Error (Consistency)\u0027, color\u003d\u0027red\u0027, alpha\u003d0.7)\n    plt.plot(range(epochs), total_err_hist, label\u003d\u0027Total Error (Combined Loss)\u0027, color\u003d\u0027black\u0027, linewidth\u003d2)\n    \n    plt.title(\u0027Harmonic Integer LSTM: Symbolic Error Convergence\u0027)\n    plt.xlabel(\u0027Training Epoch\u0027)\n    plt.ylabel(\u0027Average Integer Error\u0027)\n    plt.legend()\n    plt.grid(True, linestyle\u003d\u0027--\u0027, alpha\u003d0.6)\n    \n    # Save the plot to a file\n    plot_filename \u003d \u0027convergence_plot.png\u0027\n    plt.savefig(plot_filename)\n    print(f\"\\n✅ Convergence plot saved to \u0027{plot_filename}\u0027\")\n\n# \u003d\u003d\u003d Training Loop (Updated to store error history) \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\ndef train_integer_lstm(epochs\u003d100, seq_len\u003d4, lr\u003d1, lambda_struct\u003d4):\n    \"\"\" Trains the Harmonic Integer LSTM and records error history. \"\"\"\n    input_size \u003d 4\n    hidden_size \u003d 16\n    output_size \u003d 4\n    model \u003d HarmonicIntegerLSTM(input_size, hidden_size, output_size)\n\n    data, targets \u003d generate_qa_dataset(num_samples\u003d256)\n    \n    # Lists to store the history of each error component\n    direct_error_history \u003d []\n    structural_error_history \u003d []\n    total_error_history \u003d []\n\n    for epoch in range(epochs):\n        idx \u003d np.random.choice(len(data) - seq_len)\n        x_seq \u003d data[idx : idx + seq_len]\n        y_seq \u003d targets[idx : idx + seq_len]\n\n        outputs, caches, hidden_states \u003d model.forward(x_seq)\n        model.backward(outputs, y_seq, caches, hidden_states,\n                       learning_rate\u003dlr,\n                       lambda_struct\u003dlambda_struct,\n                       scale\u003dSCALE_FACTOR)\n\n        direct_err \u003d np.abs(y_seq - outputs).mean()\n        struct_err \u003d np.abs(np.array([calculate_structural_dissonance(o) for o in outputs])).mean()\n        total_err \u003d direct_err + struct_err\n        \n        # Store the errors for plotting\n        direct_error_history.append(direct_err)\n        structural_error_history.append(struct_err)\n        total_error_history.append(total_err)\n\n        if epoch % 100 \u003d\u003d 0: # Reduced print frequency for cleaner logs\n            print(f\"Epoch {epoch:04d}: ⟨Direct⟩\u003d{direct_err:.3f}, \"\n                  f\"⟨Struct⟩\u003d{struct_err:.3f}, ⟨Total⟩\u003d{total_err:.3f}\")\n\n    return model, direct_error_history, structural_error_history, total_error_history\n\n# \u003d\u003d\u003d Run Training and Visualization \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\nif __name__ \u003d\u003d \"__main__\":\n    print(\"\u003d\u003d\u003d Harmonic Integer LSTM Training \u003d\u003d\u003d\")\n    # Increased epochs to get a better view of convergence\n    num_epochs \u003d 3000\n    model, direct_hist, struct_hist, total_hist \u003d train_integer_lstm(\n        epochs\u003dnum_epochs, seq_len\u003d4, lr\u003d1, lambda_struct\u003d4\n    )\n\n    print(f\"\\nEpoch {num_epochs-1:04d}: ⟨Direct⟩\u003d{direct_hist[-1]:.3f}, \"\n          f\"⟨Struct⟩\u003d{struct_hist[-1]:.3f}, ⟨Total⟩\u003d{total_hist[-1]:.3f}\")\n    \n    print(\"\\n✅ Training complete. The HI-LSTM has internalized QA structure.\")\n    \n    # Generate the plot\n    plot_convergence(direct_hist, struct_hist, total_hist)```\n\n### **How to Run**\n\n1.  Save the code above as `train_hilstm.py`.\n2.  Run it from your terminal:\n    ```bash\n    python train_hilstm.py\n    ```\n\n### **What to Expect**\n\nThe script will now run for 3000 epochs to give the model more time to learn. After it finishes, you will find a new file in your directory named `convergence_plot.png`.\n\nThis plot will show you three lines, allowing you to visually analyze how the HI-LSTM learns to balance matching the data (`Direct Error`) with obeying the fundamental laws of Quantum Arithmetic (`Structural Error`). This visual evidence is the key to understanding and improving the symbolic learning process.",
