e is the complete, corrected script. The only changes are in the `main` function, where we now combine the original and augmented data before training.\n\n```python\n# qa_canonical_system.py\n# The final, canonical QA-conformant system for achieving SOTA performance.\n# Implements: Canonical Tuple Injection, Modular Time, Dual-Space TTA, and QA Confusion Profiling.\n\nimport argparse, csv, math, os, glob\nimport numpy as np\nimport tensorflow as tf\nfrom tensorflow.keras import layers, models, callbacks\nimport matplotlib.pyplot as plt\nimport networkx as nx\nfrom collections import Counter\n\n# --- [QA utility functions] ---\ndef toroidal_shift_np(X, dy, dx): return np.roll(np.roll(X, dy, axis\u003d0), dx, axis\u003d1)\ndef _rot90(K, k): R \u003d K.copy(); [R :\u003d np.rot90(R) for _ in range(k % 4)]; return R\ndef rank24_integer_stencils():\n    B0\u003dnp.array([[1,0,-1],[2,0,-2],[1,0,-1]],dtype\u003dint); B1\u003dnp.array([[1,2,1],[0,0,0],[-1,-2,-1]],dtype\u003dint); B2\u003dnp.array([[2,1,0],[1,0,-1],[0,-1,-2]],dtype\u003dint); B3\u003dnp.array([[0,1,2],[-1,0,1],[-2,-1,0]],dtype\u003dint)\n    seeds\u003d[B0,B1,B2,B3]; mixes\u003d[(1,0),(2,1),(1,1),(1,2),(1,-1),(2,-1)]; stencils\u003d[]\n    for s_idx,K in enumerate(seeds):\n        for r in range(4):\n            Kr\u003d_rot90(K,r); Kn_base\u003dseeds[(s_idx+1)%4]; Kn\u003d_rot90(Kn_base,r)\n            for(a,b)in mixes:\n                M\u003da*Kr+b*Kn; flat\u003dM.ravel(); g\u003dint(np.gcd.reduce(flat))if np.any(flat)else 1; M\u003d(M//g)if g else M; stencils.append(M.astype(int))\n                if len(stencils)\u003d\u003d24: return stencils\n    return stencils\nSTENCILS_24 \u003d rank24_integer_stencils()\ndef conv3_toroidal_std(X_uint8, K):\n    X \u003d X_uint8.astype(np.int32); acc \u003d np.zeros_like(X, dtype\u003dnp.int32)\n    for dy in (-1,0,1):\n        for dx in (-1,0,1): acc +\u003d int(K[dy+1,dx+1]) * toroidal_shift_np(X,dy,dx)\n    return np.std(acc)\n\ndef get_qa_features(X_uint8):\n    responses \u003d np.array([conv3_toroidal_std(X_uint8, K) for K in STENCILS_24])\n    qa_vector \u003d responses.astype(np.float32)\n    qa_vector_norm \u003d qa_vector / (np.linalg.norm(qa_vector) + 1e-6)\n    b \u003d responses[0]; e \u003d responses[6]; d \u003d b + e; a \u003d b + 2 * e\n    qa_tuple \u003d np.array([b, e, d, a], dtype\u003dnp.float32)\n    qa_tuple_norm \u003d qa_tuple / (np.linalg.norm(qa_tuple) + 1e-6)\n    return qa_vector_norm, qa_tuple_norm\n\n# --- [QAConv24 Layer Definition] ---\nclass QAConv24(layers.Layer):\n    def __init__(self, out_ch\u003d32, use_bias\u003dFalse, name\u003d\"QAConv24\", **kwargs):\n        super().__init__(name\u003dname, **kwargs)\n        self.out_ch \u003d out_ch; self.use_bias \u003d use_bias\n        K \u003d np.stack(STENCILS_24, axis\u003d0)[:, :, :, np.newaxis]; K \u003d np.transpose(K, (1, 2, 3, 0))\n        self.K_fixed \u003d tf.constant(K, dtype\u003dtf.float32)\n        self.mixer \u003d self.add_weight(name\u003d\"mixer_w\", shape\u003d(1, 1, 24, self.out_ch), initializer\u003d\"glorot_uniform\", trainable\u003dTrue)\n        self.bias \u003d self.add_weight(name\u003d\"mixer_b\", shape\u003d(self.out_ch,), initializer\u003d\"zeros\", trainable\u003dTrue) if use_bias else None\n    def call(self, x):\n        x24 \u003d tf.nn.conv2d(x, self.K_fixed, strides\u003d1, padding\u003d\"SAME\")\n        y \u003d tf.nn.conv2d(x24, self.mixer, strides\u003d1, padding\u003d\"SAME\")\n        return tf.nn.bias_add(y, self.bias) if self.bias is not None else y\n\n# --- Model with Dual QA Feature Injection ---\ndef build_canonical_sota_cnn(num_classes\u003d10):\n    img_inp \u003d layers.Input(shape\u003d(28, 28, 1), name\u003d\"image_input\")\n    qa_vec_inp \u003d layers.Input(shape\u003d(24,), name\u003d\"qa_vector_input\")\n    qa_tuple_inp \u003d layers.Input(shape\u003d(4,), name\u003d\"qa_tuple_input\")\n    x \u003d QAConv24(out_ch\u003d32)(img_inp); x \u003d layers.BatchNormalization()(x); x \u003d laye