{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "QA_HOPFIELD_REACHABILITY_RUN_CERT.v1.schema.json",
  "title": "QA Hopfield Reachability Run Certificate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "N",
    "objective",
    "generator_set",
    "run"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "QA_HOPFIELD_REACHABILITY_RUN_CERT"
    },
    "schema_version": {
      "type": "string",
      "enum": [
        "QA_HOPFIELD_REACHABILITY_RUN_CERT.v1"
      ]
    },
    "N": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "memories"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "HAMMING_TO_NEAREST_MEMORY"
          ]
        },
        "memories": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 10,
            "items": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          }
        }
      }
    },
    "generator_set": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "i"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "flip",
              "flip_if_one"
            ]
          },
          "i": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          }
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "start_state",
        "steps"
      ],
      "properties": {
        "policy": {
          "type": "string",
          "enum": [
            "GREEDY_MIN_ENERGY_TIEBREAK_MOVE_KEY"
          ]
        },
        "start_state": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "integer",
            "enum": [
              0,
              1
            ]
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 200,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "t",
              "state_before",
              "energy_before",
              "attempted_moves",
              "chosen_move",
              "state_after",
              "energy_after"
            ],
            "properties": {
              "t": {
                "type": "integer",
                "minimum": 0
              },
              "state_before": {
                "type": "array",
                "minItems": 1,
                "maxItems": 10,
                "items": {
                  "type": "integer",
                  "enum": [
                    0,
                    1
                  ]
                }
              },
              "energy_before": {
                "type": "integer",
                "minimum": 0
              },
              "attempted_moves": {
                "type": "array",
                "minItems": 1,
                "maxItems": 200,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "move",
                    "result"
                  ],
                  "properties": {
                    "move": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "name",
                        "i"
                      ],
                      "properties": {
                        "name": {
                          "type": "string",
                          "enum": [
                            "flip",
                            "flip_if_one"
                          ]
                        },
                        "i": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9
                        }
                      }
                    },
                    "result": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "ok"
                      ],
                      "properties": {
                        "ok": {
                          "type": "boolean"
                        },
                        "value": {
                          "type": "array",
                          "minItems": 1,
                          "maxItems": 10,
                          "items": {
                            "type": "integer",
                            "enum": [
                              0,
                              1
                            ]
                          }
                        },
                        "fail_type": {
                          "type": "string",
                          "enum": [
                            "MOVE_PRECONDITION_FAILED",
                            "DOMAIN_INVALID"
                          ]
                        },
                        "invariant_diff": {
                          "type": "object"
                        },
                        "details": {
                          "type": "object"
                        }
                      },
                      "allOf": [
                        {
                          "if": {
                            "properties": {
                              "ok": {
                                "const": true
                              }
                            },
                            "required": [
                              "ok"
                            ]
                          },
                          "then": {
                            "required": [
                              "value"
                            ],
                            "not": {
                              "required": [
                                "fail_type"
                              ]
                            }
                          },
                          "else": {
                            "required": [
                              "fail_type",
                              "invariant_diff",
                              "details"
                            ],
                            "not": {
                              "required": [
                                "value"
                              ]
                            }
                          }
                        }
                      ]
                    }
                  }
                }
              },
              "chosen_move": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "name",
                  "i"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "enum": [
                      "flip",
                      "flip_if_one"
                    ]
                  },
                  "i": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9
                  }
                }
              },
              "state_after": {
                "type": "array",
                "minItems": 1,
                "maxItems": 10,
                "items": {
                  "type": "integer",
                  "enum": [
                    0,
                    1
                  ]
                }
              },
              "energy_after": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "return_in_k_probes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 200,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "probe_id",
              "k",
              "goal_state",
              "expected"
            ],
            "properties": {
              "probe_id": {
                "type": "string",
                "minLength": 1
              },
              "k": {
                "type": "integer",
                "minimum": 0,
                "maximum": 50
              },
              "start_state": {
                "type": "array",
                "minItems": 1,
                "maxItems": 10,
                "items": {
                  "type": "integer",
                  "enum": [
                    0,
                    1
                  ]
                }
              },
              "start_from_step_t": {
                "type": "integer",
                "minimum": 0
              },
              "goal_state": {
                "type": "array",
                "minItems": 1,
                "maxItems": 10,
                "items": {
                  "type": "integer",
                  "enum": [
                    0,
                    1
                  ]
                }
              },
              "expected": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "reachable"
                ],
                "properties": {
                  "reachable": {
                    "type": "boolean"
                  },
                  "min_steps": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 50
                  }
                }
              }
            },
            "allOf": [
              {
                "oneOf": [
                  {
                    "required": [
                      "start_state"
                    ],
                    "not": {
                      "required": [
                        "start_from_step_t"
                      ]
                    }
                  },
                  {
                    "required": [
                      "start_from_step_t"
                    ],
                    "not": {
                      "required": [
                        "start_state"
                      ]
                    }
                  }
                ]
              }
            ]
          }
        }
      }
    }
  }
}

