{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "primary_source": "Wall, D. D. (1960). Fibonacci series modulo m. American Mathematical Monthly, 67(6), 525-532. DOI: 10.1080/00029890.1960.11989541.",
  "title": "QA Pisano-Orbit Correspondence Cert fixture schema [281]",
  "description": "Fixtures for qa_pisano_orbit_correspondence_cert_v1. Two fixture_type values: orbit_period (tests that a specific (b,e) pair has the expected period and family) and pisano_period (tests that pi(k) has the expected value).",
  "type": "object",
  "required": ["schema_version", "fixture_kind", "fixture_type"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "QA_PISANO_ORBIT_CORRESPONDENCE_CERT.v1"
    },
    "fixture_kind": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "fixture_type": {
      "type": "string",
      "enum": ["orbit_period", "pisano_period"]
    },
    "primary_source": {
      "type": "string"
    },
    "b_value": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "e_value": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "expected_period": {
      "type": "integer",
      "minimum": 1
    },
    "expected_family": {
      "type": "string",
      "enum": ["singularity", "satellite", "cosmos"]
    },
    "pisano_k": {
      "type": "integer",
      "minimum": 2
    },
    "expected_pisano_period": {
      "type": "integer",
      "minimum": 1
    },
    "expected_fail_type": {
      "type": "string",
      "enum": [
        "MISSING_FIELD",
        "WRONG_SATELLITE_PERIOD",
        "WRONG_COSMOS_PERIOD",
        "WRONG_PISANO_VALUE"
      ]
    }
  }
}
