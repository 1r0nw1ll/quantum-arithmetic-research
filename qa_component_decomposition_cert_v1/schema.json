{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "QA_COMPONENT_DECOMPOSITION_CERT.v1.schema.json",
  "title": "QA Component Decomposition Certificate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created_utc",
    "subject",
    "claims",
    "fixtures",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "QA_COMPONENT_DECOMPOSITION_CERT.v1"
    },
    "cert_id": {
      "type": "string",
      "minLength": 6
    },
    "created_utc": {
      "type": "string",
      "minLength": 10
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seed_unit", "N", "generators", "algebra_bridge_semantics_sha256"],
      "properties": {
        "seed_unit": { "$ref": "#/definitions/vector2" },
        "N": { "type": "integer", "minimum": 1 },
        "generators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["sigma", "mu", "R", "lambda_k", "nu"]
          }
        },
        "algebra_bridge_semantics_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Must match qa_algebra_bridge_cert_v1.semantics_anchor.BRIDGE_SEMANTICS_SHA256 (enforced by validator Gate 1)."
        },
        "failure_algebra_anchor_ref": {
          "type": "string",
          "description": "Optional soft bridge. If present, validator verifies qa_failure_algebra_structure_cert_v1.failure_algebra_anchor.FAILURE_ALGEBRA_ANCHOR_REF."
        },
        "failure_algebra_anchor_rollup_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Optional soft bridge rollup. If present, validator verifies qa_failure_algebra_structure_cert_v1.failure_algebra_anchor.FAILURE_ALGEBRA_ANCHOR_ROLLUP_SHA256."
        }
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_decomposition",
        "scaled_seed_roundtrip",
        "nu_power2_characterization",
        "bounded_theorem_sweep"
      ],
      "properties": {
        "component_decomposition": { "type": "boolean" },
        "scaled_seed_roundtrip": { "type": "boolean" },
        "nu_power2_characterization": { "type": "boolean" },
        "bounded_theorem_sweep": { "type": "boolean" }
      }
    },
    "fixtures": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decomposition_samples", "nu_samples"],
      "properties": {
        "decomposition_samples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "state",
              "expected_gcd",
              "expected_normalized",
              "expected_word",
              "expected_scaled_seed_roundtrip"
            ],
            "properties": {
              "state": { "$ref": "#/definitions/vector2" },
              "expected_gcd": { "type": "integer", "minimum": 1 },
              "expected_normalized": { "$ref": "#/definitions/vector2" },
              "expected_word": { "type": "string", "pattern": "^[LR]*$" },
              "expected_scaled_seed_roundtrip": { "$ref": "#/definitions/vector2" }
            }
          }
        },
        "nu_samples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "state",
              "expected_v2_g",
              "expected_after_v2",
              "expected_reaches_normalized",
              "expected_next_ok",
              "expected_next_fail_type"
            ],
            "properties": {
              "state": { "$ref": "#/definitions/vector2" },
              "expected_v2_g": { "type": "integer", "minimum": 0 },
              "expected_after_v2": { "$ref": "#/definitions/vector2" },
              "expected_reaches_normalized": { "type": "boolean" },
              "expected_next_ok": { "type": "boolean" },
              "expected_next_fail_type": {
                "type": "string",
                "enum": ["NOT_IN_NATURAL_DOMAIN", "ODD_BLOCK", ""]
              },
              "expected_next_value": { "$ref": "#/definitions/vector2" }
            }
          }
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "failures", "invariant_diff_map"],
      "properties": {
        "ok": { "type": "boolean" },
        "failures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["gate", "fail_type", "path", "reason"],
            "properties": {
              "gate": { "type": "integer", "minimum": 1 },
              "fail_type": { "type": "string" },
              "path": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
        "invariant_diff_map": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entries", "rollup_sha256"],
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["gate", "fail_type", "path", "reason"],
                "properties": {
                  "gate": { "type": "integer", "minimum": 1 },
                  "fail_type": { "type": "string" },
                  "path": { "type": "string" },
                  "reason": { "type": "string" }
                }
              }
            },
            "rollup_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        }
      }
    }
  },
  "definitions": {
    "vector2": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer" }
    }
  }
}
