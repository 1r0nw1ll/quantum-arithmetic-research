{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "QA_FAILURE_COMPOSE_OPERATOR_CERT.v1.schema.json",
  "title": "QA Failure Compose Operator Cert v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "cert_id",
    "created_utc",
    "carrier",
    "forms",
    "compose_table",
    "claimed"
  ],
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "QA_FAILURE_COMPOSE_OPERATOR_CERT"
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "cert_id": {
      "type": "string",
      "minLength": 6
    },
    "created_utc": {
      "type": "string",
      "minLength": 10
    },
    "carrier": {
      "type": "array",
      "minItems": 2,
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "forms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "enum": ["serial", "parallel", "feedback"]
      },
      "uniqueItems": true
    },
    "compose_table": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["form", "a", "b", "comp"],
        "properties": {
          "form": {
            "type": "string",
            "enum": ["serial", "parallel", "feedback"]
          },
          "a": {
            "type": "string",
            "minLength": 1
          },
          "b": {
            "type": "string",
            "minLength": 1
          },
          "comp": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "claimed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["closure_holds", "associativity_holds"],
      "properties": {
        "closure_holds": {
          "type": "boolean"
        },
        "associativity_holds": {
          "type": "boolean"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
