,1],[0,0,0],[-1,-2,-1]],dtype\u003dint); B2\u003dnp.array([[2,1,0],[1,0,-1],[0,-1,-2]],dtype\u003dint); B3\u003dnp.array([[0,1,2],[-1,0,1],[-2,-1,0]],dtype\u003dint)\n    seeds\u003d[B0,B1,B2,B3]; mixes\u003d[(1,0),(2,1),(1,1),(1,2),(1,-1),(2,-1)]; stencils\u003d[]\n    for s_idx,K in enumerate(seeds):\n        for r in range(4):\n            Kr\u003d_rot90(K,r); Kn_base\u003dseeds[(s_idx+1)%4]; Kn\u003d_rot90(Kn_base,r)\n            for(a,b)in mixes:\n                M\u003da*Kr+b*Kn; flat\u003dM.ravel(); g\u003dint(np.gcd.reduce(flat))if np.any(flat)else 1; M\u003d(M//g)if g else M; stencils.append(M.astype(int))\n                if len(stencils)\u003d\u003d24: return stencils\n    return stencils\nSTENCILS_24 \u003d rank24_integer_stencils()\ndef conv3_toroidal_std(X_uint8, K):\n    X \u003d X_uint8.astype(np.int32); acc \u003d np.zeros_like(X, dtype\u003dnp.int32)\n    for dy in (-1,0,1):\n        for dx in (-1,0,1): acc +\u003d int(K[dy+1,dx+1]) * toroidal_shift_np(X,dy,dx)\n    return np.std(acc)\n\ndef get_qa_features(X_uint8):\n    responses \u003d np.array([conv3_toroidal_std(X_uint8, K) for K in STENCILS_24])\n    qa_vector \u003d responses.astype(np.float32)\n    qa_vector_norm \u003d qa_vector / (np.linalg.norm(qa_vector) + 1e-6)\n    b \u003d responses[0]; e \u003d responses[6]; d \u003d b + e; a \u003d b + 2 * e\n    qa_tuple \u003d np.array([b, e, d, a], dtype\u003dnp.float32)\n    qa_tuple_norm \u003d qa_tuple / (np.linalg.norm(qa_tuple) + 1e-6)\n    return qa_vector_norm, qa_tuple_norm\n\n# --- [QAConv24 Layer Definition] ---\nclass QAConv24(layers.Layer):\n    def __init__(self, out_ch\u003d32, use_bias\u003dFalse, name\u003d\"QAConv24\", **kwargs):\n        super().__init__(name\u003dname, **kwargs)\n        self.out_ch \u003d out_ch; self.use_bias \u003d use_bias\n        K \u003d np.stack(STENCILS_24, axis\u003d0)[:, :, :, np.newaxis]; K \u003d np.transpose(K, (1, 2, 3, 0))\n        self.K_fixed \u003d tf.constant(K, dtype\u003dtf.float32)\n    