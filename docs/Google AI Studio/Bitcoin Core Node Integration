ock_hash \u003d call_rpc(\u0027getblockhash\u0027, [height])\n        # Get the block header details (verbosity 2 gives fields)\n        block_data \u003d call_rpc(\u0027getblock\u0027, [block_hash, 2])\n\n        # Extract relevant header fields. These are the components of the header *except* the nonce.\n        # We\u0027ll add our generated nonce later.\n        header_fields \u003d {\n            \u0027version\u0027: block_data.get(\u0027version\u0027),\n            \u0027previousblockhash\u0027: block_data.get(\u0027previousblockhash\u0027),\n            \u0027merkle_root\u0027: block_data.get(\u0027merkleroot\u0027), # Note: RPC uses \u0027merkleroot\u0027\n            \u0027time\u0027: block_data.get(\u0027time\u0027), # Note: RPC uses \u0027time\u0027 instead of \u0027timestamp\u0027\n            \u0027bits\u0027: block_data.get(\u0027bits\u0027), # This contains the difficulty target\n            # Note: We don\u0027t need the original nonce from here, we will replace it.\n            \u0027height\u0027: height # Store height for reference\n        }\n\n        # Ensure all necessary fields were found\n        required_fields \u003d [\u0027version\u0027, \u0027previousblockhash\u0027, \u0027merkle_root\u0027, \u0027time\u0027, \u0027bits\u0027]\n        if not all(header_fields.get(f) is not None for f in required_fields):\n             raise Exception(f\"Missing required header fields in RPC response for block {height}. Found: {header_fields}\")\n\n        return header_fields\n\n    except Exception as e:\n        print(f\"Failed to fetch block header for height {height} via RPC: {e}\")\n        return None # Indicate failure\n\n# ----------------------------------------------------------------------------\n# Bitcoin Block Header Construction and Hashing\n# ----------------------------------------------------------------------------\ndef build_block_header(header_fields, nonce):\n    \"\"\"\n    Constructs the 80-byte block header byte string.\n    heade