{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QA_EXPERIMENT_PROTOCOL.v1",
  "type": "object",
  "required": [
    "protocol_version",
    "experiment_id",
    "hypothesis",
    "null_model",
    "pre_registration",
    "decision_rules",
    "observer_projection",
    "real_data_status",
    "source_mapping",
    "ablation",
    "reproducibility"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "minLength": 1,
      "const": "QA_EXPERIMENT_PROTOCOL.v1"
    },
    "experiment_id": { "type": "string", "minLength": 1 },
    "hypothesis": { "type": "string", "minLength": 1 },
    "null_model": {
      "type": "object",
      "required": ["description", "generating_process", "held_fixed", "permuted", "independence_argument"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "generating_process": { "type": "string", "minLength": 1 },
        "held_fixed": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "permuted": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "independence_argument": { "type": "string", "minLength": 1 },
        "permutation_axis": { "type": "string" },
        "surrogate_types": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "pre_registration": {
      "type": "object",
      "required": ["seed", "date_utc", "n_trials"],
      "properties": {
        "seed": { "type": "integer", "minimum": 0 },
        "date_utc": { "type": "string", "minLength": 1, "format": "date-time" },
        "n_trials": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "decision_rules": {
      "type": "object",
      "required": ["accept_criterion", "reject_criterion", "on_unsupportive"],
      "properties": {
        "accept_criterion": { "type": "string", "minLength": 1 },
        "reject_criterion": { "type": "string", "minLength": 1 },
        "on_unsupportive": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "investigate_observer",
            "investigate_implementation",
            "pre_registered_accept"
          ]
        }
      },
      "additionalProperties": false
    },
    "observer_projection": {
      "type": "object",
      "required": ["description", "state_alphabet"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "state_alphabet": { "type": "string", "minLength": 1 },
        "source_domain": { "type": "string" }
      },
      "additionalProperties": false
    },
    "real_data_status": {
      "oneOf": [
        { "type": "string", "enum": ["pending", "synthetic_only"] },
        {
          "type": "string",
          "minLength": 1,
          "not": { "enum": ["pending", "synthetic_only"] }
        }
      ],
      "description": "Path/source of real data, or 'pending', or 'synthetic_only'"
    },
    "reproduces": { "type": "string" },
    "primary_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_mapping": {
      "type": "object",
      "required": ["theory_doc", "primary_source", "mapping_rationale"],
      "properties": {
        "theory_doc": { "type": "string", "minLength": 1 },
        "primary_source": { "type": "string", "minLength": 1 },
        "mapping_rationale": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "ablation": {
      "type": "object",
      "required": ["callable", "destroyed_structure", "expected_direction"],
      "properties": {
        "callable": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z_]\\w*$"
        },
        "destroyed_structure": { "type": "string", "minLength": 1 },
        "expected_direction": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "reproducibility": {
      "type": "object",
      "required": ["seed", "data_sha256", "package_versions", "results_ledger"],
      "properties": {
        "seed": { "type": "integer", "minimum": 0 },
        "data_sha256": {
          "oneOf": [
            { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            { "type": "string", "enum": ["pending", "synthetic_only"] }
          ]
        },
        "package_versions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "results_ledger": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
