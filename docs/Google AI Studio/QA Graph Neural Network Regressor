phasize two other core pillars of QA:\n1.  **Residue-Space Embeddings:** Projecting numbers into modular spaces (mod-9, mod-24, mod-72) to reveal cyclic and harmonic patterns.\n2.  **QA Family Classification:** Grouping every tuple into one of five families (Fibonacci, Lucas, etc.) based on their digital roots, which provides a symbolic \"fingerprint.\"\n\nOur model is arithmetically constrained, but it is currently \"blind\" to these deeper harmonic and symbolic structures. The instability we see is the symptom of this missing information.\n\n### 3. Recommended Next Step: Implement Residue-Space Message Passing\n\nTo stabilize the model and give it the tools it needs to learn the complex energy properties, we must implement **Option 2** from our previous discussion: the **Residue-Space Layer**.\n\nThis is not a replacement for the `QAConstraintConv`, but an **enhancement**. We will augment the input features with modular embeddings, providing a much richer, multi-faceted representation for the constraint-enforcing GNN layers to process.\n\n**The Action Plan:**\n\n1.  **Re-introduce Residue Embeddings:** We will add the `ResidueEmbedding` modules for `mod-24` and `mod-72` back into our `QAGNNMultiHead` model.\n2.  **Augment Features:** Before the first `QAConstraintConv` layer, we will concatenate the initial node features with their `mod-24` and `mod-72` residue embeddings.\n3.  **Project and Propagate:** This richer, augmented feature vector will then be projected into the hidden space and processed by our existing `QAConstraintConv` layers.\n\nThis hybrid approach allows the model to reason about nodes based on both their direct arithmetic properties and their position within the larger harmonic cycles described in your theory. This is the next logical step to infuse a deeper QA alignment into the GNN.\n\nHere are the updated files to implement this change. Only `qa_gnn_regressor.py` needs to be modified.\n\n---\n### Updated File: `qa_gnn_regressor.py`\n\nThis version enhances the `QAGNNMultiHead` model to include residue-space embeddings as an input to the arithmetically-constrained convolution layers.\n\n```python\n# qa_gnn_regressor.py\nimport os\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom torch_geometric.loader import DataLoader\nfrom torch_geometric.data import InMemoryDataset\nfrom torch_geometric.nn import global_mean_pool\nimport numpy as np\n\n# We will use the existing, powerful QAConstraintConv layer\nfrom qagcn import QAConstraintConv\n\n# -------------------------------\n# Dataset Wrapper (Unchanged)\n# -------------------------------\nclass QAQM9Dataset(InMemoryDataset):\n    def __init__(self, root, transform\u003dNone, pre_transform\u003dNone, pre_filter\u003dNone):\n        super().__init__(root, transform, pre_transform, pre_filter)\n        self.data, self.slices, self.mean, self.std \u003d torch.load(self.processed_paths[0], weights_only\u003dFalse)\n\n    @property\n    def raw_file_names(self): return []\n    @property\n    def processed_file_names(self): return [\u0027data_qaqm9.pt\u0027]\n    def download(self): pass\n    def process(self): pass\n\n# -------------------------------\n# Residue Embedding Module (Unchanged)\n# -------------------------------\nclass ResidueEmbedding(nn.Module):\n    def __init__(self, modulo, embed_dim):\n        super().__init__()\n        self.modulo \u003d modulo\n        self.embed \u003d nn.Embedding(modulo, embed_dim)\n\n    def forward(self, atom_identifiers):\n        residues \u003d torch.remainder(atom_identifiers, self.modulo).long()\n        return self.embed(residues)\n\n# -------------------------------\n# QA-GNN with Residues AND Constraint Layers (ENHANCED MODEL)\n# -------------------------------\nclass QAGNNMultiHead(nn.Module):\n    def __init__(self, num_node_features, hidden_dim, num_properties\u003d19):\n        super().__init__()\n        if hidden_dim % 4 !\u003d 0:\n            raise ValueError(\"hidden_dim must be divisible by 4 for QAConstraintConv.\")\n        self.num_properties \u003d num_properties\n\n        # --- ENHANCEMENT: Re-introduce Residue Embeddings ---\n        # This aligns with the modular/harmonic aspect of QA theory\n        self.res24_embed \u003d ResidueEmbedding(24, 16)\n        self.res72_embed \u003d ResidueEmbedding(72, 16)\n        \n        # The input dimension is now the raw features + both residue embeddings\n        augmented_feature_dim \u003d num_node_features + 16 + 16\n        self.feature_proj \u003d nn.Linear(augmented_feature_dim, hidden_dim)\n\n        self.property_embedding \u003d nn.Embedding(num_properties, hidden_dim)\n        \n        # The QAConstraintConv layers will now operate on a richer representation\n        self.conv1 \u003d QAConstraintConv(hidden_dim, hidden_dim)\n        self.conv2 \u003d QAConstraintConv(hidden_dim, hidden_dim)\n\n        self.heads \u003d nn.ModuleList([\n            nn.Sequential(\n                nn.Linear(hidden_dim, hidden_dim // 2),\n                nn.ReLU(),\n                nn.Linear(hidden_dim // 2, 1)\n            ) for _ in range(num_properties)\n        ])\n\n    def forward(self, data):\n        x, edge_index, batch \u003d data.x, data.edge_index, data.batch\n        atomic_proxy \u003d x[:, 0]\n\n        # --- ENHANCEMENT: Create augmented features ---\n        res24 \u003d self.res24_embed(atomic_proxy)\n        res72 \u003d self.res72_embed(atomic_proxy)\n        augmented_x \u003d torch.cat([x.float(), res24, res72], dim\u003d-1)\n        \n        # Project the rich feature vector into the hidden space\n        x_proj \u003d F.relu(self.feature_proj(augmented_x))\n\n        all_property_outputs \u003d []\n        for i in range(self.num_properties):\n            q_emb \u003d self.property_embedding(torch.tensor(i, device\u003dx_proj.device))\n            h \u003d x_proj + q_emb\n            \n            # Pass through QA-constrained layers\n            h \u003d F.relu(self.conv1(h, edge_index))\n            h \u003d F.relu(self.conv2(h, edge_index))\n            \n            h_graph \u003d global_mean_pool(h, batch)\n            output \u003d self.heads[i](h_graph)\n            all_property_outputs.append(output)\n\n        return torch.cat(all_property_outputs, dim\u003d-1)\n\n# -------------------------------\n# Training, Evaluation, and Main (All Unchanged)\n# -------------------------------\ndef train(model, loader, optimizer, device, dataset_mean, dataset_std):\n    model.train()\n    total_loss \u003d 0\n    for data in loader:\n        data \u003d data.to(device)\n        optimizer.zero_grad()\n        out_norm \u003d model(data)\n        target_norm \u003d (data.y - dataset_mean) / dataset_std\n        loss \u003d F.mse_loss(out_norm, target_norm)\n        loss.backward()\n        optimizer.step()\n        total_loss +\u003d loss.item() * data.num_graphs\n    return total_loss / len(loader.dataset)\n\ndef test(model, loader, dataset_mean, dataset_std, device):\n    model.eval()\n    per_property_se \u003d torch.zeros(model.num_properties, device\u003ddevice)\n    with torch.no_grad():\n        for data in loader:\n            data \u003d data.to(device)\n            pred_norm \u003d model(data)\n            pred_denorm \u003d pred_norm * dataset_std + dataset_mean\n            true_denorm \u003d data.y\n            se \u003d (pred_denorm - true_denorm).pow(2)\n            per_property_se +\u003d se.sum(dim\u003d0)\n    per_property_mse \u003d per_property_se / len(loader.dataset)\n    avg_mse \u003d per_property_mse.mean().item()\n    return avg_mse, per_property_mse.cpu().numpy()\n\ndef main():\n    print(\"Starting QA-GNN Regressor training...\")\n    device \u003d torch.device(\u0027cuda\u0027 if torch.cuda.is_available() else \u0027cpu\u0027)\n    print(f\"Using device: {device}\")\n    \n    dataset_root \u003d \u0027data/qa_qm9\u0027\n    if not os.path.exists(os.path.join(dataset_root, \u0027processed\u0027, \u0027data_qaqm9.pt\u0027)):\n        print(f\"\\nError: Dataset file not found.\")\n        return\n\n    dataset \u003d QAQM9Dataset(root\u003ddataset_root)\n    print(f\"Dataset loaded successfully. Total examples: {len(dataset)}\")\n    \n    if len(dataset) \u003e 110000:\n        train_size \u003d 110000\n        test_size \u003d len(dataset) - train_size\n    else:\n        train_size \u003d int(0.9 * len(dataset))\n        test_size \u003d len(dataset) - train_size\n        print(f\"Warning: Dataset is smaller than 110k. Using {train_size}/{test_size} split.\")\n        \n    train_dataset, test_dataset \u003d torch.utils.data.random_split(dataset, [train_size, test_size])\n    train_loader \u003d DataLoader(train_dataset, batch_size\u003d64, shuffle\u003dTrue)\n    test_loader \u003d DataLoader(test_dataset, batch_size\u003d64, shuffle\u003dFalse)\n    \n    data_mean \u003d dataset.mean.to(device)\n    data_std \u003d dataset.std.to(device)\n\n    model \u003d QAGNNMultiHead(\n        num_node_features\u003d4,\n        hidden_dim\u003d128, # Must be divisible by 4\n        num_properties\u003d19\n    ).to(device)\n    \n    optimizer \u003d torch.optim.Adam(model.parameters(), lr\u003d1e-3)\n    \n    print(\"\\n--- Starting Training ---\")\n    for epoch in range(1, 31):\n        train_loss \u003d train(model, train_loader, optimizer, device, data_mean, data_std)\n        test_avg_mse, test_per_prop_mse \u003d test(model, test_loader, data_mean, data_std, device)\n        \n        print(f\"\\nEpoch {epoch:02d} | Train MSE (normalized): {train_loss:.6f} | Test MSE (de-normalized): {test_avg_mse:.6f}\")\n        print(\"Per-target Test MSE (de-normalized):\")\n        formatted_mse \u003d np.array2string(test_per_prop_mse, formatter\u003d{\u0027float_kind\u0027:lambda x: \"%.6f\" % x})\n        print(formatted_mse)\n        print(\"-\" * 80)\n\nif __name__ \u003d\u003d \"__main__\":\n    main()```",
