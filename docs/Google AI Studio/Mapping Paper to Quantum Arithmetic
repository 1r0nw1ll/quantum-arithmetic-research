ixes\u003d[(1,0),(2,1),(1,1),(1,2),(1,-1),(2,-1)]; stencils\u003d[]\n    for s_idx,K in enumerate(seeds):\n        for r in range(4):\n            Kr\u003d_rot90(K,r); Kn_base\u003dseeds[(s_idx+1)%4]; Kn\u003d_rot90(Kn_base,r)\n            for(a,b)in mixes:\n                M\u003da*Kr+b*Kn; flat\u003dM.ravel(); g\u003dint(np.gcd.reduce(flat))if np.any(flat)else 1\n                M\u003d(M//g)if g else M; stencils.append(M.astype(int))\n                if len(stencils)\u003d\u003d24: return stencils\n    return stencils\nSTENCILS_24 \u003d rank24_integer_stencils()\n\n# --- [THE CRUCIAL FIX IS HERE] ---\ndef conv3_toroidal_std(X_uint8, K):\n    \"\"\"Convolves with a 3x3 kernel and returns the standard deviation of the response map.\"\"\"\n    X \u003d X_uint8.astype(np.int32)\n    acc \u003d np.zeros_like(X, dtype\u003dnp.int32)\n    for dy in (-1, 0, 1):\n        for dx in (-1, 0, 1):\n            acc +\u003d int(K[dy + 1, dx + 1]) * toroidal_shift_np(X, dy, dx)\n    return int(np.std(acc)) # Using standard deviation instead of sum of absolute values\n\ndef axis_mirror_tallies(X_uint8):\n    responses \u003d [conv3_toroidal_std(X_uint8, K) for K in STENCILS_24] # Use the new function\n    return np.array(responses[0::2], dtype\u003dnp.float64), np.array(responses[1::2], dtype\u003dnp.float64)\n\ndef qa_signature(X_uint8):\n    R\u003dresidue_spectrum_mod24(X_uint8); rings\u003dring_indices(*X_uint8.shape); ring_H\u003dring_residue_entropy(X_uint8,rings)\n    A_axis,A_mirror\u003daxis_mirror_tallies(X_uint8); resp\u003dnp.zeros(24,dtype\u003dnp.float64); resp[0::2]\u003dA_axis; resp[1::2]\u003dA_mirror\n    top\u003dint(np.argmax(resp)); top2\u003dnp.partition(resp,-2)[-2]if resp.size\u003e\u003d2 else resp[top]\n    gap\u003dfloat(resp[top]-top2); ratio\u003dfloat((A_axis.mean()+1e-9)/(A_mirror.mean()+1e-9))\n    return {\"residue_peak\":int(np.argmax(R)),\"phase_top\":top,\"phase_gap\":gap,\"axis_mirror_ratio\":ratio,\"ring_entropy\":ring_H}\n\n# --- [Keras Laye