{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "QA_PROOF_ASSISTANT_REGISTRY_SCHEMA.v1",
  "title": "QA_PROOF_ASSISTANT_REGISTRY_SCHEMA.v1",
  "description": "Deterministic adapter contract for Lean 4, Coq, and Isabelle proof-assistant ecosystems.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "registry_id",
    "created_utc",
    "adapters",
    "metrics",
    "invariant_diff"
  ],
  "properties": {
    "schema_id": {
      "const": "QA_PROOF_ASSISTANT_REGISTRY_SCHEMA.v1"
    },
    "registry_id": {
      "type": "string",
      "minLength": 1
    },
    "created_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assistant_id",
          "version",
          "executable",
          "kernel_check_command",
          "environment_hash",
          "lock_hash",
          "deterministic",
          "supported_artifacts"
        ],
        "properties": {
          "assistant_id": {
            "type": "string",
            "enum": ["lean4", "coq", "isabelle"]
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "executable": {
            "type": "string",
            "minLength": 1
          },
          "kernel_check_command": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "environment_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "lock_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "deterministic": {
            "type": "boolean"
          },
          "supported_artifacts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_count", "deterministic_count"],
      "properties": {
        "adapter_count": {
          "type": "integer",
          "minimum": 0
        },
        "deterministic_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "invariant_diff": {
      "type": "object"
    }
  }
}
