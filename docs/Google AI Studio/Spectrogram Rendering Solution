or, ValueError):\n        # Handle cases where number is too large to convert to standard int or is non-numeric\n        # Fallback or alternative calculation might be needed depending on exact number range\n        # For now, return 0 as a fallback\n        return 0\n\n    if n \u003d\u003d 0: return 0\n    # Formula: 1 + (n - 1) % 9 for n \u003e 0\n    return 1 + (n - 1) % 9\n\ndef generate_digital_root_cycle(n):\n    \"\"\"Generates the digital root sequence for 1, 2, 3,... up to length n.\"\"\"\n    # Using float for consistency\n    return np.array([float(get_digital_root(i)) for i in range(1, n + 1)], dtype\u003dnp.float64)\n\nprint(f\"Parameters set: N_TERMS\u003d{N_TERMS}\")\nprint(f\"Resonance criteria based on Digital Root values: {RESONANCE_CRITERIA}\")\n```\n\n---\n\n**(Cell 6: Markdown)**\n\n```markdown\n## 2. Generate Sequences and Create Dataset (X, y)\n```\n\n---\n\n**(Cell 7: Code) - Generate Data \u0026 Create X, y**\n\n```python\n# --- Generate the core sequences ---\nfib_seq \u003d generate_fibonacci(N_TERMS)\ncube_seq \u003d generate_cubes(N_TERMS)\ndr_seq \u003d generate_digital_root_cycle(N_TERMS) # Digital root of 1, 2, ..., N_TERMS\n\nprint(\"Sequences Generated:\")\nprint(f\"Fibonacci (first 15): {fib_seq[:15]}\")\nprint(f\"Cubes (first 15):     {cube_seq[:15]}\")\nprint(f\"Digital Root (first 15): {dr_seq[:15]}\")\nprint(\"-\" * 20)\n\n# --- Create Feature Matrix X ---\n# Stack the sequences column-wise. Each row represents a state \u0027n\u0027.\nif not (len(fib_seq) \u003d\u003d N_TERMS and len(cube_seq) \u003d\u003d N_TERMS and len(dr_seq) \u003d\u003d N_TERMS):\n    raise ValueError(f\"All sequences must have length {N_TERMS} for stacking.\")\n\nX \u003d np.stack([fib_seq, cube_seq, dr_seq], axis\u003d1)\n\n# Handle potential infinite values resulting from large numbers (important for scaling)\nif np.any(~np.isfinite(X)):\n    print(\"Warning: Non-finite values (inf or NaN) detected in feature matrix X.\")\n    print(\"Replacing non-fi