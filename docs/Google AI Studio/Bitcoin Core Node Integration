t(qa_encoded_offset), # The 32-bit offset before adding base\n                         \u0027base_step\u0027: int(base_step),\n                         \u0027current_base\u0027: int(current_base), # The base added to the offset\n                         \u0027filter_type\u0027: filter_type,\n                         \u0027filter_mod\u0027: filter_mod,\n                         \u0027filter_residue\u0027: filter_residue,\n                         \u0027passed_filter\u0027: True, # Always True if yielded by this generator\n                         \u0027total_candidates_evaluated\u0027: int(total_candidates_evaluated) # Total count before filtering\n                     }\n\n        if base_step % 100 \u003d\u003d 0:\n             print(f\"  Processed candidates from {base_step + 1}/{num_base_steps} base shells... (Total candidates evaluated: {total_candidates_evaluated:,})\")\n\n\n    print(f\"\\n[INFO] Finished processing candidates from {num_base_steps} base shells. Total candidates evaluated: {total_candidates_evaluated:,}\")\n\n# ----------------------------------------------------------------------------\n# QA Mining Simulation with Data Logging\n# Uses the data-yielding generator and logs outcomes\n# ----------------------------------------------------------------------------\n\ndef qa_mine_simulation_log(base_header_fields, simulated_target_hex,\n                            filter_type\u003dNone, filter_mod\u003d1, filter_residue\u003d0):\n    \"\"\"\n    Simulates mining using QA-guided nonces, logs data for AI training,\n    and stops upon finding a hash below the simulated target.\n    \"\"\"\n    if base_header_fields is None:\n        print(\"[ERROR] Cannot start mining simulation: Base header fields not fetched.\")\n        return None\n\n    print(\"\\n[INFO] Starting QA Mining Simulation with Data Logging...\")\n    print(f\"[INFO] Base Block Height: {base_header_fields.get(\u0027height\u0027, \u0027N/A\u0027)}\")\n    print(f\"[INFO] Using Simulated Target: {simulated_target_hex}\")\n    if LOG_DATA:\n        print(f\"[INFO] Logging data to {LOG_FILENAME}\")\n\n    try:\n        simulated_target_int \u003d int(simulated_target_hex, 16)\n    except ValueError:\n        print(f\"[ERROR] Invalid simulated target hex string: {simulated_target_hex}\")\n        return None\n\n    nonce_count_tried \u003d 0 # Count of nonces *tried* from the generator (filtered or not)\n    start_time \u003d time.time()\n\n    # Open log file if logging is enabled\n    log_file \u003d None\n    if LOG_DATA:\n        try:\n            log_file \u003d open(LOG_FILENAME, \u0027a\u0027) # Use \u0027a\u0027 mode to append\n        except IOError as e:\n            print(f\"[ERROR] Could not open log file {LOG_FILENAME}: {e}\")\n            log_file \u003d None\n            print(\"[WARNING] Data logging disabled due to file error.\")\n\n\n    # Get the data generator (includes filtering logic internally now)\n    qa_data_generator \u003d qa_guided_nonce_stream_data(start_seed\u003d0,\n                                                    num_base_steps\u003dnum_base_steps_config,\n                                                    filter_type\u003dfilter_type,\n                                                    filter_mod\u003dfilter_mod,\n                                                    filter_residue\u003dfilter_residue)\n\n    try:\n        # Iterate through data dictionaries yielded by the generator\n        for nonce_data in qa_data_generator:\n            nonce_count_tried +\u003d 1\n\n            candidate_nonce \u003d nonce_data[\u0027nonce\u0027]\n\n            # Build the full block header with the current candidate nonce\n            candidate_header_bin \u003d build_block_header(base_header_fields, candidate_nonce)\n\n            if candidate_header_bin is None:\n                print(f\"[ERROR] Failed to build header with nonce {candidate_nonce}, stopping simulation.\")\n                if log_file: log_file.close()\n       