import Mathlib.Data.ZMod.Basic
import Mathlib.Data.Matrix.Basic
import Mathlib.LinearAlgebra.Matrix.Determinant.Basic
import Mathlib.GroupTheory.OrderOfElement
import Mathlib.GroupTheory.SpecificGroups.Cyclic.Basic
import Mathlib.Tactic
import QAFibMatrix

/-!
# Cyclic Subgroup РЪеFРЪЕ РЅЁ Рёц/24Рёц in GLРѓѓ(ZMod 9)

Lifts the Fibonacci matrix `fib_mat` (defined in `QAFibMatrix.lean`) to a unit
in the matrix ring MРѓѓ(ZMod 9), then establishes the group-theoretic structure:

- `fib_mat_unit` is a unit of `(Matrix (Fin 2) (Fin 2) (ZMod 9))╦Б`
  (via `det(F) = 8`, a unit in `ZMod 9` since `gcd(8, 9) = 1`).
- `orderOf fib_mat_unit = 24` Рђћ the Pisano period becomes the group-theoretic order.
- `|РЪеFРЪЕ| = 24` Рђћ the cyclic subgroup generated by `F` has exactly 24 elements.
- `РЪеFРЪЕ` is cyclic (trivially: generated by a single element).

## Cert references

- `[128]` Pisano period ¤ђ(9) = 24 Рђћ the order statement.
- `[126]` orbit structure Рђћ the group action view of the three QA orbits.
- `[153]` singularity dominance Рђћ `det(F) РЅа 0` makes `F` a group element.
-/

-- ============================================================================
-- LIFT fib_mat TO A UNIT
-- ============================================================================

/-- The matrix inverse of `fib_mat`: `FРЂ╗┬╣ = [[0,1],[1,8]]` over `ZMod 9`.

    Direct computation: `[[1,1],[1,0]] * [[0,1],[1,8]] = [[1,9],[0,1]] = I` mod 9. -/
private def fib_mat_inv_mat : Matrix (Fin 2) (Fin 2) (ZMod 9) := !![0, 1; 1, 8]

/-- `fib_mat` as a unit of the matrix ring `MРѓѓ(ZMod 9)`.

    `det(F) = 8` is a unit in `ZMod 9` (since `gcd(8, 9) = 1`), so `F` is
    invertible and belongs to `GLРѓѓ(ZMod 9) = (MРѓѓ(ZMod 9))╦Б`. -/
def fib_mat_unit : (Matrix (Fin 2) (Fin 2) (ZMod 9))╦Б :=
  РЪеfib_mat, fib_mat_inv_mat, by native_decide, by native_decideРЪЕ

/-- The underlying matrix of `fib_mat_unit` is `fib_mat`. -/
@[simp]
theorem fib_mat_unit_val :
    (fib_mat_unit : Matrix (Fin 2) (Fin 2) (ZMod 9)) = fib_mat := rfl

-- ============================================================================
-- POWER LAWS IN THE UNIT GROUP
-- ============================================================================

/-- `F^24 = 1` in `(MРѓѓ(ZMod 9))╦Б` (lifts `fib_mat_pow_24` to the unit group). -/
theorem fib_mat_unit_pow_24 : fib_mat_unit ^ 24 = 1 := by
  apply Units.val_injective
  simp only [Units.val_pow_eq_pow_val, Units.val_one, fib_mat_unit_val]
  exact fib_mat_pow_24

/-- For all `k Рѕѕ {1,...,23}`, `F^k РЅа 1` in `(MРѓѓ(ZMod 9))╦Б`.

    Lifts `fib_mat_order_exact` from matrix equality to unit equality. -/
theorem fib_mat_unit_order_exact :
    Рѕђ k : Fin 24, k.val РЅа 0 Рєњ fib_mat_unit ^ k.val РЅа 1 := by
  intro k hk heq
  have hmat : fib_mat ^ k.val = 1 := by
    have := congr_arg Units.val heq
    simp only [Units.val_pow_eq_pow_val, Units.val_one, fib_mat_unit_val] at this
    exact this
  exact fib_mat_order_exact k hk hmat

/-- `F^12 РЅа 1` in `(MРѓѓ(ZMod 9))╦Б` (needed for `orderOf` proof, prime factor `p = 2`). -/
theorem fib_mat_unit_pow_12_ne_one : fib_mat_unit ^ 12 РЅа 1 :=
  fib_mat_unit_order_exact РЪе12, by norm_numРЪЕ (by norm_num)

/-- `F^8 РЅа 1` in `(MРѓѓ(ZMod 9))╦Б` (needed for `orderOf` proof, prime factor `p = 3`). -/
theorem fib_mat_unit_pow_8_ne_one : fib_mat_unit ^ 8 РЅа 1 :=
  fib_mat_unit_order_exact РЪе8, by norm_numРЪЕ (by norm_num)

-- ============================================================================
-- MAIN THEOREM: orderOf F = 24
-- ============================================================================

/-- **The multiplicative order of `F` in `GLРѓѓ(ZMod 9)` is exactly 24** (cert [128]).

    This is the group-theoretic formulation of the Pisano period ¤ђ(9) = 24:
    `F` generates a cyclic subgroup of order 24 in `(MРѓѓ(ZMod 9))╦Б`. -/
theorem fib_mat_unit_orderOf : orderOf fib_mat_unit = 24 := by
  rw [orderOf_eq_iff (by norm_num : 0 < 24)]
  refine РЪеfib_mat_unit_pow_24, fun m hm24 hm1 heq => ?_РЪЕ
  exact fib_mat_unit_order_exact РЪеm, hm24РЪЕ (Nat.pos_iff_ne_zero.mp hm1) heq

-- ============================================================================
-- CYCLIC SUBGROUP РЪеFРЪЕ
-- ============================================================================

/-- **The cyclic subgroup `РЪеFРЪЕ` has exactly 24 elements** (cert [128] / [126]).

    By `orderOf_eq_card_zpowers`, the cardinality of the subgroup generated
    by `F` equals the multiplicative order of `F`. -/
theorem fib_mat_zpowers_card :
    Fintype.card РєЦ(Subgroup.zpowers fib_mat_unit) = 24 := by
  rw [Fintype.card_zpowers]
  exact fib_mat_unit_orderOf

/-- **РЪеFРЪЕ is a cyclic group** (trivially: generated by a single element).

    Any subgroup of the form `zpowers g` is cyclic Рђћ generated by `g` itself. -/
theorem fib_mat_zpowers_isCyclic : IsCyclic РєЦ(Subgroup.zpowers fib_mat_unit) :=
  Subgroup.isCyclic_zpowers fib_mat_unit
