{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QA_NEIGHBORHOOD_SUFFICIENCY_CERT.v1",
  "description": "v1.1: adds dominance_result enum (DOMINANT / FAILS_BOUNDARY_CONTAMINATION / INCONCLUSIVE) and boundary_metrics. Backward-compatible: v1 fixtures omit these fields.",
  "type": "object",
  "required": ["schema_version", "dataset", "classifier", "split_protocol", "seed", "generators", "metrics", "dominance", "digests"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "enum": ["QA_NEIGHBORHOOD_SUFFICIENCY_CERT.v1", "QA_NEIGHBORHOOD_SUFFICIENCY_CERT.v1.1"]},
    "dataset": {"type": "string"},
    "classifier": {"type": "string"},
    "split_protocol": {"type": "string"},
    "seed": {"type": "integer"},
    "generators": {
      "type": "object",
      "required": ["spec", "patch"],
      "additionalProperties": false,
      "properties": {
        "spec": {
          "type": "object",
          "required": ["type", "dim"],
          "properties": {
            "type": {"type": "string"},
            "dim": {"type": "integer", "minimum": 1}
          }
        },
        "patch": {
          "type": "object",
          "required": ["type", "radius_values", "feature_dim"],
          "properties": {
            "type": {"type": "string"},
            "radius_values": {"type": "array", "items": {"type": "integer", "minimum": 1}, "minItems": 1},
            "feature_dim": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["spec", "patch", "minimal_radius", "failure_mode"],
      "additionalProperties": false,
      "properties": {
        "spec": {
          "type": "object",
          "required": ["oa"],
          "additionalProperties": true,
          "properties": {
            "oa": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "aa": {"type": ["number", "null"]},
            "kappa": {"type": ["number", "null"]}
          }
        },
        "patch": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["oa"],
            "properties": {
              "oa": {"type": "number", "minimum": 0.0, "maximum": 1.0},
              "aa": {"type": ["number", "null"]},
              "kappa": {"type": ["number", "null"]}
            }
          }
        },
        "minimal_radius": {"type": "integer", "minimum": 1},
        "failure_mode": {
          "type": "string",
          "enum": ["BOUNDARY_CONTAMINATION", "INSUFFICIENT_CONTEXT", "NONE", "BOUNDARY_CONTAMINATION_DOMINATES"]
        }
      }
    },
    "dominance": {
      "type": "object",
      "required": ["patch_dominates_spec", "plateau_tolerance_pp"],
      "additionalProperties": false,
      "properties": {
        "patch_dominates_spec": {"type": "boolean"},
        "plateau_tolerance_pp": {"type": "number", "minimum": 0.0}
      }
    },
    "dominance_result": {
      "type": "string",
      "enum": ["DOMINANT", "FAILS_BOUNDARY_CONTAMINATION", "INCONCLUSIVE"]
    },
    "boundary_metrics": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "fragmentation_proxy": {"type": "number"},
        "thin_region_proxy": {"type": "number"},
        "expected_fail_type": {"type": "string", "enum": ["BOUNDARY_CONTAMINATION_DOMINATES"]},
        "notes": {"type": "string"}
      }
    },
    "digests": {
      "type": "object",
      "required": ["canonical_sha256"],
      "additionalProperties": false,
      "properties": {
        "canonical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
