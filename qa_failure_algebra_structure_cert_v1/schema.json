{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "QA_FAILURE_ALGEBRA_STRUCTURE_CERT.v1.schema.json",
  "title": "QA Failure Algebra Structure Certificate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cert_id",
    "created_utc",
    "carrier",
    "leq",
    "join_table",
    "compose_table",
    "unit",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "QA_FAILURE_ALGEBRA_STRUCTURE_CERT.v1"
    },
    "cert_id": {
      "type": "string",
      "minLength": 6
    },
    "created_utc": {
      "type": "string",
      "minLength": 10
    },
    "carrier": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "leq": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "a",
          "b"
        ],
        "properties": {
          "a": {
            "type": "string"
          },
          "b": {
            "type": "string"
          }
        }
      }
    },
    "join_table": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "a",
          "b",
          "join"
        ],
        "properties": {
          "a": {
            "type": "string"
          },
          "b": {
            "type": "string"
          },
          "join": {
            "type": "string"
          }
        }
      }
    },
    "compose_table": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "a",
          "b",
          "comp"
        ],
        "properties": {
          "a": {
            "type": "string"
          },
          "b": {
            "type": "string"
          },
          "comp": {
            "type": "string"
          }
        }
      }
    },
    "unit": {
      "type": "string",
      "minLength": 1
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "violations",
        "invariant_diff_map"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "gate",
              "fail_type",
              "path",
              "reason"
            ],
            "properties": {
              "gate": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "fail_type": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "invariant_diff_map": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "entries",
            "rollup_sha256"
          ],
          "properties": {
            "entries": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "gate",
                  "fail_type",
                  "path",
                  "reason"
                ],
                "properties": {
                  "gate": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "fail_type": {
                    "type": "string",
                    "minLength": 1
                  },
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reason": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "rollup_sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        }
      }
    }
  }
}
