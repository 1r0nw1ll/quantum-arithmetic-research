{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "QA_MATH_COMPILER_KERNEL_TRACE_MANIFEST.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "toolchain_id", "cases"],
  "properties": {
    "schema_id": {
      "const": "QA_MATH_COMPILER_KERNEL_TRACE_MANIFEST.v1"
    },
    "toolchain_id": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "source",
          "expected_status",
          "artifact_dir"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "expected_status": {
            "enum": ["SUCCESS", "FAIL"]
          },
          "proof_method": {
            "type": "string",
            "minLength": 1
          },
          "fail_type": {
            "type": "string",
            "minLength": 1
          },
          "diagnostic_pattern": {
            "type": "string",
            "minLength": 1
          },
          "artifact_dir": {
            "type": "string",
            "minLength": 1
          },
          "lake_project": {
            "type": "string",
            "minLength": 1
          },
          "upstream_declaration": {
            "type": "string",
            "minLength": 1
          },
          "trace_before_imports": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
