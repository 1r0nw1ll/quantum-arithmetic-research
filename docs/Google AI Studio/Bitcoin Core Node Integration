7BITCOIN_RPC_USER\u0027, \u0027your_rpc_username\u0027)\nRPC_PASSWORD \u003d os.environ.get(\u0027BITCOIN_RPC_PASSWORD\u0027, \u0027your_rpc_password\u0027)\nRPC_HOST \u003d os.environ.get(\u0027BITCOIN_RPC_HOST\u0027, \u0027127.0.0.1\u0027)\nRPC_PORT \u003d int(os.environ.get(\u0027BITCOIN_RPC_PORT\u0027, 18332)) # Use 18332 for Testnet\n\n# ----------------------------------------------------------------------------\n# RPC Helper Function (from previous scripts)\n# ----------------------------------------------------------------------------\ndef call_rpc(method, params\u003d[]):\n    url \u003d f\"http://{RPC_HOST}:{RPC_PORT}\"\n    payload \u003d json.dumps({\n        \"jsonrpc\": \"1.0\",\n        \"id\": \"qa_miner_rpc_call\",\n        \"method\": method,\n        \"params\": params\n    })\n    headers \u003d {\u0027content-type\u0027: \u0027application/json\u0027}\n\n    try:\n        response \u003d requests.post(url, headers\u003dheaders, data\u003dpayload, auth\u003d(RPC_USER, RPC_PASSWORD))\n        response.raise_for_status()\n        rpc_response \u003d response.json()\n        if rpc_response.get(\u0027error\u0027) is not None:\n            raise Exception(f\"RPC Error calling \u0027{method}\u0027 with params {params}: {rpc_response[\u0027error\u0027]}\")\n        return rpc_response[\u0027result\u0027]\n    except requests.exceptions.RequestException as e:\n        raise Exception(f\"HTTP Request failed: {e}\")\n    except Exception as e:\n        raise Exception(f\"RPC call failed: {e}\")\n\n# ----------------------------------------------------------------------------\n# Fetch Block Header Data using RPC\n# ----------------------------------------------------------------------------\ndef fetch_block_header_rpc(height):\n    \"\"\"Fetches block header fields needed for mining from a specified height.\"\"\"\n    try:\n        block_hash \u003d call_rpc(\u0027getblockhash\u0027, [height])\n        block_data \u003d call_rpc(\u0027getblock\u0027, [block