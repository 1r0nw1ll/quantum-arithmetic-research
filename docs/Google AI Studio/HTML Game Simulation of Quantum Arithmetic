     }\n\n        // --- Update Display Function ---\n        function updateDisplay(initialQuNit, resultQuNit, measurement, harmonics) {\n            initialBOut.textContent \u003d initialQuNit.b;\n            initialEOut.textContent \u003d initialQuNit.e;\n            initialDOut.textContent \u003d initialQuNit.d;\n            initialAOut.textContent \u003d calculateInitialA(initialQuNit.b, initialQuNit.e, initialQuNit.d).toFixed(3); // Recalculate for display\n\n            outputB.textContent \u003d resultQuNit.b;\n            outputE.textContent \u003d resultQuNit.e;\n            outputD.textContent \u003d resultQuNit.d;\n            outputA.textContent \u003d resultQuNit.a.toFixed(3); // Format to 3 decimal places\n\n            measureA.textContent \u003d measurement.rounded_a;\n            measureRatio.textContent \u003d measurement.ratio;\n            measurePrime.textContent \u003d measurement.primeRootCheck ? \u0027Yes\u0027 : \u0027No\u0027;\n\n            // Update harmonics list\n            harmonicsList.innerHTML \u003d \u0027\u0027; // Clear previous harmonics\n            if (harmonics.length \u003e 0) {\n                harmonics.forEach(part \u003d\u003e {\n                    const li \u003d document.createElement(\u0027li\u0027);\n                    li.textContent \u003d part;\n                    harmonicsList.appendChild(li);\n                });\n            } else {\n                 harmonicsList.innerHTML \u003d \u0027\u003cli\u003eNone\u003c/li\u003e\u0027;\n            }\n        }\n\n\n        // --- Event Listener ---\n        runButton.addEventListener(\u0027click\u0027, () \u003d\u003e {\n            // 1. Get input values\n            const bVal \u003d parseInt(inputB.value, 10);\n            const eVal \u003d parseInt(inputE.value, 10);\n            const dVal \u003d parseInt(inputD.value, 10);\n\n            // Basic validation\n            if (isNaN(bVal) || isNaN(eVal) || isNaN(dVal)) {\n                alert(\"Please enter va