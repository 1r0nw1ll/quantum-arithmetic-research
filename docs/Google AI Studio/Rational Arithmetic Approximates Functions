 Each step is a \u0027thought process\u0027 that in\n           a real complex search (like a B-tree) would involve memory access.\"\"\"\n        h \u003d hashlib.sha256(key.encode()).hexdigest()\n        k_R, k_f \u003d int(h[:32], 16) % 24, int(h[32:], 16) % 24\n        \n        path \u003d [(k_R, k_f)]\n        while (k_R + k_f)**2 \u003c self.params[\u0027q_star\u0027]:\n            self.memory.access_count +\u003d 1 # Simulate communication for the next step\n            k_R_new \u003d (k_R + self.params[\u0027delta_R\u0027] + round(self.params[\u0027gamma\u0027] * k_f)) % 24\n            k_f_new \u003d (k_f + self.params[\u0027delta_f\u0027] - round(self.params[\u0027gamma\u0027] * k_R)) % 24\n            k_R, k_f \u003d k_R_new, k_f_new\n            path.append((k_R, k_f))\n            \n        final_address \u003d k_R * 24 + k_f\n        return final_address, path\n\n    def insert(self, key, value):\n        address, path \u003d self._get_address(key)\n        self.memory.write(address, value)\n        return len(path) - 1\n\n    def search(self, key):\n        address, path \u003d self._get_address(key)\n        value \u003d self.memory.read(address)\n        return value, len(path) - 1\n\nclass QAPIMemoryChip(Memory):\n    \"\"\"A \u0027smart\u0027 memory chip with a built-in QA simulation engine.\"\"\"\n    def __init__(self, name\u003d\"QA-PIM\"):\n        super().__init__(name)\n        self.params \u003d {\u0027delta_R\u0027: 3, \u0027delta_f\u0027: -2, \u0027gamma\u0027: 0.05, \u0027q_star\u0027: 484}\n        self.last_internal_path \u003d []\n\n    def _internal_compute_address(self, key):\n        \"\"\"The simulation runs entirely inside the memory chip.\"\"\"\n        h \u003d hashlib.sha256(key.encode()).hexdigest()\n        k_R, k_f \u003d int(h[:32], 16) % 24, int(h[32:], 16) % 24\n        \n        path \u003d [(k_R, k_f)]\n        while (k_R + k_f)**2 \u003c self.params[\u0027q_star\u0027]:\n            k_R_new \u003d (k_R + self.params[\u0027delta_R\u0027] + round(self.params[\u0027gamma\u0027] * k_f)) % 24\n            k_f_new \u003d (k_f + self.params[\u0027delta_f\u0027] - round(self.params[\u0027gamma\u0027] * k_R)) % 24\n            k_R, k_f \u003d k_R_new, k_f_new\n            path.append((k_R, k_f))\n            \n        self.last_internal_path \u003d path\n        return k_R * 24 + k_f\n\n    def execute_search(self, key):\n        self.access_count +\u003d 1\n        address \u003d self._internal_compute_address(key)\n        return self.memory.get(address, None)\n        \n    def execute_insert(self, key, value):\n        self.access_count +\u003d 1\n        address \u003d self._internal_compute_address(key)\n        self.memory[address] \u003d value\n\n# --- Comprehensive Demo ---\n\ndef run_comprehensive_demo():\n    # 1. Define sample data and systems\n    sample_data \u003d {\n        \"Rosetta\": \"Unified scaling law data.\",\n        \"Cryptography\": \"A very secret key.\",\n        \"QANumber\": \"The fundamental atom of the system.\",\n        \"FractalGraph\": \"The world/lattice for QA.\",\n        \"NonExistentKey\": \"This value will not be found.\"\n    }\n    keys_to_insert \u003d list(sample_data.keys())[:-1]\n    keys_to_search \u003d list(sample_data.keys())\n\n    vn_mem \u003d Memory(name\u003d\"Dumb RAM\")\n    vn_cpu \u003d VonNeumannCPU(vn_mem)\n    pim_mem \u003d QAPIMemoryChip()\n    \n    report_data \u003d []\n\n    # 2. Run INSERT operations\n    print(\"--- Phase 1: INSERT Operations ---\")\n    for key in keys_to_insert:\n        value \u003d sample_data[key]\n        \n        # Von Neumann\n        vn_mem.access_count \u003d 0\n        vn_steps \u003d vn_cpu.insert(key, value)\n        \n        # PIM\n        pim_mem.access_count \u003d 0\n        pim_mem.execute_insert(key, value)\n        pim_steps \u003d len(pim_mem.last_internal_path) - 1\n        \n        report_data.append([\"Insert\", key, vn_steps, vn_mem.access_count, pim_steps, pim_mem.access_count])\n\n    # 3. Run SEARCH operations\n    print(\"\\n--- Phase 2: SEARCH Operations ---\")\n    for key in keys_to_search:\n        \n        # Von Neumann\n        vn_mem.access_count \u003d 0\n        _, vn_steps \u003d vn_cpu.search(key)\n        \n        # PIM\n        pim_mem.access_count \u003d 0\n        pim_mem.execute_search(key)\n        pim_steps \u003d len(pim_mem.last_internal_path) - 1\n        \n        report_data.append([\"Search\", key, vn_steps, vn_mem.access_count, pim_steps, pim_mem.access_count])\n\n    # 4. Display the detailed report\n    df_report \u003d pd.DataFrame(report_data, columns\u003d[\n        \"Operation\", \"Key\", \n        \"VN Sim Steps\", \"VN Bus Traffic\", \n        \"PIM Internal Steps\", \"PIM Bus Traffic\"\n    ])\n    \n    print(\"\\n\" + \"\u003d\"*80)\n    print(\"                COMPREHENSIVE PERFORMANCE REPORT\")\n    print(\"\u003d\"*80)\n    print(df_report.to_string())\n    print(\"\u003d\"*80)\n\n    # 5. Final Analysis\n    total_vn_traffic \u003d df_report[\"VN Bus Traffic\"].sum()\n    total_pim_traffic \u003d df_report[\"PIM Bus Traffic\"].sum()\n    efficiency_gain \u003d total_vn_traffic / total_pim_traffic\n    \n    print(\"\\n--- FINAL ANALYSIS ---\")\n    print(f\"Total Von Neumann Bus Traffic: {total_vn_traffic} interactions\")\n    print(f\"Total QA-PIM Bus Traffic:      {total_pim_traffic} interactions\")\n    print(f\"\\nOverall Efficiency Gain of QA-PIM: {efficiency_gain:.2f}x\")\n    print(\"\u003d\"*80)\n    \n# --- Execute the Demo ---\nrun_comprehensive_demo()\n```\n\n### **Analysis of the Expected Comprehensive Output**\n\nWhen you run this script, it will produce a detailed, table-formatted report followed by a final summary. It will look similar to this:\n\n```\n--- Phase 1: INSERT Operations ---\n--- Phase 2: SEARCH Operations ---\n\n\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d