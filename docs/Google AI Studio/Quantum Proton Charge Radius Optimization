ke the updates much smaller and more gentle. We can simulate a fractional learning rate using our fixed-point arithmetic.\n\n---\n\n### **Corrected `train_hilstm.py` with a Stable Learning Rate**\n\nHere is the updated training script. I have made only **two small but critical changes** to the `train_integer_lstm` function to implement a smaller, more stable learning rate.\n\n```python\n#!/usr/bin/env python3\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom harmonic_integer_lstm import HarmonicIntegerLSTM, SCALE_FACTOR\n\n# \u003d\u003d\u003d Dataset and Plotting Functions (Unchanged) \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\ndef generate_qa_dataset(num_samples\u003d1000, noise\u003d2):\n    data, targets \u003d [], []\n    for _ in range(num_samples):\n        b \u003d np.random.randint(1, 20)\n        e \u003d np.random.randint(1, 10)\n        d \u003d b + e + np.random.randint(-noise, noise + 1)\n        a \u003d b + 2 * e + np.random.randint(-noise, noise + 1)\n        sample \u003d np.array([b, e, d, a], dtype\u003dnp.int32)\n        target \u003d np.array([b, e, b + e, b + 2 * e], dtype\u003dnp.int32)\n        data.append(sample)\n        targets.append(target)\n    return np.array(data), np.array(targets)\n\ndef plot_convergence(direct_err_hist, total_err_hist):\n    epochs \u003d len(direct_err_hist)\n    plt.figure(figsize\u003d(12, 7))\n    plt.plot(range(epochs), direct_err_hist, label\u003d\u0027Direct Error (Raw)\u0027, color\u003d\u0027blue\u0027, alpha\u003d0.3)\n    plt.plot(range(epochs), total_err_hist, label\u003d\u0027Direct Error (Smoothed)\u0027, color\u003d\u0027black\u0027, linewidth\u003d2)\n    plt.title(\u0027Harmonic Integer LSTM (QA-Aware Head): Symbolic Error Convergence\u0027)\n    plt.xlabel(\u0027Training Epoch\u0027)\n    plt.ylabel(\u0027Average Integer Error\u0027)\n    plt.legend()\n    plt.grid(True, linestyle\u003d\u0027--\u0027, alpha\u003d0.6)\n    plot_filename \u003d \u0027convergence_plot_qa_aware.png\u0027\n    plt.savefig(plot_filename)\n    print(f\"\\n✅ Convergence plot saved to \u0027{plot_filename}\u0027\")\n\n# \u003d\u003d\u003d Training Loop (UPDATED WITH STABLE LEARNING RATE) \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\ndef train_integer_lstm(epochs\u003d100, seq_len\u003d4): # Removed lr from here\n    input_size \u003d 4\n    hidden_size \u003d 16\n    output_size \u003d 2\n    model \u003d HarmonicIntegerLSTM(input_size, hidden_size, output_size)\n    data, targets \u003d generate_qa_dataset(num_samples\u003d256)\n    direct_error_history \u003d []\n\n    # --- MODIFICATION 1: Define a fixed-point learning rate ---\n    # We\u0027ll use a learning rate of 1/16.\n    # lr\u003d1, scale\u003d4 means we multiply by 1 and then shift right by 4 bits.\n    learning_rate \u003d 1\n    learning_rate_scale \u003d 4 # This is the effective \"dampening\" factor\n    # --- END MODIFICATION ---\n\n    for epoch in range(epochs):\n        idx \u003d np.random.choice(len(data) - seq_len)\n        x_seq \u003d data[idx : idx + seq_len]\n        y_seq_full \u003d targets[idx : idx + seq_len]\n\n        predicted_be, caches, hidden_states \u003d model.forward(x_seq)\n\n        b_p, e_p \u003d predicted_be[:, 0], predicted_be[:, 1]\n        d_p \u003d b_p + e_p\n        a_p \u003d b_p + 2 * e_p\n        reconstructed_outputs \u003d np.stack([b_p, e_p, d_p, a_p], axis\u003d1)\n\n        full_error \u003d y_seq_full - reconstructed_outputs\n        err_b \u003d full_error[:, 0] + full_error[:, 2] + full_error[:, 3]\n        err_e \u003d full_error[:, 1] + full_error[:, 2] + 2 * full_error[:, 3]\n        error_signal_for_be \u003d np.stack([err_b, err_e], axis\u003d1)\n        \n        target_for_backward_pass \u003d predicted_be + error_signal_for_be\n        \n        # --- MODIFICATION 2: Use the new scale factor in the backward pass ---\n        model.backward(predicted_be, target_for_backward_pass, caches, hidden_states,\n                       learning_rate\u003dlearning_rate,\n                       lambda_struct\u003d0,\n                       scale\u003dSCALE_FACTOR + learning_rate_scale) # Add scales together\n        # --- END MODIFICATION ---\n\n        direct_err \u003d np.abs(full_error).mean()\n        direct_error_history.append(direct_err)\n\n        if epoch % 100 \u003d\u003d 0:\n            print(f\"Epoch {epoch:04d}: ⟨Direct Error⟩\u003d{direct_err:.3f}\")\n\n    return model, direct_error_history\n\n# \u003d\u003d\u003d Run Training \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\nif __name__ \u003d\u003d \"__main__\":\n    print(\"\u003d\u003d\u003d Harmonic Integer LSTM Training (QA-Aware Head) \u003d\u003d\u003d\")\n    num_epochs \u003d 3000\n    model, direct_hist \u003d train_integer_lstm(epochs\u003dnum_epochs) # lr removed from call\n    smoothed_hist \u003d np.convolve(direct_hist, np.ones(50)/50, mode\u003d\u0027same\u0027)\n    print(f\"\\nEpoch {num_epochs-1:04d}: ⟨Final Direct Error⟩\u003d{direct_hist[-1]:.3f}\")\n    print(\"\\n✅ Training complete.\")\n    plot_convergence(direct_hist, smoothed_hist)\n```\n\n### **What to Expect Now**\n\nWhen you run this corrected script, the learning updates will be much smaller and more stable. You should now see the `Direct Error` begin to converge properly, resulting in a much lower final error and a meaningful downward trend in the convergence plot. This will confirm that the QA-Aware architecture is indeed superior, once the learning dynamics are correctly stabilized.",
