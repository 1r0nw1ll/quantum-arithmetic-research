n range(height):\n                img_array[i, :] \u003d int(255 * (i / height))\n        elif pattern_type \u003d\u003d \u0027random_squares\u0027:\n            num_squares \u003d random.randint(1, 5)\n            for _ in range(num_squares):\n                sq_size \u003d random.randint(self.patch_size // 2, self.patch_size * 2)\n                r \u003d random.randint(0, height - sq_size)\n                c \u003d random.randint(0, width - sq_size)\n                color \u003d random.randint(0, 255)\n                img_array[r:r+sq_size, c:c+sq_size] \u003d color\n\n        return Image.fromarray(img_array)\n\n    def extract_patches(self, image):\n        \"\"\"Extracts patches from an image.\"\"\"\n        img_array \u003d np.array(image.convert(\u0027L\u0027)) # Convert to grayscale\n        h, w \u003d img_array.shape\n        patches \u003d []\n        for r in range(0, h - self.patch_size + 1, self.stride):\n            for c in range(0, w - self.patch_size + 1, self.stride):\n                patch \u003d img_array[r:r+self.patch_size, c:c+self.patch_size]\n                patches.append(patch)\n        return patches\n\n    def get_qa_features_from_patch(self, patch):\n        \"\"\"\n        Extracts QA features from a single image patch.\n        Applies integer DFT and mod-24 residue histograms.\n        \"\"\"\n        flat_patch \u003d patch.flatten().tolist()\n        \n        features \u003d []\n        \n        # Integer DFT on patch\n        dft_features \u003d self.qa_core.integer_dft(np.array(flat_patch))\n        features.extend(dft_features)\n\n        # Mod-24 residue histogram of patch pixel values\n        if self.qa_core.use_mod24:\n            residues \u003d [self.qa_core.mod24_residue_embedding(int(x)) for x in flat_patch]\n            residue_counts \u003d Counter(residues)\n            # Create a fixed-size vector for residues (-11 to 11, plus 0)\n            residue_hist \u003d np.zeros(24) \n            for r, count in residue_counts.items():\n                if r !\u003d 0:\n                    idx \u003d (r + 11) % 24 # Map -11 to 0, -1 to 10, 1 to 12, 11 to 22\n                    if idx \u003e\u003d 0 and idx \u003c 24:\n                        residue_hist[idx] \u003d count\n            features.extend(residue_hist)\n        \n        return np.array(features)\n\n    def process_image_for_qa_features(self, image):\n        \"\"\"Processes an entire image to get aggregated QA features.\"\"\"\n        patches \u003d self.extract_patches(image)\n        all_patch_features \u003d []\n        for patch in patches:\n            patch_features \u003d self.get_qa_features_from_patch(patch)\n            all_patch_features.append(patch_features)\n        \n        if not all_patch_features:\n            return np.array([])\n        \n        # Aggregate features (e.g., mean, max, or concatenate if few patches)\n        # For simplicity, we\u0027ll average the features across patches.\n        # In a real model, this would be fed into a pooling layer or attention.\n        aggregated_features \u003d np.mean(all_patch_features, axis\u003d0)\n        return aggregated_features\n\n    def dry_run(self):\n        \"\"\"Runs a dry-run with synthetic images.\"\"\"\n        self.eval_utils.logger.info(f\"Starting ImageNet QA Features dry-run with {self.max_images} synthetic images.\")\n        \n        all_image_features \u003d []\n        \n        for i in range(self.max_images):\n            self.eval_utils.logger.info(f\"\\n--- Synthetic Image {i+1} ---\")\n            synthetic_image \u003d self.generate_synthetic_image()\n            \n            self.eval_utils.logger.info(f\"Generated synthetic image (size: {synthetic_image.size}, mode: {synthetic_image.mode})\")\n            \n            qa_features \u003d self.process_image_for_qa_features(synthetic_image)\n            self.eval_utils.logger.info(f\"Extracted QA Features (length {len(qa_features)}, first 10): {qa_features[:10]}...\")\n            \n            all_image_features.append(qa_features)\n            \n            self.eval_utils.log_result(f\"ImageNet_Synthetic_Image_{i+1}\", {\n                \"image_size\": synthetic_image.size,\n                \"num_patches\": len(self.extract_patches(synthetic_image)),\n                \"qa_features_sample\": qa_features[:5].tolist() # Log a sample\n            })\n        \n        self.eval_utils.logger.info(f\"\\nSuccessfully processed {len(all_image_features)} synthetic images.\")\n        if all_image_features:\n            self.eval_utils.logger.info(f\"Aggregated features shape: {np.array(all_image_features).shape}\")\n        self.eval_utils.logger.info(\"Dry-run complete. QA features generated for synthetic images.\")\n\n    def run_full_evaluation(self):\n        \"\"\"\n        Runs evaluation on actual ImageNet dataset images.\n        (This part is a placeholder and needs actual ImageNet dataset loading and model training logic)\n        \"\"\"\n        if not self.imagenet_dir or not os.path.exists(self.imagenet_dir):\n            self.eval_utils.logger.error(f\"ImageNet directory not found: {self.imagenet_dir}. Cannot run full evaluation.\")\n            return\n\n        self.eval_utils.logger.info(f\"Starting full ImageNet QA Features extraction from {self.imagenet_dir} (placeholder).\")\n        \n        # For ImageNet, you\u0027d typically load images, extract features,\n        # and then train a light head (logreg/MLP) or adapter.\n        # This is a conceptual loop.\n        \n        # For now, just a message indicating where to plug in.\n        self.eval_utils.logger.info(\"To run full evaluation, implement ImageNet dataset loading here.\")\n        self.eval_utils.logger.info(\"You would load images, extract QA features, and then train a classification head.\")\n        self.eval_utils.logger.info(\"Metrics: top-1 accuracy, robustness deltas on ImageNet-A/O.\")\n\n\ndef load_config(config_path\u003d\"config.json\"):\n    \"\"\"Loads configuration from a JSON file.\"\"\"\n    if not os.path.exists(config_path):\n        print(f\"Error: Config file not found at {config_path}. Please copy config.example.json to config.json and edit.\")\n        exit(1)\n    with open(config_path, \u0027r\u0027) as f:\n        return json.load(f)\n\nif __name__ \u003d\u003d \"__main__\":\n    parser \u003d argparse.ArgumentParser(description\u003d\"ImageNet QA Features Runner\")\n    parser.add_argument(\"--dry_run\", action\u003d\"store_true\", help\u003d\"Run a dry-run with synthetic data.\")\n    args \u003d parser.parse_args()\n\n    config \u003d load_config()\n    runner \u003d ImageNetQAFeatures(config)\n\n    if args.dry_run:\n        runner.dry_run()\n    else:\n        runner.run_full_evaluation() # This will currently just print a placeholder message\n\n```\n\n---\n\n### `config.example.json`\n\n```json\n{\n  \"paths\": {\n    \"arc_dir\": \"/path/to/ARC/\",\n    \"gsm8k_file\": \"/path/to/gsm8k/train.jsonl\",\n    \"math_dir\": \"/path/to/MATH/\",\n    \"humaneval_file\": \"/path/to/HumanEval.jsonl\",\n    \"imagenet_dir\": \"/path/to/imagenet/\"\n  },\n  \"output_dir\": \"./outputs\",\n  \"imagenet\": {\n    \"patch_size\": 16,\n    \"stride\": 16,\n    \"max_images\": 16\n  },\n  \"qa\": {\n    \"fft_window\": 32,\n    \"use_mod24\": true\n  }\n}\n```\n\n---\n\n### Remaining `gsm8k_runner.py` (continuation)\n\n```python\n            elif i \u003d\u003d 6: ref_answer \u003d 1.0 # 1/2 * 2 \u003d 1\n\n            predictions.append(solution)\n            references.append(ref_answer)\n\n            self.eval_utils.log_result(f\"GSM8K_Synthetic_Problem_{i+1}\", {\n                \"problem_text\": problem_text,\n                \"parsed_problem\": parsed_problem,\n                \"qa_solution\": solution,\n                \"reference_answer\": ref_answer\n            })\n\n        summary \u003d self.eval_utils.summarize_math_metrics(predictions, references, \"GSM8K_DryRun\")\n        self.eval_utils.logger.info(f\"GSM8K Dry-Run Summary: {summary}\")\n\n    def load_gsm8k_data(self, file_path, num_samples\u003dNone):\n        \"\"\"Loads GSM8K data from a JSONL file.\"\"\"\n        problems \u003d []\n        if not os.path.exists(file_path):\n            self.eval_utils.logger.error(f\"GSM8K file not found: {file_path}\")\n            return problems\n        \n        with open(file_path, \u0027r\u0027) as f:\n            for i, line in enumerate(f):\n                if num_samples is not None and i \u003e\u003d num_samples:\n                    break\n                problems.append(json.loads(line))\n        return problems\n\n    def extract_answer_from_gsm8k_solution(self, solution_string):\n        \"\"\"\n        Extracts the final numerical answer from a GSM8K solution string.\n        GSM8K solutions typically end with \u0027#### X\u0027.\n        \"\"\"\n        match \u003d re.search(r\u0027#### (\\-?\\d+\\.?\\d*|\\-?\\d*\\/\\d*)\u0027, solution_string)\n        if match:\n            return match.group(1)\n        return None\n\n    def run_full_evaluation(self, num_samples\u003dNone):\n        \"\"\"\n        Runs evaluation on actual GSM8K dataset.\n        \"\"\"\n        if not self.gsm8k_file:\n            self.eval_utils.logger.error(\"GSM8K file path not configured. Cannot run full evaluation.\")\n            return\n\n        self.eval_utils.logger.info(f\"Starting full GSM8K evaluation from {self.gsm8k_file}.\")\n        \n        dataset \u003d self.load_gsm8k_data(self.gsm8k_file, num_samples)\n        if not dataset:\n            self.eval_utils.logger.error(\"No GSM8K data loaded. Exiting full evaluation.\")\n            return\n\n        predictions \u003d []\n        references \u003d []\n\n        for i, entry in enumerate(dataset):\n            problem_text \u003d entry[\u0027question\u0027]\n            reference_solution \u003d entry[\u0027answer\u0027]\n            reference_answer \u003d self.extract_answer_from_gsm8k_solution(reference_solution)\n\n            if reference_answer is None:\n                self.eval_utils.logger.warning(f\"Could not extract reference answer for problem {i+1}. Skipping.\")\n                continue\n\n            # In a real scenario, you would parse the problem more robustly\n            # and apply your QA-based symbolic solver or ML model here.\n            # For this placeholder, we\u0027ll use the dry-run solver.\n            parsed_problem \u003d self.parse_word_problem_dry_run(problem_text)\n            predicted_answer \u003d self.solve_with_qa_tuples(parsed_problem) # This is still very basic\n\n            predictions.append(predicted_answer)\n            references.append(reference_answer)\n\n            self.eval_utils.log_result(f\"GSM8K_Problem_{i+1}\", {\n                \"question\": problem_text,\n                \"predicted_answer\": predicted_answer,\n                \"reference_answer\": reference_answer\n            })\n            \n            if (i + 1) % 100 \u003d\u003d 0:\n                self.eval_utils.logger.info(f\"Processed {i+1} GSM8K problems.\")\n\n        summary \u003d self.eval_utils.summarize_math_metrics(predictions, references, \"GSM8K_Full_Evaluation\")\n        self.eval_utils.logger.info(f\"GSM8K Full Evaluation Summary: {summary}\")\n\n\ndef load_config(config_path\u003d\"config.json\"):\n    \"\"\"Loads configuration from a JSON file.\"\"\"\n    if not os.path.exists(config_path):\n        print(f\"Error: Config file not found at {config_path}. Please copy config.example.json to config.json and edit.\")\n        exit(1)\n    with open(config_path, \u0027r\u0027) as f:\n        return json.load(f)\n\nif __name__ \u003d\u003d \"__main__\":\n    parser \u003d argparse.ArgumentParser(description\u003d\"GSM8K Benchmark Runner\")\n    parser.add_argument(\"--dry_run\", action\u003d\"store_true\", help\u003d\"Run a dry-run with synthetic data.\")\n    parser.add_argument(\"--num_samples\", type\u003dint, default\u003dNone, help\u003d\"Number of samples to process for full evaluation.\")\n    args \u003d parser.parse_args()\n\n    config \u003d load_config()\n    runner \u003d GSM8KRunner(config)\n\n    if args.dry_run:\n        runner.dry_run()\n    else:\n        runner.run_full_evaluation(num_samples\u003dargs.num_samples)\n\n```\n\n---\n\n### `math_runner.py`\n\n```python\nimport json\nimport os\nimport argparse\nimport re\nfrom qa_core import QACore\nfrom eval_utils import EvalUtils\n\nclass MATHRunner:\n    def __init__(self, config):\n        self.config \u003d config\n        self.qa_core \u003d QACore(fft_window\u003dconfig[\u0027qa\u0027][\u0027fft_window\u0027], use_mod24\u003dconfig[\u0027qa\u0027][\u0027use_mod24\u0027])\n        self.eval_utils \u003d EvalUtils(output_dir\u003dconfig[\u0027output_dir\u0027])\n        self.math_dir \u003d config[\u0027paths\u0027].get(\u0027math_dir\u0027)\n\n    def parse_math_problem_dry_run(self, problem_text):\n        \"\"\"\n        A very simple dry-run parser for MATH problems.\n        This is a placeholder for a more sophisticated symbolic parser.\n        It attempts to extract numbers and identify a basic operation.\n        \"\"\"\n        numbers \u003d [float(s) for s in re.findall(r\u0027\\d+\\.?\\d*|\\d*\\.\\d+\u0027, problem_text)]\n        \n        # Simple keyword detection for operation\n        operation \u003d None\n        if \"sum\" in problem_text or \"+\" in problem_text:\n            operation \u003d \"add\"\n        elif \"difference\" in problem_text or \"-\" in problem_text:\n            operation \u003d \"subtract\"\n        elif \"product\" in problem_text or \"*\" in problem_text:\n            operation \u003d \"multiply\"\n        elif \"quotient\" in problem_text or \"/\" in problem_text or \"divide\" in problem_text:\n            operation \u003d \"divide\"\n        elif \"power\" in problem_text or \"^\" in problem_text:\n            operation \u003d \"power\"\n        \n        return {\"numbers\": numbers, \"operation\": operation, \"text\": problem_text}\n\n    def solve_with_qa_tuples_and_symbolic_solver(self, parsed_problem):\n        \"\"\"\n        Solves a parsed problem using canonical QA tuples and a conceptual\n        \"small symbolic solver\" for more complex operations.\n        This is a highly simplified demonstration.\n        \"\"\"\n        numbers \u003d parsed_problem[\u0027numbers\u0027]\n        operation \u003d parsed_problem[\u0027operation\u0027]\n        \n        if not numbers:\n            return \"Error: No numbers found.\"\n\n        # Prioritize QA tuple for simple arithmetic if applicable\n        if operation \u003d\u003d \"add\" and len(numbers) \u003e\u003d 2:\n            b, e \u003d numbers[0], numbers[1]\n            qa_tuple, _ \u003d self.qa_core.canonical_qa_tuple(b, e)\n            return qa_tuple[2] # d \u003d b+e\n        elif operation \u003d\u003d \"subtract\" and len(numbers) \u003e\u003d 2:\n            return numbers[0] - numbers[1]\n        elif operation \u003d\u003d \"multiply\" and len(numbers) \u003e\u003d 2:\n            return numbers[0] * numbers[1]\n        elif operation \u003d\u003d \"divide\" and len(numbers) \u003e\u003d 2:\n            if numbers[1] !\u003d 0:\n                return numbers[0] / numbers[1]\n            else:\n                return \"Error: Division by zero.\"\n        elif operation \u003d\u003d \"power\" and len(numbers) \u003e\u003d 2:\n            return numbers[0] ** numbers[1]\n        else:\n            # Fallback to a \"small symbolic solver\" concept for more complex cases\n            # For this dry-run, it\u0027s just a placeholder.\n            if len(numbers) \u003e\u003d 2:\n                b, e \u003d numbers[0], numbers[1]\n                qa_tuple, _ \u003d self.qa_core.canonical_qa_tuple(b, e)\n                # Return \u0027a\u0027 as a potential \"answer\" or feature from QA\n                return qa_tuple[3] \n            elif len(numbers) \u003d\u003d 1:\n                return numbers[0]\n            return \"Could not solve with simple QA tuple or symbolic logic.\"\n\n    def dry_run(self, num_problems\u003d5):\n        \"\"\"Runs a dry-run with synthetic MATH-like problems.\"\"\"\n        self.eval_utils.logger.info(f\"Starting MATH dry-run with {num_problems} synthetic problems.\")\n        \n        synthetic_problems \u003d [\n            \"What is the sum of 15 and 23?\", # Add\n            \"Calculate the difference between 100 and 45.\", # Subtract\n            \"Find the product of 7 and 9.\", # Multiply\n            \"What is 25 divided by 5?\", # Divide\n            \"What is 2 to the power of 3?\", # Power\n            \"If x \u003d 5 and y \u003d 7, what is x + 2y?\", # Multi-step (will fail with simple parser)\n            \"Simplify the fraction 12/16.\", # Rational (will fail with simple parser)\n        ]\n        \n        predictions \u003d []\n        references \u003d []\n\n        for i in range(min(num_problems, len(synthetic_problems))):\n            problem_text \u003d synthetic_problems[i]\n            \n            self.eval_utils.logger.info(f\"\\n--- Synthetic MATH Problem {i+1} ---\")\n            self.eval_utils.logger.info(f\"Problem: {problem_text}\")\n\n            parsed_problem \u003d self.parse_math_problem_dry_run(problem_text)\n            self.eval_utils.logger.info(f\"Parsed: {parsed_problem}\")\n\n            solution \u003d self.solve_with_qa_tuples_and_symbolic_solver(parsed_problem)\n            self.eval_utils.logger.info(f\"QA/Symbolic Solution: {solution}\")\n\n            # Manual reference answers for dry-run\n            ref_answer \u003d None\n            if i \u003d\u003d 0: ref_answer \u003d 38.0\n            elif i \u003d\u003d 1: ref_answer \u003d 55.0\n            elif i \u003d\u003d 2: ref_answer \u003d 63.0\n            elif i \u003d\u003d 3: ref_answer \u003d 5.0\n            elif i \u003d\u003d 4: ref_answer \u003d 8.0\n            elif i \u003d\u003d 5: ref_answer \u003d \"19\" # 5 + 2*7 \u003d 19 (expected to fail with simple solver)\n            elif i \u003d\u003d 6: ref_answer \u003d \"3/4\" # Expected to fail with simple solver\n\n            predictions.append(solution)\n            references.append(ref_answer)\n\n            self.eval_utils.log_result(f\"MATH_Synthetic_Problem_{i+1}\", {\n                \"problem_text\": problem_text,\n                \"parsed_problem\": parsed_problem,\n                \"qa_symbolic_solution\": solution,\n                \"reference_answer\": ref_answer\n            })\n\n        summary \u003d self.eval_utils.summarize_math_metrics(predictions, references, \"MATH_DryRun\")\n        self.eval_utils.logger.info(f\"MATH Dry-Run Summary: {summary}\")\n\n    def load_math_data(self, math_dir, num_samples\u003dNone):\n        \"\"\"\n        Loads MATH dataset problems.\n        The MATH dataset is structured with subdirectories for different topics\n        (e.g., algebra, geometry) and then JSON files within.\n        This function will iterate through them.\n        \"\"\"\n        problems \u003d []\n        if not os.path.exists(math_dir):\n            self.eval_utils.logger.error(f\"MATH directory not found: {math_dir}\")\n            return problems\n\n        count \u003d 0\n        for root, _, files in os.walk(math_dir):\n            for file_name in files:\n                if file_name.endswith(\u0027.json\u0027):\n                    file_path \u003d os.path.join(root, file_name)\n                    try:\n                        with open(file_path, \u0027r\u0027) as f:\n                            problem_data \u003d json.load(f)\n                            problems.append(problem_data)\n                            count +\u003d 1\n                            if num_samples is not None and count \u003e\u003d num_samples:\n                                return problems\n                    except Exception as e:\n                        self.eval_uti