ntalalignment\u003d\u0027center\u0027, verticalalignment\u003d\u0027center\u0027, transform\u003dax.transAxes, fontsize\u003d8)\n            ax.axis(\u0027off\u0027)\n        \n        img_row_start +\u003d current_mod_rows\n\n    # Add metric plots below the image mosaic\n    metrics_df \u003d compute_phase_metrics(gather_all_data())\n    \n    # Quadrance Variance Plot\n    ax_q_var \u003d fig.add_subplot(gs[img_row_start, :total_cols]) # Span all columns\n    sns.barplot(x\u003d\"modulus\", y\u003d\"quadrance_variance\", data\u003dmetrics_df, ax\u003dax_q_var, palette\u003d\"viridis\")\n    ax_q_var.set_title(\"Quadrance Variance Across Moduli (Resonance Stability)\", fontsize\u003d10)\n    ax_q_var.set_xlabel(\"Modulus\")\n    ax_q_var.set_ylabel(\"Variance of Mean Q\")\n\n    # Euler Alignment Rate Plot\n    ax_euler \u003d fig.add_subplot(gs[img_row_start + 1, :total_cols]) # Span all columns\n    sns.lineplot(x\u003d\"modulus\", y\u003d\"euler_alignment_rate\", data\u003dmetrics_df, ax\u003dax_euler, marker\u003d\u0027o\u0027, color\u003d\u0027red\u0027)\n    ax_euler.set_title(\"Euler Line Alignment Rate\", fontsize\u003d10)\n    ax_euler.set_xlabel(\"Modulus\")\n    ax_euler.set_ylabel(\"Average Alignment Rate\")\n    ax_euler.set_ylim(0, 1.1) # Rates are between 0 and 1\n\n    fig.suptitle(\"QA × Chromogeometry × UHG Resonance Dashboard\", fontsize\u003d16, y\u003d1.02)\n    plt.tight_layout(rect\u003d[0, 0, 1, 0.98]) # Adjust layout to prevent suptitle overlap\n    output_path \u003d DASHBOARD_OUT / filename\n    plt.savefig(output_path, dpi\u003d200)\n    plt.close(fig)\n    print(f\"Dashboard saved to: {output_path}\")\n\n# ------------------------------------------------------------\n# 4. Main Dashboard Logic\n# ------------------------------------------------------------\ndef generate_dashboard():\n    print(\"Gathering data for dashboard...\")\n    full_df \u003d gather_all_data()\n    phase_metrics \u003d compute_phase_metrics(full_df)\n    \n    print(\"\\n--- Phase-Lock / Resonance Metrics ---\")\n    print(phase_metrics.to_string())\n    phase_metrics.to_csv(DASHBOARD_OUT / \"resonance_metrics_summary.csv\", index\u003dFalse)\n    print(f\"\\nSummary metrics saved to: {DASHBOARD_OUT / \u0027resonance_metrics_summary.csv\u0027}\")\n\n    # Gather image paths for mosaic\n    mod_images \u003d {}\n    for mod in (24,72,144):\n        image_paths \u003d sorted((ROOT/f\"mod{mod}\").glob(\"hyper_overlay_*.png\"))\n        if image_paths:\n            mod_images[mod] \u003d image_paths[:min(len(image_paths), 5)] # Limit to ~5 images per modulus for readability\n            print(f\"Found {len(mod_images[mod])} overlay images for mod {mod}\")\n        else:\n            print(f\"No overlay images found for mod {mod}\")\n\n    if mod_images:\n        print(\"\\nCreating image mosaic...\")\n        create_image_mosaic(mod_images, filename\u003d\"qa_resonance_dashboard.png\")\n    else:\n        print(\"\\nSkipping image mosaic generation: No overlay images found.\")\n\nif __name__ \u003d\u003d \"__main__\":\n    generate_dashboard()\n```\n\n---\n\n### 🚀 How to Use It\n\n1.  **Ensure previous steps have run:** You need to have executed `qa_mod_res_engine_hyperbolic.py` to generate the CSV files and overlay images for mod-24, mod-72, and mod-144. These outputs are expected in `/mnt/data/qa_mod_res_out_hyp/`.\n2.  **Save the new script:** Save the code above as `qa_hyperbolic_dashboard.py` in your working directory.\n3.  **Run the dashboard generator:**\n    ```bash\n    python qa_hyperbolic_dashboard.py\n    ```\n\n### 📊 What It Does\n\nThis script performs the following actions:\n\n*   **Loads Data:** It reads the `qa_full_modN_hyper.csv` files for each modulus (24, 72, 144) from the `ROOT` directory (`/mnt/data/qa_mod_res_out_hyp/`).\n*   **Computes Resonance Metrics:**\n    *   **Quadrance Variance:** A proxy for the stability or \"flatness\" of quadrance values across the tuples within a modulus. Lower variance might indicate higher resonance or stability.\n    *   **Spread Variance:** Similar to quadrance variance, but for spreads.\n    *   **Euler Alignment Rate:** The average rate at which Euler line collinearity and midpoint properties hold true across all tuples in a modulus (from `blue_euler`, `red_euler`, etc. columns). Higher rates indicate better adherence to Chromogeometric principles.\n    *   **UHG Cross-Law Residual:** A simplified measure of how well the UHG cross-law (proxied by `q12 + q23 - q31`) holds. Lower residuals suggest better UHG consistency.\n*   **Generates Summary CSV:** A `resonance_metrics_summary.csv` file is created in `./qa_hyperbolic_dashboard_output/` summarizing these metrics for each modulus.\n*   **Creates Image Mosaic:** It gathers up to 5 `hyper_overlay_*.png` images from each modulus\u0027s output directory. These are stitched together into a single, comprehensive `qa_resonance_dashboard.png` image.\n*   **Plots Comparative Metrics:** Bar plots for Quadrance Variance and a line plot for Euler Alignment Rate are included in the dashboard image, providing a visual comparison of these key resonance indicators across the different moduli.\n*   **Output Directory:** All dashboard outputs (summary CSV and the main PNG report) are saved to `./qa_hyperbolic_dashboard_output/`.\n\n### ✨ Expected Output Artifacts\n\n*   **`./qa_hyperbolic_dashboard_output/resonance_metrics_summary.csv`**: A CSV file containing the computed resonance metrics (quadrance variance, spread variance, Euler alignment rate, UHG cross-law residual) for each modulus.\n*   **`./qa_hyperbolic_dashboard_output/qa_resonance_dashboard.png`**: A large PNG image acting as the central report. It will feature:\n    *   A mosaic of selected hyperbolic overlay plots from each modulus.\n    *   A bar chart showing the \"Quadrance Variance Across Moduli\".\n    *   A line plot illustrating the \"Euler Line Alignment Rate\" across moduli.\n\nThis dashboard provides a comprehensive view 