re initialized as discrete integers\n        self.weight \u003d np.random.randint(INT_MIN, INT_MAX + 1, size\u003d(out_features, in_features), dtype\u003dnp.int32)\n        self.bias \u003d np.random.randint(INT_MIN, INT_MAX + 1, size\u003d(out_features,), dtype\u003dnp.int32)\n\n    def forward(self, x):\n        \"\"\" Performs integer matrix multiplication and adds bias. \"\"\"\n        # Standard dot product results in large integers\n        output \u003d np.dot(x, self.weight.T) + self.bias\n        # Scale down the result to maintain the fixed-point representation\n        # This is the integer equivalent of dividing by 2**SCALE_FACTOR\n        output \u003d output \u003e\u003e SCALE_FACTOR\n        # Clip the output to stay within our simulated integer range\n        return np.clip(output, INT_MIN, INT_MAX)\n\nclass IntegerActivations:\n    \"\"\" A collection of integer-based activation functions. \"\"\"\n    @staticmethod\n    def tanh(x):\n        \"\"\" Integer approximation of tanh. Clips the output to [-127, 127]. \"\"\"\n        # In a real implementation, this could be a more complex lookup table.\n        # For this scaffold, clipping simulates the saturation effect.\n        return np.clip(x, INT_MIN, INT_MAX)\n\n    @staticmethod\n    def sigmoid(x):\n        \"\"\" Integer approximation of sigmoid. Clips output to [0, 127]. \"\"\"\n        # This simulates the 0-to-1 range of sigmoid, scaled to our integer space.\n        return np.clip(x, 0, INT_MAX)\n\n# --- 2. The Harmonic Integer LSTM Cell ---\n\nclass HarmonicIntegerLSTMCell:\n    \"\"\" A single LSTM cell that operates entirely on integers. \"\"\"\n    def __init__(self, input_size, hidden_size):\n        self.hidden_size \u003d hidden_size\n        \n        # We combine the four gate transformations into a single linear layer for efficiency.\n        # This layer handles the input-to-hidden transformations for all four gates.\n        self.W \u003d IntegerLinear(input_size, hidden_size * 