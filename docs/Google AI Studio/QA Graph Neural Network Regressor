rtition\n    # by maximizing modularity within the graph\u0027s structure.\n    partition \u003d community_louvain.best_partition(G)\n    num_detected_communities \u003d len(set(partition.values()))\n    print(f\"\\nLouvain algorithm detected {num_detected_communities} distinct communities.\")\n\n    # Convert the partition dictionary into a prediction tensor for evaluation\n    predictions \u003d torch.tensor([partition[i] for i in range(data.num_nodes)], dtype\u003dtorch.long)\n    \n    # 3. Evaluate the Results\n    # The Les Misérables dataset in PyG does not have canonical ground truth labels\n    # in the same way as Karate Club. The primary result is the detection and\n    # visualization of the communities themselves. We can, however, still analyze the result.\n    print(\"\\n--- Results ---\")\n    print(\"The primary result is the set of communities found by the algorithm.\")\n    print(\"We can visually inspect the graph to see if these communities are meaningful.\")\n    \n    # We can print the members of each community for analysis\n    communities \u003d {i: [] for i in range(num_detected_communities)}\n    for node, comm_id in partition.items():\n        communities[comm_id].append(node)\n    \n    print(\"\\nDetected Communities (Node IDs):\")\n    for comm_id, members in sorted(communities.items()):\n        print(f\"  - Community {comm_id}: {members}\")\n\n    print(\"\\n--- Test Complete ---\")\n    print(\"\\n✅ SUCCESS: The structural analysis has successfully partitioned the social network.\")\n    print(\"This provides a second, independent validation of the QA paradigm.\")\n\n    # 4. Visualize the Community Partitions\n    print(\"\\nGenerating visualization...\")\n    pos \u003d nx.spring_layout(G, seed\u003d42) # Use a seed for a reproducible layout\n    colors \u003d [partition[i] for i in G.nodes()]\n    \n    plt.figure(figsize\u003d(16, 12))\n    nx.draw_networkx(G, pos, node_color\u003dcolors, with_labels\u003dTrue, \n               