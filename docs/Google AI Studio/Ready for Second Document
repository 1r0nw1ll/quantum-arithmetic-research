.model_selection import GridSearchCV, PredefinedSplit\nfrom sklearn.calibration import CalibratedClassifierCV\nfrom sklearn.metrics import brier_score_loss\nimport argparse\n\n# ----------------------------- Config -----------------------------\n\nCACHE_FILE \u003d \"pla_v2_cache.csv\"\nPARAMS_FILE \u003d \"pla_v2_params.json\"\nPLOT_FILE \u003d \"pla_v2_plot.png\"\nRESULTS_FILE \u003d \"pla_v2_results.csv\"\n\nPRIMARY_URL \u003d \"https://api.manifold.markets/v0/markets\"\nALT_URL \u003d \"https://manifold.markets/api/v0/markets\" # older path some envs prefer\n\nHEADERS \u003d {\n    \"User-Agent\": \"PLA-v2.0 (+forecasting-research; contact: dev@example.com)\",\n    \"Accept\": \"application/json\"\n}\n\n# Domains for classification\nDOMAINS \u003d [\"politics\", \"finance\", \"sports\", \"science\", \"tech\", \"art\", \"misc\"]\nDOMAIN_KEYWORDS \u003d {\n    \"politics\": [\"election\", \"vote\", \"president\", \"party\", \"government\", \"referendum\", \"ballot\"],\n    \"finance\": [\"stock\", \"market\", \"crypto\", \"bitcoin\", \"ethereum\", \"economy\", \"interest rate\", \"inflation\", \"currency\", \"dollar\"],\n    \"sports\": [\"sport\", \"game\", \"team\", \"match\", \"cup\", \"league\", \"win\", \"lose\"],\n    \"science\": [\"science\", \"research\", \"discovery\", \"ai\", \"quantum\", \"physics\", \"biology\", \"space\", \"fusion\"],\n    \"tech\": [\"tech\", \"ai\", \"software\", \"google\", \"apple\", \"microsoft\", \"startup\", \"web\", \"chip\"],\n    \"art\": [\"art\", \"movie\", \"film\", \"music\", \"album\", \"actor\", \"oscars\", \"grammy\"],\n}\n\n# ----------------------------- Utils ------------------------------\n\ndef log(msg: str):\n    print(msg, flush\u003dTrue)\n\ndef parse_args():\n    parser \u003d argparse.ArgumentParser(description\u003d\"Prophetic Logic Arena v2.0\")\n    parser.add_argument(\"--live\", action\u003d\"store_true\", help\u003d\"Run in live forecasting mode (unresolved events).\")\n    parser.add_argument(\"--offline\", action\u003d\"store_true\", help\u003d\"Force synthetic data generation.\")\n    parser.add_argument(\"--limit\", type\u003dint, default\u003d200, help\u003d\"Max number of market events to fetch.\")\n    return parser.parse_args()\n\ndef safe_request(url: str, params: Optional[Dict[str, Any]]\u003dNone, retries\u003d3, sleep\u003d1.5) -\u003e Optional[List[Dict[str, Any]]]:\n    params \u003d params or {}\n    for i in range(1, retries+1):\n        try:\n            r \u003d requests.get(url, headers\u003dHEADERS, params\u003dparams, timeout\u003d12)\n            if r.status_code \u003d\u003d 200:\n                return r.json()\n            else:\n                log(f\"[warn] {url} -\u003e HTTP {r.status_code}: {r.text[:140]}\")\n        except Exception as e:\n            log(f\"[warn] request error {i}/{retries}: {e.__class__.__name__}: {e}\")\n        time.sleep(sleep * i)\n    return None\n\ndef cache_save(df: pd.DataFrame, path: str \u003d CACHE_FILE):\n    df.to_csv(path, index\u003dFalse)\n    log(f\"[cache] saved {len(df)} rows -\u003e {path}\")\n\ndef cache_load(path: str \u003d CACHE_FILE) -\u003e Optional[pd.DataFrame]:\n    if os.path.exists(path):\n        try:\n            df \u003d pd.read_csv(path)\n            # Ensure proper dtypes for loaded cache\n            df[\u0027resolved\u0027] \u003d df[\u0027resolved\u0027].astype(bool)\n            df[\u0027outcome\u0027] \u003d pd.to_numeric(df[\u0027outcome\u0027], errors\u003d\u0027coerce\u0027)\n            df[\u0027p_market\u0027] \u003d pd.to_numeric(df[\u0027p_market\u0027], errors\u003d\u0027coerce\u0027)\n            log(f\"[cache] loaded {len(df)} rows from {path}\")\n            return df\n        except Exception as e:\n            log(f\"[warn] cache read failed: {e}\")\n            return None\n    return None\n\ndef synth_events(n: int \u003d 150) -\u003e pd.DataFrame:\n    \"\"\"Generate synthetic ‘market’ rows for offline mode.\"\"\"\n    rng \u003d np.random.default_rng(17)\n    probs \u003d np.clip(rng.normal(0.5, 0.2, size\u003dn), 0.02, 0.98)\n    resolved_mask \u003d rng.random(n) \u003c 0.65 # More resolved for historical mode\n    outcomes \u003d np.where(resolved_mask, rng.binomial(1, probs), np.nan)\n    \n    questions \u003d []\n    ids \u003d []\n    # Assign some questions with keywords to test domain mapping\n    for i in range(n):\n        q \u003d f\"Synth Q{i}: Will something happen?\"\n        if i % 5 \u003d\u003d 0: q \u003d f\"Synth Q{i}: Will this election be close?\"\n        elif i % 7 \u003d\u003d 0: q \u003d f\"Synth Q{i}: Will crypto price hit X?\"\n        elif i % 11 \u003d\u003d 0: q \u003d f\"Synth Q{i}: Team A vs Team B winner?\"\n        questions.append(q)\n        ids.append(f\"synth-{i}-{int(time.time()*1000) % 1000}\") # Add timestamp hash for unique ID\n    \n    df \u003d pd.DataFrame({\n        \"id\": ids,\n        \"question\": questions,\n        \"p_market\": probs,\n        \"resolved\": resolved_mask,\n        \"outcome\": outcomes\n    })\n    return df\n\n# ----------------------------- QA core ----------------------------\n\ndef qa_tuple(b: int, e: int) -\u003e Tuple[int, int, int, int]:\n    \"\"\"Generates the (b,e,d,a) tuple based on b and e.\"\"\"\n    d \u003d b + e\n    a \u003d b + 2 * e\n    return b, e, d, a\n\ndef qa_valid(b: int, e: int, d: int, a: int, tol\u003d1e-12) -\u003e bool:\n    \"\"\"Checks the inner ellipse law a^2 \u003d d^2 + 2de + e^2.\"\"\"\n    return abs(a*a - (d*d + 2*d*e + e*e)) \u003c tol\n\ndef qa_residue24(x: int) -\u003e int:\n    \"\"\"\n    24-normalised residue for values coprime to 24 (invertible mod 24),\n    otherwise mod 8 for consistent modular representation.\n    \"\"\"\n    if math.gcd(x, 24) \u003d\u003d 1:\n        return x % 24\n    return x % 8\n\ndef deterministic_be_from_id(s: str) -\u003e Tuple[int, int]:\n    \"\"\"\n    Generates stable (b,e) integers [1..12] for an event ID.\n    Ensures that the QA features are consistent for the same event across runs.\n    \"\"\"\n    # Use a stronger hash function if available, or just Python\u0027s hash\n    h \u003d abs(hash(s)) % (12 * 12)\n    b \u003d (h % 12) + 1\n    e \u003d (h // 12) + 1\n    return b, e\n\n# New: QA 4-component feature vector\nGOLDEN_RATIO \u003d (1 + math.sqrt(5)) / 2\n\ndef qa_feature_vector(b: int, e: int, tau: float \u003d 1.0) -\u003e Dict[str, float]:\n    \"\"\"\n    Generates a dictionary of QA harmonic features.\n    tau: temperature parameter to scale the confidence/spread of phase components.\n         tau \u003e 1 sharpens, tau \u003c 1 flattens.\n    \"\"\"\n    b24, e24 \u003d qa_residue24(b), qa_residue24(e)\n    \n    # 1. Icositetragonal Phase (Cos \u0026 Sin)\n    # The sum (b24+e24) maps to the 24-gon, its angle determines position.\n    # Scaled by tau for confidence.\n    angle_sum \u003d np.pi * (b24 + e24) / 12.0\n    cos_theta \u003d np.cos(angle_sum) / max(tau, 0.1) # Scale by tau\n    sin_theta \u003d np.sin(angle_sum) / max(tau, 0.1)\n    \n    # 2. Fractal Root Amplitude\n    # Derived from (b-e)/b related to golden ratio powers, normalized.\n    # Avoid division by zero if b\u003d0 (though b,e \u003e\u003d 1 here).\n    if b !\u003d 0:\n        fractal_exponent \u003d (b - e) / b\n        fractal_amp \u003d np.power(GOLDEN_RATIO, fractal_exponent)\n    else:\n        fractal_amp \u003d 1.0 # Default if b is somehow 0\n    fractal_amp \u003d np.tanh(fractal_amp - 1) # Normalize to approx [-1,1] around 0\n    \n    # 3. Mirror Plane Polarity\n    # Simple +/-1 based on parity, representing mirror symmetry.\n    mirror_parity \u003d float(-1 if (b + e) % 2 !\u003d 0 else 1)\n    \n    return {\n        \"q_cos_theta\": float(cos_theta),\n        \"q_sin_theta\": float(sin_theta),\n        \"q_fractal_amp\": float(fractal_amp),\n        \"q_mirror_parity\": mirror_parity,\n    }\n\n# ----------------------------- Scoring ----------------------------\n\ndef brier_score(preds: np.ndarray, outcomes: np.ndarray) -\u003e float:\n    \"\"\"Calculates Brier score, handling NaNs in outcomes.\"\"\"\n    mask \u003d ~np.isnan(outcomes)\n    if mask.sum() \u003d\u003d 0: return np.nan\n    return float(np.mean((preds[mask] - outcomes[mask])**2))\n\ndef logical_consistency_rate(df: pd.DataFrame) -\u003e float:\n    \"\"\"Calculates the rate of events where the QA constraint held.\"\"\"\n    if len(df) \u003d\u003d 0: return np.nan\n    return float(np.mean(df[\"logical_ok\"]))\n\n# --------------------------- Market Fetch ------------------------\n\ndef get_market_events(limit: int \u003d 120, offline: bool \u003d False) -\u003e pd.DataFrame:\n    \"\"\"\n    Fetches market events from API or cache.\n    Falls back to synthetic data if no live data and no cache.\n    \"\"\"\n    if offline:\n        log(\"[mode] OFFLINE — synthetic events generated.\")\n        df \u003d synth_events(limit)\n        cache_save(df)\n        return df\n\n    df \u003d fetch_markets(limit\u003dlimit)\n    if df is not None and len(df):\n        cache_save(df)\n        return df\n\n    log(\"[error] live fetch failed; attempting cache…\")\n    cached \u003d cache_load()\n    if cached is not None and len(cached):\n        return cached\n\n    log(\"[fallback] no live data \u0026 no cache — switching to synthetic events.\")\n    df \u003d synth_events(limit)\n    cache_save(df)\n    return df\n\ndef fetch_markets(limit: int) -\u003e Optional[pd.DataFrame]:\n    \"\"\"Tries primary, then alt endpoint. Returns normalized DataFrame or None.\"\"\"\n    params \u003d {\"limit\": str(limit)}\n    data \u003d safe_request(PRIMARY_URL, params\u003dparams)\n    if data is None:\n        log(\"[info] trying alternate Manifold endpoint…\")\n        data \u003d safe_request(ALT_URL, params\u003dparams)\n    if data is None:\n        return None\n\n    rows \u003d []\n    for m in data:\n        # Only process binary YES/NO markets with a probability\n        p \u003d m.get(\"probability\", None)\n        if p is None or m.get(\"outcomeType\") !\u003d \"BINARY\":\n            continue\n        \n        is_resolved \u003d bool(m.get(\"isResolved\", False))\n        res \u003d m.get(\"resolution\", None)\n        outcome \u003d np.nan\n        if is_resolved and res in (\"YES\", \"NO\"):\n            outcome \u003d 1.0 if res \u003d\u003d \"YES\" else 0.0\n\n        rows.append({\n            \"id\": m.get(\"id\", \"\"),\n            \"question\": m.get(\"question\", \"\")[:200],\n            \"p_market\": float(p),\n            \"resolved\": is_resolved,\n            \"outcome\": outcome,\n            \"closeTime\": m.get(\"closeTime\", 0) # For chronological split\n        })\n    if not rows:\n        return None\n    \n    df \u003d pd.DataFrame(rows)\n    # Convert closeTime to datetime and sort for chronological splits\n    df[\u0027closeTime\u0027] \u003d pd.to_datetime(df[\u0027closeTime\u0027], unit\u003d\u0027ms\u0027)\n    df \u003d df.sort_values(by\u003d\u0027closeTime\u0027).reset_index(drop\u003dTrue)\n    return df\n\n# ----------------------- Feature Engineering ----------------------\n\ndef infer_domain(question: str) -\u003e str:\n    \"\"\"Infers the domain of a market question based on keywords.\"\"\"\n    question_lower \u003d question.lower()\n    for domain, keywords in DOMAIN_KEYWORDS.items():\n        if any(kw in question_lower for kw in keywords):\n            return domain\n    return \"misc\" # Default category\n\ndef build_feature_dataframe(df_raw: pd.DataFrame, tau: float) -\u003e pd.DataFrame:\n    \"\"\"\n    Builds the full feature set including market log-odds, QA vector,\n    logical_ok status, and domain one-hot encoding.\n    \"\"\"\n    rows \u003d []\n    for _, ev in df_raw.iterrows():\n        b, e \u003d deterministic_be_from_id(ev[\"id\"])\n        b, e, d, a \u003d qa_tuple(b, e)\n        logical_ok \u003d qa_valid(b, e, d, a)\n        \n        qa_feats \u003d qa_feature_vector(b, e, tau\u003dtau)\n        \n        row_dict \u003d {\n            \"id\": ev[\"id\"],\n            \"question\": ev[\"question\"],\n            \"p_market\": float(ev[\"p_market\"]),\n            \"z_market\": float(np.log(ev[\"p_market\"] / (1 - ev[\"p_market\"]))), # Logit(p_market)\n            **qa_feats, # Unpack QA features\n            \"logical_ok\": logical_ok,\n            \"resolved\": bool(ev[\"resolved\"]),\n            \"outcome\": ev[\"outcome\"],\n            \"b\": b, \"e\": e, \"d\": d, \"a\": a,\n            \"closeTime\": ev[\"closeTime\"]\n        }\n        \n        # Add domain one-hot encoding\n        domain \u003d infer_domain(ev[\"question\"])\n        for d_name in DOMAINS:\n            row_dict[f\"domain_{d_name}\"] \u003d 1 if d_name \u003d\u003d domain else 0\n            \n        rows.append(row_dict)\n    \n    return pd.DataFrame(rows)\n\n# ------------------------ PLA core: training ------------------------\n\ndef train_and_evaluate(\n    df_resolved: pd.DataFrame, \n    tau_grid: np.ndarray, \n    train_ratio: float \u003d 0.7\n) -\u003e Dict[str, Any]:\n    \"\"\"\n    Trains and evaluates the hybrid model using resolved historical data.\n    Performs grid search for \u0027tau\u0027 using a chronological train/validation split.\n    \"\"\"\n    log(f\"[train] Training on {len(df_resolved)} resolved events.\")\n    \n    # Chronological train/validation split\n    split_point \u003d int(len(df_resolved) * train_ratio)\n    train_df \u003d df_resolved.iloc[:split_point]\n    val_df \u003d df_resolved.iloc[split_point:]\n    \n    if len(val_df) \u003c 5:\n        log(\"[warn] Not enough validation data for robust tuning. Using full resolved for tuning.\")\n        train_df \u003d df_resolved.copy()\n        val_df \u003d df_resolved.copy() # Use same for validation, accept potential overfitting bias\n    \n    best_tau \u003d None\n    best_val_brier \u003d np.inf\n    best_model \u003d None\n    \n    feature_cols \u003d [\"z_market\"] + list(qa_feature_vector(1,1).keys()) + [f\"domain_{d}\" for d in DOMAINS]\n\n    # Grid search for optimal tau\n    for tau in tau_grid:\n        train_feats \u003d build_feature_dataframe(train_df, tau\u003dtau)\n        val_feats \u003d build_feature_dataframe(val_df, tau\u003dtau)\n        \n        X_train \u003d train_feats[feature_cols].values\n        y_train \u003d train_feats[\"outcome\"].values\n        X_val \u003d val_feats[feature_cols].values\n        y_val \u003d val_feats[\"outcome\"].values\n        \n        # Logistic Regression with L2 regularization\n        model \u003d LogisticRegression(solver\u003d\u0027liblinear\u0027, C\u003d5.0, max_iter\u003d2000, random_state\u003d42)\n        model.fit(X_train, y_train)\n        \n        # Evaluate on validation set\n        val_preds \u003d model.predict_proba(X_val)[:, 1]\n        current_brier \u003d brier_score(val_preds, y_val)\n        \n        if not np.isnan(current_brier) and current_brier \u003c best_val_brier:\n            best_val_brier \u003d current_brier\n            best_tau \u003d tau\n            best_model \u003d model\n            log(f\"[tune] Tau\u003d{tau:.3g} -\u003e Val Brier\u003d{current_brier:.4f}\")\n\n    if best_model is None:\n        log(\"[error] No suitable model found during tuning. Using default tau\u003d1.0 and re-training.\")\n        best_tau \u003d 1.0\n        train_feats \u003d build_feature_dataframe(train_df, tau\u003dbest_tau)\n        X_train \u003d train_feats[feature_cols].values\n        y_train \u003d train_feats[\"outcome\"].values\n        best_model \u003d LogisticRegression(solver\u003d\u0027liblinear\u0027, C\u003d5.0, max_iter\u003d2000, random_state\u003d42)\n        best_model.fit(X_train, y_train)\n\n    log(f\"[train] Optimal tau found: {best_tau:.3g} (Val Brier: {best_val_brier:.4f})\")\n    \n    # Store learned coefficients\n    feature_names \u003d feature_cols\n    params \u003d {\n        \"best_tau\": best_tau,\n        \"intercept\": float(best_model.intercept_[0]),\n        \"coefficients\": {name: float(coef) for name, coef in zip(feature_names, best_model.coef_[0])},\n        \"feature_cols\": feature_cols # To re-create feature matrix later\n    }\n    with open(PARAMS_FILE, \u0027w\u0027) as f:\n        json.dump(params, f, indent\u003d2)\n    log(f\"[params] Learned parameters saved to {PARAMS_FILE}\")\n\n    # Final evaluation on the full resolved dataset using the best model\n    full_feats \u003d build_feature_dataframe(df_resolved, tau\u003dbest_tau)\n    X_full \u003d full_feats[feature_cols].values\n    y_full \u003d full_feats[\"outcome\"].values\n    \n    p_market_full \u003d full_feats[\"p_market\"].values\n    p_hybrid_full \u003d best_model.predict_proba(X_full)[:, 1]\n    \n    bs_market \u003d brier_score(p_market_full, y_full)\n    bs_hybrid \u003d brier_score(p_hybrid_full, y_full)\n    lcr \u003d logical_consistency_rate(full_feats)\n\n    # Isotonic Calibration (optional, for post-hoc calibration)\n    calibrated_model \u003d CalibratedClassifierCV(best_model, method\u003d\u0027isotonic\u0027, cv\u003d\"prefit\")\n    calibrated_model.fit(X_full, y_full)\n    p_hybrid_calibrated \u003d calibrated_model.predict_proba(X_full)[:, 1]\n    bs_calibrated \u003d brier_score(p_hybrid_calibrated, y_full)\n    \n    log(f\"\\n[results: historical backtest on {len(df_resolved)} resolved events]\")\n    log(f\" Brier (market): {bs_market:.4f}\")\n    log(f\" Brier (hybrid - tuned logistic): {bs_hybrid:.4f}\")\n    log(f\" Brier (hybrid - isotonic calibrated): {bs_calibrated:.4f}\")\n    log(f\" Logical Consistency Rate: {lcr:.2%}\")\n\n    df_resolved[\u0027p_hybrid_tuned\u0027] \u003d p_hybrid_full\n    df_resolved[\u0027p_hybrid_calibrated\u0027] \u003d p_hybrid_calibrated\n\n    return {\n        \"best_model\": best_model,\n        \"best_tau\": best_tau,\n        \"feature_cols\": feature_cols,\n        \"df_evaluated\": df_resolved, # Returns df with hybrid predictions for resolved\n        \"metrics\": {\n            \"brier_market\": bs_market,\n            \"brier_hybrid_tuned\": bs_hybrid,\n            \"brier_hybrid_calibrated\": bs_calibrated,\n            \"lcr\": lcr\n        }\n    }\n\n# ------------------------ PLA core: live forecasting ------------------------\n\ndef forecast_live_events(\n    df_unresolved: pd.DataFrame, \n    model: LogisticRegression, \n    tau: float, \n    feature_cols: List[str]\n) -\u003e pd.DataFrame:\n    \"\"\"\n    Applies the trained model to make predictions on unresolved events.\n    \"\"\"\n    log(f\"[live] Forecasting {len(df_unresolved)} unresolved events.\")\n    if len(df_unresolved) \u003d\u003d 0:\n        log(\"[live] No unresolved events to forecast.\")\n        return pd.DataFrame()\n\n    live_feats \u003d build_feature_dataframe(df_unresolved, tau\u003dtau)\n    X_live \u003d live_feats[feature_cols].values\n    \n    # Predict probabilities\n    p_hybrid_live \u003d model.predict_proba(X_live)[:, 1]\n    \n    df_unresolved[\u0027p_hybrid_live\u0027] \u003d p_hybrid_live\n    df_unresolved[\u0027p_qa_prior\u0027] \u003d live_feats[\u0027q_cos_theta\u0027] # Just for display/checking\n    df_unresolved[\u0027logical_ok\u0027] \u003d live_feats[\u0027logical_ok\u0027]\n    df_unresolved[\u0027domain\u0027] \u003d df_unresolved[\u0027question\u0027].apply(infer_domain)\n\n    log(f\"[live] Generated {len(df_unresolved)} live hybrid forecasts.\")\n    return df_unresolved\n\n# ------------------------------ Main ------------------------------\n\ndef run_prophetic_logic_arena():\n    args \u003d parse_args()\n\n    log(f\"--- Prophetic Logic Arena v2.0 {\u0027(LIVE MODE)\u0027 if args.live else \u0027(HISTORICAL BACKTEST)\u0027} ---\")\n    df_raw \u003d get_market_events(limit\u003dargs.limit, offline\u003dargs.offline)\n\n    # Split into resolved and unresolved\n    resolved_df \u003d df_raw[df_raw[\"resolved\"] \u0026 ~df_raw[\"outcome\"].isna()].copy()\n    unresolved_df \u003d df_raw[~df_raw[\"resolved\"]].copy()\n\n    log(f\"\\n[info] Total events fetched: {len(df_raw)}\")\n    log(f\"[info] Resolved for training/evaluation: {len(resolved_df)}\")\n    log(f\"[info] Unresolved for live forecasting: {len(unresolved_df)}\")\n\n    # Define the grid for tau search\n    tau_grid \u003d np.geomspace(0.05, 5.0, 15) # From very flat to very sharp QA priors\n\n    if args.live:\n        # Live mode: load parameters, then forecast\n        if not os.path.exists(PARAMS_FILE):\n            log(\"[error] No pre-trained parameters found for live mode. Please run in historical mode first.\")\n            sys.exit(1)\n        \n        with open(PARAMS_FILE, \u0027r\u0027) as f:\n            params \u003d json.load(f)\n        \n        model \u003d LogisticRegression(solver\u003d\u0027liblinear\u0027, C\u003d5.0, max_iter\u003d2000, random_state\u003d42)\n        model.intercept_ \u003d np.array([params[\u0027intercept\u0027]])\n        model.coef_ \u003d np.array([list(params[\u0027coefficients\u0027].values())])\n        best_tau \u003d params[\u0027best_tau\u0027]\n        feature_cols \u003d params[\u0027feature_cols\u0027]\n\n        # NOTE: For true live forecasting, you\u0027d fit CalibratedClassifierCV on resolved\n        # data and use `calibrated_model.predict_proba` here.\n        # For simplicity, we just use the raw LogisticRegression output for live.\n\n        forecasted_df \u003d forecast_live_events(unresolved_df, model, best_tau, feature_cols)\n        \n        # Save results (unresolved only)\n        final_results_df \u003d forecasted_df[[\u0027id\u0027, \u0027question\u0027, \u0027p_market\u0027, \u0027p_hybrid_live\u0027, \u0027p_qa_prior\u0027, \u0027logical_ok\u0027, \u0027domain\u0027]].copy()\n        final_results_df.rename(columns\u003d{\u0027p_hybrid_live\u0027: \u0027p_hybrid\u0027}, inplace\u003dTrue)\n        final_results_df.to_csv(RESULTS_FILE, index\u003dFalse)\n        log(f\"[done] Live forecasts saved to {RESULTS_FILE}\")\n\n        # Plot market vs. hybrid for unresolved\n        if not final_results_df.empty:\n            plt.figure(figsize\u003d(8,5))\n            plt.scatter(final_results_df[\"p_market\"], final_results_df[\"p_hybrid\"], alpha\u003d0.6, s\u003d15, edgecolor\u003d\u0027k\u0027)\n            plt.plot([0,1],[0,1],\u0027k--\u0027,lw\u003d1)\n            plt.xlabel(\"Market probability\")\n            plt.ylabel(\"Hybrid (QA-Logit) probability\")\n            plt.title(f\"Live QA-Hybrid Forecasts vs Market (τ\u003d{best_tau:.2g})\")\n            plt.grid(True, linestyle\u003d\u0027--\u0027, alpha\u003d0.7)\n            plt.tight_layout()\n            plt.savefig(PLOT_FILE, dpi\u003d180)\n            plt.show()\n            log(f\"[plot] Saved live forecast plot to {PLOT_FILE}\")\n\n    else:\n        # Historical backtest mode\n        if len(resolved_df) \u003c 20: # Require a minimum for meaningful training\n            log(\"[error] Not enough resolved events (need at least 20) for historical backtest. Try --offline or wait for more markets to resolve.\")\n            sys.exit(1)\n\n        train_eval_results \u003d train_and_evaluate(resolved_df, tau_grid)\n        df_evaluated \u003d train_eval_results[\"df_evaluated\"]\n        \n        # Combine evaluated resolved with raw unresolved for a complete output file\n        # Note: Unresolved markets don\u0027t have p_hybrid_tuned/calibrated yet without a live forecast run\n        out_all \u003d pd.concat([\n            df_evaluated[[\u0027id\u0027, \u0027question\u0027, \u0027p_market\u0027, \u0027p_hybrid_tuned\u0027, \u0027p_hybrid_calibrated\u0027, \u0027outcome\u0027, \u0027resolved\u0027, \u0027logical_ok\u0027, \u0027closeTime\u0027]],\n            unresolved_df[[\u0027id\u0027, \u0027question\u0027, \u0027p_market\u0027, \u0027outcome\u0027, \u0027resolved\u0027, \u0027closeTime\u0027]]\n        ], ignore_index\u003dTrue, sort\u003dFalse)\n        out_all.rename(columns\u003d{\u0027p_hybrid_tuned\u0027: \u0027p_hybrid\u0027, \u0027p_hybrid_calibrated\u0027: \u0027p_hybrid_iso_calibrated\u0027}, inplace\u003dTrue)\n        out_all.to_csv(RESULTS_FILE, index\u003dFalse)\n        log(f\"[done] Historical backtest results saved to {RESULTS_FILE}\")\n\n        # Plot resolved market vs. hybrid\n        plt.figure(figsize\u003d(8,5))\n        plt.scatter(df_evaluated[\"p_market\"], df_evaluated[\"p_hybrid_tuned\"], alpha\u003d0.6, s\u003d15, edgecolor\u003d\u0027k\u0027)\n        plt.plot([0,1],[0,1],\u0027k--\u0027,lw\u003d1)\n        plt.xlabel(\"Market probability\")\n        plt.ylabel(\"Hybrid (QA-Logit) probability\")\n        plt.title(f\"Historical QA-Hybrid Forecasts vs Market (τ\u003d{train_eval_results[\u0027best_tau\u0027]:.2g})\")\n        plt.grid(True, linestyle\u003d\u0027--\u0027, alpha\u003d0.7)\n        plt.tight_layout()\n        plt.savefig(PLOT_FILE, dpi\u003d180)\n        plt.show()\n        log(f\"[plot] Saved historical backtest plot to {PLOT_FILE}\")\n\nif __name__ \u003d\u003d \"__main__\":\n    try:\n        run_prophetic_logic_arena()\n    except Exception as e:\n        log(f\"[fatal] An unexpected error occurred: {e}\")\n        sys.exit(1)\n\n```",
